{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/gaas",
      "destination": "/agentic-as-a-service/",
      "permanent": true
    },
    {
      "source": "/gaas/",
      "destination": "/agentic-as-a-service/",
      "permanent": true
    },
    {
      "source": "/resources/gaas-guide",
      "destination": "/resources/what-is-gaas/",
      "permanent": true
    },
    {
      "source": "/resources/gaas-guide/",
      "destination": "/resources/what-is-gaas/",
      "permanent": true
    },
    {
      "source": "/resources/gaas-vs-saas",
      "destination": "/resources/what-is-gaas/#gaas-vs-saas",
      "permanent": true
    },
    {
      "source": "/resources/gaas-vs-saas/",
      "destination": "/resources/what-is-gaas/#gaas-vs-saas",
      "permanent": true
    }
  ]
}
