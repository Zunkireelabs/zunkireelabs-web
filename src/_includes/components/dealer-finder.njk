{# =====================================================
   Dealer Finder — listens for 'product-selected' event
   Shows nearby dealers for the selected product's brand.
   ===================================================== #}

<div
  x-data="dealerFinder()"
  x-init="init()"
  id="dealer-finder"
  class="w-full max-w-5xl mx-auto scroll-mt-24"
>

  {# ── Empty state ── #}
  <div x-show="!brand" x-transition class="text-center py-14 px-6 bg-white border border-dashed border-gray-300 rounded-2xl">
    <div class="w-14 h-14 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-7 h-7 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
    </div>
    <p class="text-gray-500 text-sm">Select a product above to find nearby dealers</p>
  </div>

  {# ── Active state ── #}
  <div x-show="brand" x-transition class="space-y-5">

    {# Product + search bar #}
    <div class="bg-white border border-gray-200 rounded-2xl px-5 py-4 space-y-4">

      {# Product context pill #}
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-zunkiree-50 rounded-full flex-shrink-0 flex items-center justify-center">
          <svg class="w-4 h-4 text-zunkiree-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-gray-400 font-medium">Finding dealers for</p>
          <p class="text-base font-medium text-gray-900">
            <span x-text="brand"></span>
            <span class="text-gray-400 font-normal" x-show="productName !== brand"> — <span x-text="productName"></span></span>
          </p>
        </div>
      </div>

      {# City input row #}
      <div class="flex gap-2 flex-wrap sm:flex-nowrap">
        <div class="relative flex-1 min-w-0">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <input
            x-model="city"
            @keydown.enter="searchDealers()"
            type="text"
            placeholder="Enter your city (e.g. Kathmandu)"
            class="w-full pl-9 pr-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-zunkiree-400 focus:ring-2 focus:ring-zunkiree-100 transition-colors"
          />
        </div>

        {# Geolocation #}
        <button
          @click="useMyLocation()"
          :disabled="geoLoading"
          title="Use my location"
          class="flex items-center gap-1.5 px-3.5 py-2.5 border border-gray-200 text-gray-600 text-sm rounded-xl hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors flex-shrink-0"
        >
          <svg x-show="!geoLoading" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          <svg x-show="geoLoading" class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <span class="hidden sm:inline" x-text="geoLoading ? 'Locating...' : 'My location'"></span>
        </button>

        {# Search #}
        <button
          @click="searchDealers()"
          :disabled="loading || (!city.trim() && !coords)"
          class="flex items-center gap-2 px-5 py-2.5 bg-zunkiree-600 text-white text-sm font-medium rounded-xl hover:bg-zunkiree-700 disabled:opacity-40 disabled:cursor-not-allowed transition-colors flex-shrink-0"
        >
          <svg x-show="loading" class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <svg x-show="!loading" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <span x-text="loading ? 'Searching...' : 'Search'"></span>
        </button>
      </div>

      <p x-show="geoError" class="text-xs text-red-500" x-text="geoError"></p>
      <p x-show="searchError" class="text-xs text-red-500" x-text="searchError"></p>
    </div>

    {# ── Results ── #}
    <div x-show="dealers.length > 0" x-transition class="grid grid-cols-1 lg:grid-cols-5 gap-5">

      {# Dealer cards (left) #}
      <div class="lg:col-span-2 space-y-3">

        <div class="flex items-center justify-between mb-1">
          <p class="text-sm font-medium text-gray-700">
            <span x-text="dealers.length"></span> dealers near
            <span class="text-zunkiree-600" x-text="searchedCity"></span>
          </p>
          <a
            :href="mapsSearchUrl"
            target="_blank"
            class="text-xs text-zunkiree-600 hover:text-zunkiree-700 underline underline-offset-2"
          >View all on Maps →</a>
        </div>

        <template x-for="dealer in dealers" :key="dealer.id">
          <div class="bg-white border rounded-xl p-4 transition-all"
               :class="dealer.is_verified ? 'border-zunkiree-200 shadow-sm' : 'border-gray-200'">

            {# Header row #}
            <div class="flex items-start justify-between gap-2 mb-2">
              <div class="min-w-0">
                <div class="flex items-center gap-1.5 flex-wrap mb-0.5">
                  <span x-show="dealer.is_verified"
                        class="inline-flex items-center gap-1 text-[10px] font-semibold text-zunkiree-700 bg-zunkiree-50 border border-zunkiree-200 px-2 py-0.5 rounded-full">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                    </svg>
                    Verified Partner
                  </span>
                </div>
                <h4 class="text-sm font-semibold text-gray-900 leading-snug" x-text="dealer.name"></h4>
              </div>
              {# Open/Closed badge #}
              <span
                x-show="dealer.open_now !== null && dealer.open_now !== undefined"
                class="text-[10px] font-medium px-2 py-0.5 rounded-full flex-shrink-0"
                :class="dealer.open_now ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-600'"
                x-text="dealer.open_now ? 'Open' : 'Closed'"
              ></span>
            </div>

            {# Address #}
            <p class="text-xs text-gray-500 mb-2 flex items-start gap-1">
              <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span x-text="dealer.address"></span>
            </p>

            {# Rating #}
            <div x-show="dealer.rating" class="flex items-center gap-1.5 mb-3">
              <div class="flex items-center gap-0.5">
                <template x-for="i in 5" :key="i">
                  <svg
                    class="w-3.5 h-3.5"
                    :class="i <= Math.round(dealer.rating) ? 'text-amber-400' : 'text-gray-200'"
                    fill="currentColor" viewBox="0 0 24 24"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                </template>
              </div>
              <span class="text-xs text-gray-600 font-medium" x-text="dealer.rating?.toFixed(1)"></span>
              <span class="text-xs text-gray-400" x-show="dealer.user_ratings_total" x-text="'(' + dealer.user_ratings_total + ')'"></span>
            </div>

            {# Actions #}
            <div class="flex gap-2">
              <a
                x-show="dealer.phone"
                :href="'tel:' + dealer.phone"
                class="flex-1 flex items-center justify-center gap-1.5 py-2 border border-gray-200 text-xs font-medium text-gray-700 rounded-lg hover:bg-gray-50 transition-colors"
              >
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                Call
              </a>
              <a
                :href="dealer.maps_url || 'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(dealer.name + ' ' + dealer.address)"
                target="_blank"
                rel="noopener noreferrer"
                class="flex-1 flex items-center justify-center gap-1.5 py-2 bg-zunkiree-600 text-white text-xs font-medium rounded-lg hover:bg-zunkiree-700 transition-colors"
              >
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                </svg>
                Directions
              </a>
            </div>

          </div>
        </template>
      </div>

      {# Map (right) #}
      <div class="lg:col-span-3 rounded-2xl overflow-hidden bg-gray-100 border border-gray-200" style="min-height: 380px;">

        {# Embedded map (when API key available) #}
        <iframe
          x-show="mapEmbedUrl"
          :src="mapEmbedUrl"
          width="100%"
          height="100%"
          style="min-height: 380px; border: 0;"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>

        {# Fallback: no embed key — show a map placeholder with open link #}
        <div
          x-show="!mapEmbedUrl"
          class="w-full h-full flex flex-col items-center justify-center gap-4 p-8 text-center"
          style="min-height: 380px;"
        >
          <div class="w-16 h-16 bg-white rounded-full shadow flex items-center justify-center">
            <svg class="w-8 h-8 text-zunkiree-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-gray-700 mb-1"><span x-text="dealers.length"></span> dealers found</p>
            <p class="text-xs text-gray-400 mb-4">Open Google Maps to see all locations</p>
            <a
              :href="mapsSearchUrl"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#1A73E8] text-white text-sm font-medium rounded-xl hover:bg-[#1558B0] transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              Open in Google Maps
            </a>
          </div>
        </div>

      </div>
    </div>

    {# No results state #}
    <div
      x-show="searched && !loading && dealers.length === 0"
      class="text-center py-12 bg-white border border-gray-200 rounded-2xl"
    >
      <p class="text-gray-500 text-sm">No dealers found in <strong x-text="searchedCity"></strong>.</p>
      <p class="text-gray-400 text-xs mt-1">Try a different city or check Google Maps directly.</p>
      <a :href="mapsSearchUrl" target="_blank" class="inline-block mt-4 text-sm text-zunkiree-600 underline underline-offset-2">Search on Google Maps →</a>
    </div>

  </div>
</div>

<script>
const MOCK_DEALERS_CLIENT = [
  { id: 'c1',  brand: 'apple',   name: 'iStore Nepal',                       address: 'Durbarmarg, Kathmandu',     city: 'Kathmandu', phone: '+977-1-4222112', rating: 4.6, user_ratings_total: 184, is_verified: true,  open_now: true,  source: 'verified' },
  { id: 'c2',  brand: 'apple',   name: 'Evo Store — Apple Authorised',       address: 'Labim Mall, Lalitpur',      city: 'Kathmandu', phone: '+977-1-5970000', rating: 4.5, user_ratings_total: 132, is_verified: true,  open_now: true,  source: 'verified' },
  { id: 'c3',  brand: 'apple',   name: 'Connect Plus',                       address: 'Civil Mall, New Road',      city: 'Kathmandu', phone: '+977-1-4232256', rating: 4.2, user_ratings_total: 89,  is_verified: false, open_now: false, source: 'google' },
  { id: 'c4',  brand: 'samsung', name: 'Samsung SmartCafé Nepal',            address: 'Thamel, Kathmandu',         city: 'Kathmandu', phone: '+977-1-4901234', rating: 4.5, user_ratings_total: 184, is_verified: true,  open_now: true,  source: 'verified' },
  { id: 'c5',  brand: 'samsung', name: 'Samsung Plaza',                      address: 'Bhatbhateni, Maharajgunj',  city: 'Kathmandu', phone: '+977-1-4426789', rating: 4.3, user_ratings_total: 102, is_verified: true,  open_now: true,  source: 'verified' },
  { id: 'c6',  brand: 'oneplus', name: 'OnePlus Exclusive Store Nepal',      address: 'New Road, Kathmandu',       city: 'Kathmandu', phone: '+977-1-4345678', rating: 4.3, user_ratings_total: 92,  is_verified: true,  open_now: true,  source: 'verified' },
  { id: 'c7',  brand: 'oneplus', name: 'Tech World Nepal',                   address: 'Durbarmarg, Kathmandu',     city: 'Kathmandu', phone: '+977-1-4567812', rating: 4.1, user_ratings_total: 67,  is_verified: false, open_now: false, source: 'google' },
  { id: 'c8',  brand: 'xiaomi',  name: 'Mi Store Nepal',                     address: 'Putalisadak, Kathmandu',    city: 'Kathmandu', phone: '+977-1-4421100', rating: 4.4, user_ratings_total: 156, is_verified: true,  open_now: true,  source: 'verified' },
  { id: 'c9',  brand: 'google',  name: 'Pixel Authorised — TechHub',         address: 'Kamaladi, Kathmandu',       city: 'Kathmandu', phone: '+977-1-4256789', rating: 4.2, user_ratings_total: 54,  is_verified: false, open_now: true,  source: 'google' },
  { id: 'c10', brand: 'realme',  name: 'Realme Brand Store',                 address: 'Putalisadak, Kathmandu',    city: 'Kathmandu', phone: '+977-1-4789098', rating: 4.0, user_ratings_total: 41,  is_verified: true,  open_now: true,  source: 'verified' },
  { id: 'c11', brand: 'yamaha',  name: 'Yamaha Official Nepal',              address: 'New Baneshwor, Kathmandu',  city: 'Kathmandu', phone: '+977-1-4789012', rating: 4.4, user_ratings_total: 156, is_verified: true,  open_now: true,  source: 'verified' },
  { id: 'c12', brand: 'honda',   name: 'Honda Authorized Nepal',             address: 'Bag Bazaar, Kathmandu',     city: 'Kathmandu', phone: '+977-1-4234567', rating: 4.6, user_ratings_total: 210, is_verified: true,  open_now: true,  source: 'verified' },
  { id: 'c13', brand: 'bajaj',   name: 'Bajaj Sales & Service',              address: 'Tinkune, Kathmandu',        city: 'Kathmandu', phone: '+977-1-4111234', rating: 4.2, user_ratings_total: 88,  is_verified: true,  open_now: true,  source: 'verified' },
  { id: 'c14', brand: 'tvs',     name: 'TVS Motors — Authorised Showroom',   address: 'Balaju, Kathmandu',         city: 'Kathmandu', phone: '+977-1-4359000', rating: 4.1, user_ratings_total: 65,  is_verified: true,  open_now: true,  source: 'verified' },
  { id: 'c15', brand: 'suzuki',  name: 'Suzuki Two-Wheeler Showroom',        address: 'Thapathali, Kathmandu',     city: 'Kathmandu', phone: '+977-1-4112233', rating: 4.0, user_ratings_total: 49,  is_verified: false, open_now: true,  source: 'google' },
  { id: 'c16', brand: 'hero',    name: 'Hero MotoCorp Authorized Showroom',  address: 'Kamaladi, Kathmandu',       city: 'Kathmandu', phone: '+977-1-4123456', rating: 4.5, user_ratings_total: 128, is_verified: true,  open_now: true,  source: 'verified' },
  { id: 'c17', brand: 'lg',      name: 'LG Authorised Service',              address: 'Thapathali, Kathmandu',     city: 'Kathmandu', phone: '+977-1-4234123', rating: 4.0, user_ratings_total: 45,  is_verified: false, open_now: true,  source: 'google' },
  { id: 'c18', brand: 'sony',    name: 'Sony Centre Nepal',                  address: 'New Road, Kathmandu',       city: 'Kathmandu', phone: '+977-1-4234500', rating: 4.3, user_ratings_total: 73,  is_verified: true,  open_now: true,  source: 'verified' },
  { id: 'c19', brand: 'daikin',  name: 'Daikin Nepal Official Dealer',       address: 'Putalisadak, Kathmandu',    city: 'Kathmandu', phone: '+977-1-4678901', rating: 4.3, user_ratings_total: 61,  is_verified: true,  open_now: true,  source: 'verified' }
];

function mockDealerSearch(brand, city) {
  const b = (brand || '').toLowerCase();
  const c = (city || 'Kathmandu').trim();
  const matches = MOCK_DEALERS_CLIENT.filter(d => d.brand === b);
  return {
    dealers: matches,
    city: c,
    map_embed_url: null,
    maps_search_url: `https://www.google.com/maps/search/${encodeURIComponent(brand + ' dealer ' + c)}`
  };
}

function dealerFinder() {
  return {
    brand: '',
    productName: '',
    city: '',
    coords: null,
    dealers: [],
    mapEmbedUrl: null,
    mapsSearchUrl: '#',
    searchedCity: '',
    loading: false,
    geoLoading: false,
    geoError: '',
    searchError: '',
    searched: false,

    init() {
      window.addEventListener('product-selected', (e) => {
        const product = e.detail.product;
        this.brand       = product.brand || product.name.split(' ')[0];
        this.productName = product.name;
        this.dealers     = [];
        this.searched    = false;
        this.mapEmbedUrl = null;
        this.coords      = null;
        this.searchError = '';
      });
    },

    async useMyLocation() {
      if (!navigator.geolocation) {
        this.geoError = 'Geolocation not supported by your browser.';
        return;
      }
      this.geoLoading = true;
      this.geoError = '';
      try {
        const pos = await new Promise((resolve, reject) =>
          navigator.geolocation.getCurrentPosition(resolve, reject, { timeout: 8000 })
        );
        this.coords = { lat: pos.coords.latitude, lng: pos.coords.longitude };
        this.city = '';
        await this.searchDealers();
      } catch (e) {
        this.geoError = e.code === 1
          ? 'Location access denied. Please type your city instead.'
          : 'Could not get your location. Please type your city.';
      }
      this.geoLoading = false;
    },

    async searchDealers() {
      if (!this.brand) return;
      const hasCity   = this.city.trim();
      const hasCoords = this.coords;
      if (!hasCity && !hasCoords) {
        this.searchError = 'Enter a city or use your location first.';
        return;
      }

      this.loading     = true;
      this.searchError = '';
      this.dealers     = [];
      this.searched    = false;

      const applyResult = (data) => {
        this.dealers      = data.dealers || [];
        this.mapEmbedUrl  = data.map_embed_url || null;
        this.mapsSearchUrl= data.maps_search_url || '#';
        this.searchedCity = data.city || this.city || 'your location';
      };

      try {
        const params = new URLSearchParams({ brand: this.brand });
        if (hasCity)   { params.set('city', this.city.trim()); }
        if (hasCoords) { params.set('lat', this.coords.lat); params.set('lng', this.coords.lng); }

        const res  = await fetch(`/api/dealers?${params}`);
        const text = await res.text();
        // Empty body / non-JSON → API unreachable (e.g. eleventy dev server) → fall back to embedded mock
        if (!text) { applyResult(mockDealerSearch(this.brand, this.city)); }
        else {
          let data;
          try { data = JSON.parse(text); } catch { applyResult(mockDealerSearch(this.brand, this.city)); data = null; }
          if (data) {
            if (!res.ok) throw new Error(data.error || 'Search failed');
            applyResult(data);
          }
        }
      } catch (e) {
        if (e.name === 'TypeError') {
          // network failure → use embedded mock
          applyResult(mockDealerSearch(this.brand, this.city));
        } else {
          this.searchError = e.message;
        }
      }

      this.loading  = false;
      this.searched = true;

      this.$nextTick(() => {
        if (this.dealers.length) {
          this.$el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    }
  };
}
</script>
