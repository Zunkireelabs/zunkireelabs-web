{# =====================================================
   AI Shopping Agent Chat Widget
   Usage: {% include "components/shopping-agent.njk" %}
   ===================================================== #}

<div
  x-data="shoppingAgent()"
  x-init="init()"
  class="w-full max-w-2xl mx-auto"
  id="shopping-agent"
>

  {# Chat Window #}
  <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-lg">

    {# Header #}
    <div class="flex items-center gap-3 px-5 py-4 bg-zunkiree-600 text-white">
      <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center flex-shrink-0">
        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-white">AI Shopping Assistant</p>
        <p class="text-xs text-white/70">Powered by Zunkiree Labs</p>
      </div>
      <div class="ml-auto flex items-center gap-1.5">
        <span class="w-2 h-2 bg-green-400 rounded-full"></span>
        <span class="text-xs text-white/70">Online</span>
      </div>
    </div>

    {# Messages #}
    <div
      class="h-96 overflow-y-auto p-5 space-y-4 bg-gray-50"
      x-ref="messagesContainer"
    >
      {# Welcome message #}
      <div class="flex gap-3">
        <div class="w-7 h-7 bg-zunkiree-600 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
          <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <div class="bg-white rounded-2xl rounded-tl-none px-4 py-3 shadow-sm border border-gray-100 max-w-xs">
          <p class="text-sm text-gray-700">Hi! Tell me what product you're looking for and your budget — I'll find the best options for you.</p>
        </div>
      </div>

      {# Dynamic messages #}
      <template x-for="msg in messages" :key="msg.id">
        <div>
          {# User message #}
          <div x-show="msg.role === 'user'" class="flex justify-end">
            <div class="bg-zunkiree-600 text-white rounded-2xl rounded-tr-none px-4 py-3 max-w-xs shadow-sm">
              <p class="text-sm" x-text="msg.text"></p>
            </div>
          </div>

          {# Assistant text message #}
          <div x-show="msg.role === 'assistant' && msg.type === 'text'" class="flex gap-3">
            <div class="w-7 h-7 bg-zunkiree-600 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
              <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
              </svg>
            </div>
            <div class="bg-white rounded-2xl rounded-tl-none px-4 py-3 shadow-sm border border-gray-100 max-w-sm">
              <p class="text-sm text-gray-700" x-text="msg.text"></p>
            </div>
          </div>

          {# Assistant product cards message #}
          <div x-show="msg.role === 'assistant' && msg.type === 'products'" class="space-y-3">
            <div class="flex gap-3">
              <div class="w-7 h-7 bg-zunkiree-600 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                </svg>
              </div>
              <div class="bg-white rounded-2xl rounded-tl-none px-4 py-3 shadow-sm border border-gray-100">
                <p class="text-sm text-gray-700" x-text="msg.text"></p>
              </div>
            </div>

            {# Product cards grid #}
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pl-10">
              <template x-for="product in msg.products" :key="product.id">
                <div class="bg-white border border-gray-200 rounded-xl p-4 shadow-sm hover:border-zunkiree-300 hover:shadow-md transition-all cursor-pointer"
                     @click="selectProduct(product)">
                  {# Header row #}
                  <div class="flex items-start justify-between mb-2">
                    <div>
                      <p class="text-xs text-gray-400 uppercase tracking-wide" x-text="product.brand"></p>
                      <p class="text-sm font-medium text-gray-900 leading-tight" x-text="product.name"></p>
                    </div>
                    {# Value score badge #}
                    <div class="flex-shrink-0 ml-2">
                      <div class="w-10 h-10 rounded-full flex items-center justify-center text-xs font-bold text-white"
                           :class="product.value_score >= 9 ? 'bg-green-500' : product.value_score >= 8 ? 'bg-zunkiree-600' : 'bg-gray-400'">
                        <span x-text="product.value_score.toFixed(1)"></span>
                      </div>
                      <p class="text-[10px] text-center text-gray-400 mt-0.5">score</p>
                    </div>
                  </div>

                  {# Price #}
                  <p class="text-base font-semibold text-gray-900 mb-2">
                    Rs. <span x-text="product.price.toLocaleString('en-IN')"></span>
                  </p>

                  {# Highlight #}
                  <p class="text-xs text-zunkiree-600 leading-relaxed" x-text="product.highlight"></p>

                  {# Top specs (first 2) #}
                  <div class="mt-3 pt-3 border-t border-gray-100 flex flex-wrap gap-1">
                    <template x-for="[key, val] in Object.entries(product.specs).slice(0, 3)" :key="key">
                      <span class="text-[10px] bg-gray-50 text-gray-600 px-2 py-0.5 rounded-full border border-gray-200"
                            x-text="`${key.replace(/_/g, ' ')}: ${val}`"></span>
                    </template>
                  </div>
                </div>
              </template>
            </div>

          </div>

          {# Festival discount alert message #}
          <div x-show="msg.role === 'assistant' && msg.type === 'festival'" class="flex gap-3">
            <div class="w-7 h-7 bg-amber-400 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5 text-sm">
              🎉
            </div>
            <div
              class="rounded-2xl rounded-tl-none px-4 py-3 shadow-sm max-w-sm"
              :class="msg.urgent ? 'bg-red-50 border border-red-200' : 'bg-amber-50 border border-amber-200'"
            >
              <p class="text-sm font-medium mb-1" :class="msg.urgent ? 'text-red-800' : 'text-amber-900'" x-text="msg.text"></p>
              <div x-show="!msg.urgent && msg.savingMin > 0" class="flex items-center justify-between mt-2 pt-2 border-t" :class="msg.urgent ? 'border-red-200' : 'border-amber-200'">
                <span class="text-xs font-medium" :class="msg.urgent ? 'text-red-700' : 'text-amber-700'">
                  Rs. <span x-text="msg.savingMin?.toLocaleString('en-IN')"></span> – Rs. <span x-text="msg.savingMax?.toLocaleString('en-IN')"></span> potential saving
                </span>
                <a
                  href="#emi-calculator"
                  class="text-xs font-medium underline underline-offset-2 whitespace-nowrap ml-3"
                  :class="msg.urgent ? 'text-red-700' : 'text-amber-700'"
                >Set reminder →</a>
              </div>
            </div>
          </div>

        </div>
      </template>

      {# Typing indicator #}
      <div x-show="loading" class="flex gap-3">
        <div class="w-7 h-7 bg-zunkiree-600 rounded-full flex-shrink-0 flex items-center justify-center">
          <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <div class="bg-white rounded-2xl rounded-tl-none px-4 py-3 shadow-sm border border-gray-100">
          <div class="flex items-center gap-1">
            <span class="w-2 h-2 bg-gray-300 rounded-full animate-bounce" style="animation-delay: 0ms"></span>
            <span class="w-2 h-2 bg-gray-300 rounded-full animate-bounce" style="animation-delay: 150ms"></span>
            <span class="w-2 h-2 bg-gray-300 rounded-full animate-bounce" style="animation-delay: 300ms"></span>
          </div>
        </div>
      </div>
    </div>

    {# Input #}
    <div class="px-4 py-3 bg-white border-t border-gray-100">
      <form @submit.prevent="sendMessage(input)" class="flex gap-2">
        <input
          x-model="input"
          :disabled="loading"
          type="text"
          placeholder="e.g. I want OnePlus 12, budget Rs. 1,00,000"
          class="flex-1 text-sm px-4 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:border-zunkiree-400 focus:ring-2 focus:ring-zunkiree-100 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
        />
        <button
          type="submit"
          :disabled="loading || !input.trim()"
          class="w-10 h-10 bg-zunkiree-600 text-white rounded-xl flex items-center justify-center hover:bg-zunkiree-700 disabled:opacity-40 disabled:cursor-not-allowed transition-colors flex-shrink-0"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
        </button>
      </form>
      <p class="text-[10px] text-gray-400 mt-1.5 text-center">Searches bikes, phones &amp; appliances across all budgets</p>
    </div>
  </div>
</div>

<script>
const PRODUCTS = {{ shop_products | dump | safe }};
const FESTIVALS = {{ festival_discounts | dump | safe }};

// ── Festival helpers ─────────────────────────────────────────────────────────

function daysUntilDate(dateStr) {
  const today = new Date(); today.setHours(0, 0, 0, 0);
  return Math.ceil((new Date(dateStr) - today) / 86400000);
}

function nearestFestival(category, windowDays = 45) {
  return FESTIVALS
    .filter(f => {
      const d = daysUntilDate(f.date);
      return d >= 0 && d <= windowDays &&
        (f.applies_to.includes('all') || f.applies_to.includes(category));
    })
    .sort((a, b) => daysUntilDate(a.date) - daysUntilDate(b.date))[0] || null;
}

function buildFestivalChatMsg(festival, avgPrice) {
  const days = daysUntilDate(festival.date);
  if (days <= 7) {
    return {
      urgent: true,
      savingMin: 0, savingMax: 0,
      text: `${festival.name} sale may already be live — check with your dealer before paying full price.`
    };
  }
  const savingMin = Math.round(avgPrice * festival.discount_min_pct / 100);
  const savingMax = Math.round(avgPrice * festival.discount_max_pct / 100);
  const cats = festival.applies_to.includes('all') ? 'all categories' : festival.applies_to.join(' & ');
  return {
    urgent: false, savingMin, savingMax,
    text: `${festival.name} is ${days} days away — expect ${festival.discount_min_pct}–${festival.discount_max_pct}% discount on ${cats}. Estimated saving: Rs. ${savingMin.toLocaleString('en-IN')} – Rs. ${savingMax.toLocaleString('en-IN')}.`
  };
}

function parseBudget(message) {
  const msg = message.toLowerCase();
  // "1.5 lakh", "1 lakh", "2 lakhs"
  const lakhMatch = msg.match(/(\d+(?:\.\d+)?)\s*lakh/i);
  if (lakhMatch) return Math.round(parseFloat(lakhMatch[1]) * 100000);
  // grab biggest number ≥ 1000 from message (handles "1,00,000", "uptop 100000", "100,000")
  const nums = msg.match(/\d[\d,.]*\d|\d/g) || [];
  const parsed = nums
    .map(n => parseInt(n.replace(/[,.]/g, ''), 10))
    .filter(n => !isNaN(n) && n >= 1000);
  if (parsed.length) return Math.max(...parsed);
  return 200000;
}

function detectBrand(message) {
  const msg = message.toLowerCase();
  const map = {
    Apple: ['apple', 'iphone'],
    Samsung: ['samsung', 'galaxy'],
    OnePlus: ['oneplus', 'one plus'],
    Xiaomi: ['xiaomi', 'redmi', 'mi '],
    Google: ['google', 'pixel'],
    Realme: ['realme'],
    Yamaha: ['yamaha'],
    Honda: ['honda'],
    Bajaj: ['bajaj'],
    TVS: ['tvs'],
    Suzuki: ['suzuki'],
    Hero: ['hero'],
    Daikin: ['daikin'],
    LG: ['lg '],
    Sony: ['sony']
  };
  for (const [brand, keywords] of Object.entries(map)) {
    if (keywords.some(k => msg.includes(k))) return brand;
  }
  return null;
}

function buildComparison(alt, requested, category) {
  // Returns a single comparison sentence: "<Brand X> beats <Brand Y> on <axis>"
  const a = alt.specs || {};
  const r = requested.specs || {};
  const altLabel = alt.brand;
  const reqLabel = requested.brand;

  const parseNum = (v) => {
    if (typeof v === 'number') return v;
    const m = String(v || '').match(/\d+(\.\d+)?/);
    return m ? parseFloat(m[0]) : null;
  };

  const axes = {
    phones: [
      { key: 'camera', label: 'camera', better: 'higher' },
      { key: 'battery', label: 'battery', better: 'higher' },
      { key: 'ram', label: 'RAM', better: 'higher' },
      { key: 'storage', label: 'storage', better: 'higher' }
    ],
    bikes: [
      { key: 'power', label: 'power', better: 'higher' },
      { key: 'mileage', label: 'mileage', better: 'higher' },
      { key: 'torque', label: 'torque', better: 'higher' },
      { key: 'fuel_tank', label: 'fuel tank', better: 'higher' }
    ],
    appliances: [
      { key: 'star_rating', label: 'energy rating', better: 'higher' },
      { key: 'capacity', label: 'capacity', better: 'higher' },
      { key: 'cooling_area', label: 'cooling area', better: 'higher' }
    ]
  };

  const candidates = axes[category] || [];
  for (const axis of candidates) {
    const aVal = parseNum(a[axis.key]);
    const rVal = parseNum(r[axis.key]);
    if (aVal != null && rVal != null && aVal > rVal) {
      return `${altLabel} beats ${reqLabel} on ${axis.label}: ${a[axis.key]} vs ${r[axis.key]}`;
    }
  }
  // price advantage fallback
  if (alt.price < requested.price) {
    const saving = (requested.price - alt.price).toLocaleString('en-IN');
    return `${altLabel} costs Rs. ${saving} less than ${reqLabel} in the same range`;
  }
  // generic value-score fallback
  if (alt.value_score > requested.value_score) {
    return `${altLabel} scores ${alt.value_score} on value vs ${reqLabel}'s ${requested.value_score}`;
  }
  return `${altLabel} is a strong alternative in the same price range`;
}

function mockSearch(message) {
  const budget = parseBudget(message);
  const brand = detectBrand(message);

  const msg = message.toLowerCase();
  let category = null;
  if (/phone|iphone|samsung|oneplus|xiaomi|pixel|realme|galaxy|redmi/i.test(msg)) category = 'phones';
  else if (/bike|scooter|motorcycle|yamaha|honda|bajaj|tvs|suzuki|hero/i.test(msg)) category = 'bikes';
  else if (/\bac\b|tv|washing|fridge|appliance|daikin|aircon/i.test(msg)) category = 'appliances';
  else category = 'phones';

  const inBudget = PRODUCTS.filter(p => p.category === category && p.price <= budget);

  // Requested brand picks (up to 2)
  const brandPicks = brand
    ? inBudget.filter(p => p.brand === brand).sort((a, b) => b.value_score - a.value_score).slice(0, 2)
    : inBudget.slice().sort((a, b) => b.value_score - a.value_score).slice(0, 2);

  // Cross-brand alternatives at similar price (within ±25% of brandPicks[0].price)
  const anchor = brandPicks[0];
  let alternatives = [];
  if (anchor) {
    const low = anchor.price * 0.75;
    const high = Math.min(budget, anchor.price * 1.25);
    alternatives = inBudget
      .filter(p => p.brand !== anchor.brand && p.price >= low && p.price <= high)
      .sort((a, b) => b.value_score - a.value_score)
      .slice(0, 2)
      .map(alt => ({ ...alt, highlight: buildComparison(alt, anchor, category) }));
  } else if (brand) {
    // No brand matches in budget — show top alternatives with comparison vs an out-of-budget reference
    const reference = PRODUCTS.filter(p => p.category === category && p.brand === brand).sort((a, b) => a.price - b.price)[0];
    if (reference) {
      alternatives = inBudget
        .sort((a, b) => b.value_score - a.value_score)
        .slice(0, 3)
        .map(alt => ({ ...alt, highlight: buildComparison(alt, reference, category) }));
    }
  } else {
    alternatives = inBudget
      .sort((a, b) => b.value_score - a.value_score)
      .slice(2, 4);
  }

  // Tag brand picks with their own highlights
  const brandHighlights = [
    'Top pick — best value among ' + (brand || 'available') + ' options',
    'Strong second pick — solid balance of price and specs'
  ];
  const taggedBrandPicks = brandPicks.map((p, i) => ({ ...p, highlight: brandHighlights[i] || brandHighlights[0] }));

  const products = [...taggedBrandPicks, ...alternatives];

  if (!products.length) {
    return {
      type: 'product_search',
      category,
      message: `No ${category} found under Rs. ${budget.toLocaleString('en-IN')}. Try a higher budget.`,
      products: []
    };
  }

  let summary;
  if (brand && brandPicks.length) {
    summary = alternatives.length
      ? `Found ${brandPicks.length} ${brand} ${category === 'phones' ? 'phone' + (brandPicks.length === 1 ? '' : 's') : category} under Rs. ${budget.toLocaleString('en-IN')}, plus ${alternatives.length} alternative${alternatives.length === 1 ? '' : 's'} that beat ${brand} on key specs in the same range.`
      : `Found ${brandPicks.length} ${brand} option${brandPicks.length === 1 ? '' : 's'} under Rs. ${budget.toLocaleString('en-IN')}.`;
  } else if (brand && !brandPicks.length) {
    summary = `No ${brand} ${category} under Rs. ${budget.toLocaleString('en-IN')} — here are ${alternatives.length} alternatives compared against the cheapest ${brand}.`;
  } else {
    summary = `Found ${products.length} ${category} option${products.length === 1 ? '' : 's'} under Rs. ${budget.toLocaleString('en-IN')}, sorted by value score:`;
  }

  return {
    type: 'product_search',
    category,
    message: summary,
    products
  };
}

function shoppingAgent() {
  return {
    input: '',
    messages: [],
    loading: false,
    history: [],
    msgId: 0,

    init() {},

    async sendMessage(text) {
      if (!text || !text.trim() || this.loading) return;
      this.input = '';

      this.messages.push({ id: ++this.msgId, role: 'user', type: 'text', text: text.trim() });
      this.scrollToBottom();

      this.loading = true;

      // Small delay so the typing indicator is visible
      await new Promise(r => setTimeout(r, 500));

      const data = mockSearch(text.trim());

      if (data.type === 'product_search' && data.products?.length) {
        this.messages.push({
          id: ++this.msgId,
          role: 'assistant',
          type: 'products',
          text: data.message,
          products: data.products
        });

        // Festival discount awareness
        const festival = nearestFestival(data.category);
        if (festival) {
          const avgPrice = data.products.reduce((s, p) => s + p.price, 0) / data.products.length;
          const festMsg = buildFestivalChatMsg(festival, avgPrice);
          this.messages.push({ id: ++this.msgId, role: 'assistant', type: 'festival', ...festMsg });
        }
      } else {
        this.messages.push({
          id: ++this.msgId,
          role: 'assistant',
          type: 'text',
          text: data.message
        });
      }

      this.loading = false;
      this.scrollToBottom();
    },

    selectProduct(product) {
      window.dispatchEvent(new CustomEvent('product-selected', { detail: { product } }));
    },

    scrollToBottom() {
      this.$nextTick(() => {
        const el = this.$refs.messagesContainer;
        if (el) el.scrollTop = el.scrollHeight;
      });
    }
  };
}
</script>
