<footer class="bg-black text-white pt-16 lg:pt-24 pb-8">
  <div class="container-custom">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8 lg:gap-6 mb-12">
      <!-- Brand Column -->
      <div class="col-span-2 md:col-span-3 lg:col-span-2">
        <a href="/" class="flex items-center mb-6">
          <img src="/assets/images/zunkireelabs-logo-light.svg" alt="Zunkiree Labs" class="h-6 w-auto" />
        </a>
        <p class="text-navy-200 text-small leading-relaxed mb-6 max-w-sm">
          Building intelligent software platforms that connect data, systems, and human interaction through AI.
        </p>
        <!-- Social Links -->
        <div class="flex items-center gap-3">
          <a href="https://www.linkedin.com/company/zunkireelabs/" class="w-10 h-10 bg-white/10 hover:bg-zunkiree-600 flex items-center justify-center text-navy-200 hover:text-white transition-all duration-200" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>

      <!-- Products Links -->
      <div>
        <h4 class="text-white font-semibold mb-5 text-small uppercase tracking-wider">Products</h4>
        <ul class="space-y-3">
          {% for item in navigation.footer.products %}
            <li>
              <a href="{{ item.url }}" class="text-navy-200 hover:text-white text-small transition-colors duration-200">{{ item.label }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>

      <!-- Solutions Links -->
      <div>
        <h4 class="text-white font-semibold mb-5 text-small uppercase tracking-wider">Solutions</h4>
        <ul class="space-y-3">
          {% for item in navigation.footer.solutions %}
            <li>
              <a href="{{ item.url }}" class="text-navy-200 hover:text-white text-small transition-colors duration-200">{{ item.label }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>

      <!-- Services Links -->
      <div>
        <h4 class="text-white font-semibold mb-5 text-small uppercase tracking-wider">Services</h4>
        <ul class="space-y-3">
          {% for item in navigation.footer.services | slice(4) %}
            <li>
              <a href="{{ item.url }}" class="text-navy-200 hover:text-white text-small transition-colors duration-200">{{ item.label }}</a>
            </li>
          {% endfor %}
          <li>
            <a href="/services/" class="text-zunkiree-400 hover:text-zunkiree-300 text-small transition-colors duration-200">View all &rarr;</a>
          </li>
        </ul>
      </div>

      <!-- Company Links -->
      <div>
        <h4 class="text-white font-semibold mb-5 text-small uppercase tracking-wider">Company</h4>
        <ul class="space-y-3">
          {% for item in navigation.footer.company %}
            <li>
              <a href="{{ item.url }}" class="text-navy-200 hover:text-white text-small transition-colors duration-200">{{ item.label }}</a>
            </li>
          {% endfor %}
          {% for item in navigation.footer.resources %}
            <li>
              <a href="{{ item.url }}" class="text-navy-200 hover:text-white text-small transition-colors duration-200">{{ item.label }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-navy-300 text-small">
        &copy; {% year %} {{ site.name }}. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a href="/privacy/" class="text-navy-300 hover:text-white text-small transition-colors duration-200">Privacy Policy</a>
        <a href="/terms/" class="text-navy-300 hover:text-white text-small transition-colors duration-200">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
