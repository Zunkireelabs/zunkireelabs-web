{# =====================================================
   CTA + FAQ SECTION (Reusable Component)
   ===================================================== #}
<section id="faq-cta-section" class="py-16 md:py-24 relative">
  {# faq-green-glow moved to cta-band.njk so it persists when FAQ is hidden #}
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16" x-data="{ ctaHeight: null }" x-init="$nextTick(() => { ctaHeight = $refs.faqSection.offsetHeight })">

      {# Left Side - CTA Panel (dark glass) #}
      <div
        class="cta-dark-panel"
        :style="ctaHeight ? 'height: ' + ctaHeight + 'px' : ''"
      >
        <div class="relative z-10">
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-normal text-white mb-8 leading-tight">
            Start your AI<br>journey today
          </h2>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact/" class="inline-flex items-center justify-center px-7 py-3.5 rounded-full bg-zunkiree-600 text-white font-medium hover:bg-zunkiree-700 transition-colors">
              Contact Us
            </a>
            <a href="/products/search/" class="inline-flex items-center justify-center px-7 py-3.5 rounded-full border border-white/30 text-white font-medium hover:bg-white hover:text-[#0a1f2b] transition-colors">
              View Demo
            </a>
          </div>
        </div>
      </div>

      {# Right Side - FAQ Accordion (dark mode) #}
      <div x-ref="faqSection">
      <div x-data="{ activeIndex: null, expandAll: false }">
        {# Header #}
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-2xl md:text-3xl font-medium text-white">Get to know Zunkiree</h3>
          <button
            @click="expandAll = !expandAll; activeIndex = expandAll ? 'all' : null"
            class="text-sm text-white/50 hover:text-white transition-colors"
          >
            <span x-text="expandAll ? 'Collapse All' : 'Expand All'"></span>
          </button>
        </div>

        {# FAQ Items #}
        <div class="divide-y divide-white/10">
          {% for item in faq %}
          <div class="py-5">
            <button
              @click="activeIndex = (activeIndex === {{ loop.index }} && !expandAll) ? null : {{ loop.index }}"
              class="w-full flex items-center justify-between text-left group"
            >
              <span class="text-lg font-medium text-white group-hover:text-zunkiree-200 transition-colors pr-4">
                {{ item.question }}
              </span>
              <span class="flex-shrink-0 text-white/40">
                <svg
                  class="w-5 h-5 transition-transform duration-200"
                  :class="{ 'rotate-45': activeIndex === {{ loop.index }} || expandAll }"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
              </span>
            </button>
            <div
              x-show="activeIndex === {{ loop.index }} || expandAll"
              x-transition:enter="transition ease-out duration-200"
              x-transition:enter-start="opacity-0 -translate-y-2"
              x-transition:enter-end="opacity-100 translate-y-0"
              x-transition:leave="transition ease-in duration-150"
              x-transition:leave-start="opacity-100 translate-y-0"
              x-transition:leave-end="opacity-0 -translate-y-2"
              class="overflow-hidden"
            >
              <p class="pt-4 text-white/80 leading-relaxed">
                {{ item.answer }}
              </p>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
      </div>

    </div>
  </div>
</section>
