<div
  x-data="{
    scrolled: false,
    headerHidden: false,
    lastScrollY: 0,
    activeDropdown: null,
    mobileMenuOpen: false,
    mobileSubmenu: null,
    handleScroll() {
      const currentScrollY = window.scrollY;
      if (currentScrollY < 10) {
        this.headerHidden = false;
      } else if (currentScrollY > this.lastScrollY) {
        this.headerHidden = true;
        this.closeDropdown();
      } else {
        this.headerHidden = false;
      }
      this.lastScrollY = currentScrollY;
      this.scrolled = currentScrollY > 10;
    },
    toggleDropdown(label) {
      this.activeDropdown = this.activeDropdown === label ? null : label;
    },
    closeDropdown() {
      this.activeDropdown = null;
    }
  }"
  x-init="lastScrollY = window.scrollY;"
  @scroll.window.throttle.50ms="handleScroll()"
>
  <!-- Dark Overlay (outside header for proper z-index stacking) -->
  <div
    class="hidden lg:block fixed inset-0 z-40"
    style="top: 3.5rem; background-color: rgba(0, 0, 0, 0.7);"
    x-show="activeDropdown !== null"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click="closeDropdown()"
    x-cloak
  ></div>

  <header
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
    style="background-color: var(--header-bg); border-bottom: 1px solid var(--header-border);"
    :class="headerHidden && !activeDropdown ? '-translate-y-full' : 'translate-y-0'"
  >
    <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-6">
      <nav class="relative flex items-center h-14">
        <!-- Logo -->
        <a href="/" class="flex items-center flex-shrink-0">
          <img
            src="/assets/images/zunkireelabs-logo-round.svg"
            alt="Zunkiree Labs"
            class="h-6 w-auto"
          />
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden lg:flex items-center ml-8">
          {% for item in navigation.main %}
            {% if item.hasDropdown %}
              <div class="relative">
                <button
                  @click="toggleDropdown('{{ item.label }}')"
                  class="flex items-center gap-1 px-4 py-2 text-[15px] font-medium transition-colors duration-200"
                  :class="activeDropdown === '{{ item.label }}' ? 'text-zunkiree-600' : 'text-[var(--foreground-muted)] hover:text-[var(--foreground)]'"
                >
                  {{ item.label }}
                  <svg class="w-3.5 h-3.5 transition-transform duration-200" :class="activeDropdown === '{{ item.label }}' ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
              </div>
            {% else %}
              <a
                href="{{ item.url }}"
                class="px-4 py-2 text-[15px] font-medium transition-colors duration-200"
                style="color: var(--foreground-muted);"
                onmouseover="this.style.color='var(--foreground)'"
                onmouseout="this.style.color='var(--foreground-muted)'"
              >
                {{ item.label }}
              </a>
            {% endif %}
          {% endfor %}

          <!-- AI Agents CTA with Hover Dropdown -->
          <div
            class="relative ml-4"
            x-data="{ showCard: false }"
            @mouseenter="showCard = true"
            @mouseleave="showCard = false"
          >
            <a
              href="/ai-agents/"
              class="cta-shimmer block px-3.5 py-1 text-[13px] font-normal uppercase tracking-wider rounded-md bg-zunkiree-600 hover:bg-zunkiree-700 text-white transition-all duration-200"
            >
              AI Agents + Orchestration
            </a>

            <!-- Hover Dropdown Card -->
            <div
              class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-72 rounded-lg shadow-2xl overflow-hidden"
              style="background-color: var(--card); border: 1px solid var(--border);"
              x-show="showCard"
              x-transition:enter="transition ease-out duration-200"
              x-transition:enter-start="opacity-0 translate-y-2"
              x-transition:enter-end="opacity-100 translate-y-0"
              x-transition:leave="transition ease-in duration-150"
              x-transition:leave-start="opacity-100 translate-y-0"
              x-transition:leave-end="opacity-0 translate-y-2"
              x-cloak
            >
              <!-- Header Graphic -->
              <div class="w-full h-24 overflow-hidden">
                <img
                  src="/assets/images/ai-agents-card-header.svg"
                  alt="AI Agents Network"
                  class="w-full h-full object-cover"
                />
              </div>

              <!-- Content -->
              <div class="relative p-5">
                <!-- Background SVG -->
                <img
                  src="/assets/images/contact-bg.svg"
                  alt=""
                  class="absolute right-0 bottom-0 w-32 h-32 opacity-40 pointer-events-none"
                  aria-hidden="true"
                />
                <h3 class="relative text-lg font-semibold mb-2" style="color: var(--foreground);">
                  Agents That Work Together
                </h3>
                <p class="relative text-sm leading-relaxed" style="color: var(--foreground-muted);">
                  Build custom AI agents for any task. Orchestrate them into workflows that run your business end-to-end.
                </p>
              </div>

              <!-- Full-width CTA -->
              <a
                href="/ai-agents/"
                class="flex items-center justify-center gap-2 w-full py-3 text-sm font-medium text-white bg-zunkiree-600 hover:bg-zunkiree-700 transition-colors"
              >
                Join the Waitlist
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Right Side -->
        <div class="hidden lg:flex items-center gap-1 ml-auto">
          <!-- Search -->
          <button
            class="p-2 transition-colors"
            style="color: var(--foreground-muted);"
            onmouseover="this.style.color='var(--foreground)'"
            onmouseout="this.style.color='var(--foreground-muted)'"
            aria-label="Search"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </button>
          <!-- Ask AI Button -->
          <button
            onclick="openZunkireeWidget()"
            class="flex items-center gap-1.5 px-3 py-1.5 ml-1 border border-gray-300 rounded-full text-sm font-medium transition-all hover:border-zunkiree-500 hover:text-zunkiree-600"
            style="color: var(--foreground-muted);"
            aria-label="Ask AI"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z" />
            </svg>
            Ask
          </button>
          <!-- About -->
          <a
            href="/about/"
            class="px-3 py-2 text-[15px] transition-colors"
            style="color: var(--foreground-muted);"
            onmouseover="this.style.color='var(--foreground)'"
            onmouseout="this.style.color='var(--foreground-muted)'"
          >About</a>
          <!-- Contact -->
          <a
            href="/contact/"
            class="px-3 py-2 text-[15px] transition-colors"
            style="color: var(--foreground-muted);"
            onmouseover="this.style.color='var(--foreground)'"
            onmouseout="this.style.color='var(--foreground-muted)'"
          >Contact</a>
        </div>

        <!-- Mobile Menu Button -->
        <button
          class="lg:hidden p-2 transition-colors ml-auto"
          style="color: var(--foreground-muted);"
          @click="mobileMenuOpen = !mobileMenuOpen"
          aria-label="Toggle menu"
          :aria-expanded="mobileMenuOpen"
        >
          <svg x-show="!mobileMenuOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg x-show="mobileMenuOpen" x-cloak class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </nav>
    </div>

    <!-- Mega Menu Dropdowns -->
    {% for item in navigation.main %}
      {% if item.hasDropdown and item.dropdownType == 'megamenu' %}
        <div
          class="hidden lg:block absolute top-14 left-0 right-0"
          x-show="activeDropdown === '{{ item.label }}'"
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 -translate-y-2"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 -translate-y-2"
          x-cloak
        >
          <div class="shadow-xl w-full" style="background-color: var(--card); border-top: 1px solid var(--border);">
            <div class="max-w-screen-2xl mx-auto px-6 lg:px-8 py-8">

              {# Dynamic grid based on number of columns + featured #}
              {% set colCount = item.megamenu.columns | length %}
              {% set hasFeature = item.megamenu.featured %}

              <div class="grid gap-8 {% if colCount == 2 and hasFeature %}grid-cols-12{% elif colCount == 3 and hasFeature %}grid-cols-12{% else %}grid-cols-{{ colCount }}{% endif %}">

                {# Render each column #}
                {% for column in item.megamenu.columns %}
                  <div class="{% if colCount == 2 and hasFeature %}col-span-4{% elif colCount == 3 and hasFeature %}col-span-3{% else %}{% endif %}">

                    {# Column Header #}
                    {% if column.header %}
                      <p class="text-[11px] font-semibold uppercase tracking-wider mb-5" style="color: var(--foreground-subtle);">
                        {{ column.header }}
                      </p>
                    {% endif %}

                    {# Items #}
                    <ul class="space-y-1">
                      {% for link in column.items %}
                        <li>
                          <a
                            href="{{ link.url }}"
                            class="group flex items-start gap-3 p-2 -mx-2 rounded-lg transition-colors hover:bg-[var(--background-alt)]"
                            @click="closeDropdown()"
                          >
                            {# Icon (only for descriptive type) #}
                            {% if column.type == 'descriptive' and link.icon %}
                              <span class="mt-0.5 text-zunkiree-600">
                                {% set iconName = link.icon %}
                                {% include "components/nav-icon.njk" %}
                              </span>
                            {% endif %}

                            <div class="flex-1 min-w-0">
                              <div class="flex items-center gap-2">
                                <span class="text-[15px] font-medium transition-colors group-hover:text-zunkiree-600" style="color: var(--foreground);">
                                  {{ link.label }}
                                </span>
                                {% if link.badge %}
                                  <span class="px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide bg-zunkiree-100 text-zunkiree-700 rounded">
                                    {{ link.badge }}
                                  </span>
                                {% endif %}
                              </div>
                              {% if column.type == 'descriptive' and link.description %}
                                <p class="mt-0.5 text-[13px] leading-snug" style="color: var(--foreground-muted);">
                                  {{ link.description }}
                                </p>
                              {% endif %}
                            </div>
                          </a>
                        </li>
                      {% endfor %}

                      {# See All Link #}
                      {% if column.seeAll %}
                        <li class="pt-3">
                          <a
                            href="{{ column.seeAll.url }}"
                            class="inline-flex items-center gap-1.5 text-sm font-medium text-zunkiree-600 hover:gap-2.5 transition-all"
                            @click="closeDropdown()"
                          >
                            {{ column.seeAll.label }}
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                            </svg>
                          </a>
                        </li>
                      {% endif %}
                    </ul>
                  </div>
                {% endfor %}

                {# Featured Card #}
                {% if item.megamenu.featured %}
                  <div class="{% if colCount == 2 %}col-span-4{% elif colCount == 3 %}col-span-3{% else %}col-span-1{% endif %}">
                    <div class="h-full p-5 rounded-xl border" style="background-color: var(--background); border-color: var(--border);">
                      <p class="text-[10px] font-semibold uppercase tracking-wider mb-3 text-zunkiree-600">
                        {{ item.megamenu.featured.label }}
                      </p>
                      <h4 class="text-base font-semibold mb-2" style="color: var(--foreground);">
                        {{ item.megamenu.featured.title }}
                      </h4>
                      <p class="text-[13px] leading-relaxed mb-4" style="color: var(--foreground-muted);">
                        {{ item.megamenu.featured.description }}
                      </p>
                      <a
                        href="{{ item.megamenu.featured.cta.url }}"
                        class="inline-flex items-center gap-1.5 text-sm font-medium text-zunkiree-600 hover:gap-2.5 transition-all"
                        @click="closeDropdown()"
                      >
                        {{ item.megamenu.featured.cta.label }}
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                      </a>
                    </div>
                  </div>
                {% endif %}

              </div>
            </div>

            {# CTA Bar #}
            {% if item.megamenu.cta %}
              <div class="bg-zunkiree-600">
                <div class="max-w-screen-2xl mx-auto px-6 lg:px-8 py-3">
                  <div class="flex items-center gap-4">
                    <span class="text-sm text-white/90">{{ item.megamenu.cta.prompt }}</span>
                    <a
                      href="{{ item.megamenu.cta.url }}"
                      class="inline-flex items-center gap-1.5 text-sm font-medium text-white hover:gap-2.5 transition-all"
                      @click="closeDropdown()"
                    >
                      {{ item.megamenu.cta.button }}
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                      </svg>
                    </a>
                  </div>
                </div>
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}

  </header>

  <!-- Mobile Menu (outside header for proper z-index stacking) -->
  <div
    class="lg:hidden fixed inset-0 top-14 z-[60] overflow-y-auto"
    style="background-color: #ffffff;"
    x-show="mobileMenuOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click.away="mobileMenuOpen = false"
  >
    <div class="px-4 py-4">
      <div class="flex flex-col">
        {% for item in navigation.main %}
          {% if item.hasDropdown and item.dropdownType == 'megamenu' %}
            <div x-data="{ open: false }">
              <button
                @click="open = !open"
                class="w-full flex items-center justify-between px-2 py-3 text-base font-medium transition-colors"
                style="color: var(--foreground);"
              >
                {{ item.label }}
                <svg class="w-4 h-4 transition-transform duration-200" style="color: var(--foreground-subtle);" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>

              <div x-show="open" x-collapse class="pb-2">
                {% for column in item.megamenu.columns %}
                  {% if column.header %}
                    <p class="text-[10px] font-semibold uppercase tracking-wider px-2 pt-4 pb-2" style="color: var(--foreground-subtle);">
                      {{ column.header }}
                    </p>
                  {% endif %}
                  {% for link in column.items %}
                    <a
                      href="{{ link.url }}"
                      class="flex items-center gap-3 px-2 py-2.5 text-[15px] transition-colors hover:bg-[var(--background-alt)] rounded-lg"
                      style="color: var(--foreground-muted);"
                      @click="mobileMenuOpen = false"
                    >
                      {% if link.icon %}
                        <span class="text-zunkiree-600">
                          {% set iconName = link.icon %}
                          {% include "components/nav-icon.njk" %}
                        </span>
                      {% endif %}
                      <span>{{ link.label }}</span>
                      {% if link.badge %}
                        <span class="ml-auto px-1.5 py-0.5 text-[9px] font-medium uppercase bg-zunkiree-100 text-zunkiree-700 rounded">
                          {{ link.badge }}
                        </span>
                      {% endif %}
                    </a>
                  {% endfor %}
                {% endfor %}

                {# Featured card in mobile #}
                {% if item.megamenu.featured %}
                  <div class="mx-2 mt-4 p-4 rounded-lg border" style="background-color: var(--background-alt); border-color: var(--border);">
                    <p class="text-[10px] font-semibold uppercase tracking-wider mb-2 text-zunkiree-600">
                      {{ item.megamenu.featured.label }}
                    </p>
                    <p class="text-sm font-medium mb-1" style="color: var(--foreground);">
                      {{ item.megamenu.featured.title }}
                    </p>
                    <a
                      href="{{ item.megamenu.featured.cta.url }}"
                      class="inline-flex items-center gap-1 text-sm font-medium text-zunkiree-600"
                      @click="mobileMenuOpen = false"
                    >
                      {{ item.megamenu.featured.cta.label }}
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                      </svg>
                    </a>
                  </div>
                {% endif %}
              </div>
            </div>
          {% else %}
            <a
              href="{{ item.url }}"
              class="px-2 py-3 text-base font-medium transition-colors"
              style="color: var(--foreground);"
              @click="mobileMenuOpen = false"
            >
              {{ item.label }}
            </a>
          {% endif %}
        {% endfor %}

        <!-- AI Agents CTA (Mobile) -->
        <a
          href="/ai-agents/"
          class="flex items-center gap-2 px-2 py-3 text-base font-medium text-zunkiree-600 transition-colors"
          @click="mobileMenuOpen = false"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L14.09 8.26L20.18 9.27L15.54 13.14L16.82 19.02L12 16.11L7.18 19.02L8.46 13.14L3.82 9.27L9.91 8.26L12 2Z"/>
          </svg>
          AI Agents + Orchestration
        </a>

        <div class="my-3" style="border-top: 1px solid var(--border);"></div>

        <!-- Ask AI Button (Mobile) -->
        <button
          onclick="openZunkireeWidget()"
          class="flex items-center gap-2 px-2 py-3 text-base font-medium text-zunkiree-600 transition-colors"
          @click="mobileMenuOpen = false"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z" />
          </svg>
          Ask AI
        </button>

        <a href="/about/" class="px-2 py-3 text-base transition-colors" style="color: var(--foreground);" @click="mobileMenuOpen = false">About</a>
        <a href="/contact/" class="px-2 py-3 text-base transition-colors" style="color: var(--foreground);" @click="mobileMenuOpen = false">Contact</a>

        <div class="mt-4 px-2">
          <a
            href="/contact/"
            class="flex items-center justify-center gap-2 w-full py-3 text-sm font-medium text-white bg-zunkiree-600 hover:bg-zunkiree-700 rounded-lg transition-colors"
            @click="mobileMenuOpen = false"
          >
            Schedule a call
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
