<header
  class="fixed top-0 left-0 right-0 z-50 transition-colors duration-300"
  style="background-color: var(--header-bg); border-bottom: 1px solid var(--header-border);"
  x-data="{
    scrolled: false,
    activeDropdown: null,
    activeProduct: 'zunkiree-search',
    mobileMenuOpen: false,
    darkMode: localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches),
    toggleTheme() {
      this.darkMode = !this.darkMode;
      localStorage.setItem('theme', this.darkMode ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', this.darkMode);
    }
  }"
  x-init="
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      if (!localStorage.getItem('theme')) {
        darkMode = e.matches;
        document.documentElement.classList.toggle('dark', darkMode);
      }
    });
  "
  @scroll.window="scrolled = window.scrollY > 10"
>
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-6">
    <nav class="relative flex items-center h-12">
      <!-- Logo -->
      <a href="/" class="flex items-center flex-shrink-0">
        <img
          x-show="!darkMode"
          src="/assets/images/zunkireelabs-logo-round.svg"
          alt="Zunkiree Labs"
          class="h-6 w-auto"
        />
        <img
          x-show="darkMode"
          x-cloak
          src="/assets/images/logo-light.svg"
          alt="Zunkiree Labs"
          class="h-6 w-auto"
        />
      </a>

      <!-- Desktop Navigation - Immediately after logo -->
      <div class="hidden lg:flex items-center ml-8">
        {% for item in navigation.main %}
          {% if item.hasDropdown %}
            <!-- Dropdown Nav Item -->
            <div
              class="relative"
              @mouseenter="activeDropdown = '{{ item.label }}'; {% if item.dropdownType == 'product' %}activeProduct = '{{ item.items[0].id }}'{% endif %}"
              @mouseleave="activeDropdown = null"
            >
              <button
                class="flex items-center gap-1 px-3 py-2 text-base transition-colors duration-200"
                :class="activeDropdown === '{{ item.label }}' ? 'text-[var(--foreground)]' : 'text-[var(--foreground-muted)] hover:text-[var(--foreground)]'"
              >
                {{ item.label }}
                <svg class="w-3.5 h-3.5 transition-transform duration-200" :class="activeDropdown === '{{ item.label }}' ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>
            </div>
          {% else %}
            <!-- Regular Nav Link -->
            <a
              href="{{ item.url }}"
              class="px-3 py-2 text-base transition-colors duration-200"
              style="color: var(--foreground-muted);"
              onmouseover="this.style.color='var(--foreground)'"
              onmouseout="this.style.color='var(--foreground-muted)'"
            >
              {{ item.label }}
            </a>
          {% endif %}
        {% endfor %}
      </div>

      <!-- Right Side - Icons and Links -->
      <div class="hidden lg:flex items-center gap-1 ml-auto">
        <!-- Search Icon -->
        <button
          class="p-2 transition-colors"
          style="color: var(--foreground-muted);"
          onmouseover="this.style.color='var(--foreground)'"
          onmouseout="this.style.color='var(--foreground-muted)'"
          aria-label="Search"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </button>
        <!-- About Link -->
        <a
          href="/about/"
          class="px-3 py-2 text-base transition-colors"
          style="color: var(--foreground-muted);"
          onmouseover="this.style.color='var(--foreground)'"
          onmouseout="this.style.color='var(--foreground-muted)'"
        >About</a>
        <!-- Contact Link -->
        <a
          href="/contact/"
          class="px-3 py-2 text-base transition-colors"
          style="color: var(--foreground-muted);"
          onmouseover="this.style.color='var(--foreground)'"
          onmouseout="this.style.color='var(--foreground-muted)'"
        >Contact</a>
        <!-- Theme Toggle -->
        <button
          @click="toggleTheme()"
          class="p-2 transition-colors ml-1"
          style="color: var(--foreground-muted);"
          onmouseover="this.style.color='var(--foreground)'"
          onmouseout="this.style.color='var(--foreground-muted)'"
          type="button"
          title="Toggle theme"
          aria-label="Toggle theme"
        >
          <!-- Sun Icon (shown in dark mode) -->
          <svg
            x-show="darkMode"
            x-cloak
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
          </svg>
          <!-- Moon Icon (shown in light mode) -->
          <svg
            x-show="!darkMode"
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
          </svg>
        </button>
      </div>

      <!-- Mobile Menu Button -->
      <button
        class="lg:hidden p-2 transition-colors ml-auto"
        style="color: var(--foreground-muted);"
        @click="mobileMenuOpen = !mobileMenuOpen"
        aria-label="Toggle menu"
        :aria-expanded="mobileMenuOpen"
      >
        <svg x-show="!mobileMenuOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg x-show="mobileMenuOpen" x-cloak class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <!-- Mega Menu Dropdowns -->
      {% for item in navigation.main %}
        {% if item.hasDropdown %}
          <div
            class="hidden lg:block absolute top-full left-0 right-0 pt-0"
            x-show="activeDropdown === '{{ item.label }}'"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            @mouseenter="activeDropdown = '{{ item.label }}'"
            @mouseleave="activeDropdown = null"
            x-cloak
          >
            {% if item.dropdownType == 'product' %}
              <!-- Product Mega Menu -->
              <div class="shadow-lg transition-colors duration-300" style="background-color: var(--card); border-top: 1px solid var(--border);">
                <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-6 py-6">
                  <div class="grid grid-cols-12 gap-8">
                    <!-- Products List -->
                    <div class="col-span-5">
                      <p class="text-xs uppercase tracking-widest mb-4" style="color: var(--foreground-subtle);">Products</p>
                      <div class="space-y-1">
                        {% for product in item.items %}
                          <a
                            href="{{ product.url }}"
                            class="group flex items-start gap-4 p-3 transition-colors duration-200"
                            :class="activeProduct === '{{ product.id }}' ? 'bg-[var(--background-alt)]' : 'hover:bg-[var(--background-alt)]'"
                            @mouseenter="activeProduct = '{{ product.id }}'"
                          >
                            <div class="w-9 h-9 flex items-center justify-center flex-shrink-0 transition-colors" style="background-color: var(--background-alt); color: var(--foreground-muted);">
                              {% if product.icon == 'search' %}
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                </svg>
                              {% elif product.icon == 'calendar' %}
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                </svg>
                              {% elif product.icon == 'users' %}
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                                </svg>
                              {% elif product.icon == 'health' %}
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                                </svg>
                              {% elif product.icon == 'factory' %}
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                                </svg>
                              {% else %}
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                                </svg>
                              {% endif %}
                            </div>
                            <div class="flex-1">
                              <div class="flex items-center gap-2">
                                <span class="text-sm" style="color: var(--foreground);">{{ product.label }}</span>
                                {% if product.badge %}
                                  <span class="text-xs px-1.5 py-0.5 {% if product.badge == 'Flagship' %}bg-zunkiree-600 text-white{% else %}bg-[var(--background-muted)] text-[var(--foreground-muted)]{% endif %}">
                                    {{ product.badge }}
                                  </span>
                                {% endif %}
                              </div>
                              <p class="text-xs mt-0.5" style="color: var(--foreground-subtle);">{{ product.description }}</p>
                            </div>
                          </a>
                        {% endfor %}
                      </div>
                    </div>

                    <!-- Product Preview -->
                    <div class="col-span-7 p-6 transition-colors" style="background-color: var(--background-alt);">
                      {% for product in item.items %}
                        <div
                          x-show="activeProduct === '{{ product.id }}'"
                          x-transition:enter="transition ease-out duration-200"
                          x-transition:enter-start="opacity-0"
                          x-transition:enter-end="opacity-100"
                          class="h-full flex flex-col"
                        >
                          <h4 class="text-xl mb-2" style="color: var(--foreground);">{{ product.label }}</h4>
                          <p class="text-sm mb-4" style="color: var(--foreground-muted);">{{ product.extendedDescription }}</p>
                          <a href="{{ product.url }}" class="inline-flex items-center gap-2 text-sm text-zunkiree-600 dark:text-zunkiree-400 hover:gap-3 transition-all mt-auto">
                            Learn more
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                            </svg>
                          </a>
                        </div>
                      {% endfor %}
                    </div>
                  </div>
                </div>
              </div>
            {% else %}
              <!-- Simple Dropdown -->
              <div class="shadow-lg transition-colors duration-300" style="background-color: var(--card); border-top: 1px solid var(--border);">
                <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-6 py-4">
                  <div class="grid grid-cols-3 gap-4">
                    {% for subitem in item.items %}
                      <a
                        href="{{ subitem.url }}"
                        class="group p-3 transition-colors duration-200 hover:bg-[var(--background-alt)]"
                      >
                        <span class="text-sm block group-hover:text-zunkiree-600 dark:group-hover:text-zunkiree-400" style="color: var(--foreground);">{{ subitem.label }}</span>
                        {% if subitem.description %}
                          <p class="text-xs mt-0.5" style="color: var(--foreground-subtle);">{{ subitem.description }}</p>
                        {% endif %}
                      </a>
                    {% endfor %}
                  </div>
                </div>
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div
    class="lg:hidden fixed inset-0 top-12 z-40 overflow-y-auto transition-colors duration-300"
    style="background-color: var(--background);"
    x-show="mobileMenuOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click.away="mobileMenuOpen = false"
    x-cloak
  >
    <div class="px-4 py-4">
      <div class="flex flex-col">
        {% for item in navigation.main %}
          {% if item.hasDropdown %}
            <!-- Mobile Dropdown Section -->
            <div x-data="{ open: false }">
              <button
                @click="open = !open"
                class="w-full flex items-center justify-between px-2 py-3 text-sm transition-colors hover:bg-[var(--background-alt)]"
                style="color: var(--foreground);"
              >
                {{ item.label }}
                <svg class="w-4 h-4 transition-transform duration-200" style="color: var(--foreground-subtle);" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>
              <div x-show="open" x-collapse class="pl-4 ml-2" style="border-left: 1px solid var(--border);">
                {% for subitem in item.items %}
                  <a
                    href="{{ subitem.url }}"
                    class="flex items-center gap-2 px-2 py-2.5 text-sm transition-colors hover:bg-[var(--background-alt)]"
                    style="color: var(--foreground-muted);"
                    @click="mobileMenuOpen = false"
                  >
                    <span>{{ subitem.label }}</span>
                    {% if subitem.badge %}
                      <span class="text-xs px-1.5 py-0.5 {% if subitem.badge == 'Flagship' %}bg-zunkiree-600 text-white{% else %}bg-[var(--background-muted)] text-[var(--foreground-muted)]{% endif %}">
                        {{ subitem.badge }}
                      </span>
                    {% endif %}
                  </a>
                {% endfor %}
              </div>
            </div>
          {% else %}
            <!-- Mobile Regular Link -->
            <a
              href="{{ item.url }}"
              class="px-2 py-3 text-sm transition-colors hover:bg-[var(--background-alt)]"
              style="color: var(--foreground);"
              @click="mobileMenuOpen = false"
            >
              {{ item.label }}
            </a>
          {% endif %}
        {% endfor %}

        <!-- Divider -->
        <div class="my-2" style="border-top: 1px solid var(--border);"></div>

        <!-- Mobile About & Contact -->
        <a href="/about/" class="px-2 py-3 text-sm transition-colors hover:bg-[var(--background-alt)]" style="color: var(--foreground);" @click="mobileMenuOpen = false">About</a>
        <a href="/contact/" class="px-2 py-3 text-sm transition-colors hover:bg-[var(--background-alt)]" style="color: var(--foreground);" @click="mobileMenuOpen = false">Contact</a>

        <!-- Mobile Theme Toggle -->
        <button
          @click="toggleTheme()"
          class="flex items-center gap-2 px-2 py-3 text-sm transition-colors hover:bg-[var(--background-alt)]"
          style="color: var(--foreground);"
        >
          <svg x-show="darkMode" x-cloak class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
          </svg>
          <svg x-show="!darkMode" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
          </svg>
          <span x-text="darkMode ? 'Light mode' : 'Dark mode'"></span>
        </button>
      </div>
    </div>
  </div>
</header>
