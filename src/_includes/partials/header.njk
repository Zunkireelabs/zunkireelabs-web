<header
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background-color: var(--header-bg); border-bottom: 1px solid var(--header-border);"
  :class="headerHidden && !activeDropdown ? '-translate-y-full' : 'translate-y-0'"
  x-data="{
    scrolled: false,
    headerHidden: false,
    lastScrollY: 0,
    activeDropdown: null,
    activeProduct: 'zunkiree-search',
    mobileMenuOpen: false,
    darkMode: localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches),
    handleScroll() {
      const currentScrollY = window.scrollY;
      if (currentScrollY < 10) {
        this.headerHidden = false;
      } else if (currentScrollY > this.lastScrollY) {
        this.headerHidden = true;
        this.closeDropdown();
      } else {
        this.headerHidden = false;
      }
      this.lastScrollY = currentScrollY;
      this.scrolled = currentScrollY > 10;
    },
    toggleDropdown(label) {
      this.activeDropdown = this.activeDropdown === label ? null : label;
    },
    closeDropdown() {
      this.activeDropdown = null;
    },
    toggleTheme() {
      this.darkMode = !this.darkMode;
      localStorage.setItem('theme', this.darkMode ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', this.darkMode);
    }
  }"
  x-init="
    lastScrollY = window.scrollY;
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      if (!localStorage.getItem('theme')) {
        darkMode = e.matches;
        document.documentElement.classList.toggle('dark', darkMode);
      }
    });
  "
  @scroll.window.throttle.50ms="handleScroll()"
>
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-6">
    <nav class="relative flex items-center h-12">
      <!-- Logo -->
      <a href="/" class="flex items-center flex-shrink-0">
        <img
          x-show="!darkMode"
          src="/assets/images/zunkireelabs-logo-round.svg"
          alt="Zunkiree Labs"
          class="h-6 w-auto"
        />
        <img
          x-show="darkMode"
          x-cloak
          src="/assets/images/logo-light.svg"
          alt="Zunkiree Labs"
          class="h-6 w-auto"
        />
      </a>

      <!-- Desktop Navigation - Immediately after logo -->
      <div class="hidden lg:flex items-center ml-8">
        {% for item in navigation.main %}
          {% if item.hasDropdown %}
            <!-- Dropdown Nav Item -->
            <div class="relative">
              <button
                @click="toggleDropdown('{{ item.label }}')"
                class="flex items-center gap-1 px-3 py-2 text-base transition-colors duration-200"
                :class="activeDropdown === '{{ item.label }}' ? 'text-[var(--foreground)]' : 'text-[var(--foreground-muted)] hover:text-[var(--foreground)]'"
              >
                {{ item.label }}
                <svg class="w-3.5 h-3.5 transition-transform duration-200" :class="activeDropdown === '{{ item.label }}' ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>
            </div>
          {% else %}
            <!-- Regular Nav Link -->
            <a
              href="{{ item.url }}"
              class="px-3 py-2 text-base transition-colors duration-200"
              style="color: var(--foreground-muted);"
              onmouseover="this.style.color='var(--foreground)'"
              onmouseout="this.style.color='var(--foreground-muted)'"
            >
              {{ item.label }}
            </a>
          {% endif %}
        {% endfor %}
      </div>

      <!-- Right Side - Icons and Links -->
      <div class="hidden lg:flex items-center gap-1 ml-auto">
        <!-- Search Icon -->
        <button
          class="p-2 transition-colors"
          style="color: var(--foreground-muted);"
          onmouseover="this.style.color='var(--foreground)'"
          onmouseout="this.style.color='var(--foreground-muted)'"
          aria-label="Search"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </button>
        <!-- About Link -->
        <a
          href="/about/"
          class="px-3 py-2 text-base transition-colors"
          style="color: var(--foreground-muted);"
          onmouseover="this.style.color='var(--foreground)'"
          onmouseout="this.style.color='var(--foreground-muted)'"
        >About</a>
        <!-- Contact Link -->
        <a
          href="/contact/"
          class="px-3 py-2 text-base transition-colors"
          style="color: var(--foreground-muted);"
          onmouseover="this.style.color='var(--foreground)'"
          onmouseout="this.style.color='var(--foreground-muted)'"
        >Contact</a>
        <!-- Theme Toggle -->
        <button
          @click="toggleTheme()"
          class="p-2 transition-colors ml-1"
          style="color: var(--foreground-muted);"
          onmouseover="this.style.color='var(--foreground)'"
          onmouseout="this.style.color='var(--foreground-muted)'"
          type="button"
          title="Toggle theme"
          aria-label="Toggle theme"
        >
          <!-- Sun Icon (shown in dark mode) -->
          <svg
            x-show="darkMode"
            x-cloak
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
          </svg>
          <!-- Moon Icon (shown in light mode) -->
          <svg
            x-show="!darkMode"
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
          </svg>
        </button>
      </div>

      <!-- Mobile Menu Button -->
      <button
        class="lg:hidden p-2 transition-colors ml-auto"
        style="color: var(--foreground-muted);"
        @click="mobileMenuOpen = !mobileMenuOpen"
        aria-label="Toggle menu"
        :aria-expanded="mobileMenuOpen"
      >
        <svg x-show="!mobileMenuOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg x-show="mobileMenuOpen" x-cloak class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

    </nav>
  </div>

  <!-- Dark Overlay - Shows when mega menu is open -->
  <div
    class="hidden lg:block fixed inset-0 top-12 bg-black/15 z-40"
    x-show="activeDropdown !== null"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click="closeDropdown()"
    x-cloak
  ></div>

  <!-- Mega Menu Dropdowns - Outside container for full width -->
  {% for item in navigation.main %}
    {% if item.hasDropdown and item.dropdownType == 'megamenu' %}
      <div
        class="hidden lg:block fixed top-12 left-0 right-0 z-50"
        x-show="activeDropdown === '{{ item.label }}'"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        x-cloak
      >
        <!-- Mega Menu Container - Full Width Background -->
        <div class="shadow-lg transition-colors duration-300 w-full" style="background-color: var(--card); border-top: 1px solid var(--border);">
          <!-- Content Area - Constrained to header width -->
          <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-6 py-6">
            <div class="grid grid-cols-4 gap-8">
                  {% for column in item.megamenu.columns %}
                    <div>
                      {% if column.header %}
                        <p class="text-[10px] font-medium uppercase tracking-widest mb-4" style="color: var(--foreground-subtle);">{{ column.header }}</p>
                      {% else %}
                        <div class="h-5 mb-4"></div>
                      {% endif %}
                      <ul class="space-y-2.5">
                        {% for link in column.items %}
                          <li>
                            <a
                              href="{{ link.url }}"
                              class="text-base transition-colors duration-150 hover:text-zunkiree-600 dark:hover:text-zunkiree-400"
                              style="color: var(--foreground);"
                            >{{ link.label }}</a>
                          </li>
                        {% endfor %}
                        {% if column.seeAll %}
                          <li class="pt-2">
                            <a
                              href="{{ column.seeAll.url }}"
                              class="inline-flex items-center gap-1 text-sm font-medium text-zunkiree-600 dark:text-zunkiree-400 hover:gap-2 transition-all duration-150"
                            >
                              {{ column.seeAll.label }}
                              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                              </svg>
                            </a>
                          </li>
                        {% endif %}
                      </ul>
                    </div>
                  {% endfor %}
                </div>
              </div>

              <!-- CTA Bar -->
              {% if item.megamenu.cta %}
                <div class="bg-zunkiree-600 dark:bg-zunkiree-700">
                  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
                    <div class="flex items-center gap-4">
                      <span class="text-sm text-white/90">{{ item.megamenu.cta.prompt }}</span>
                      <a
                        href="{{ item.megamenu.cta.url }}"
                        class="inline-flex items-center gap-1.5 text-sm font-medium text-white hover:gap-2.5 transition-all duration-150"
                      >
                        {{ item.megamenu.cta.button }}
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
              {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}

  <!-- Mobile Menu -->
  <div
    class="lg:hidden fixed inset-0 top-12 z-40 overflow-y-auto transition-colors duration-300"
    style="background-color: var(--background);"
    x-show="mobileMenuOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click.away="mobileMenuOpen = false"
    x-cloak
  >
    <div class="px-4 py-4">
      <div class="flex flex-col">
        {% for item in navigation.main %}
          {% if item.hasDropdown and item.dropdownType == 'megamenu' %}
            <!-- Mobile Dropdown Section -->
            <div x-data="{ open: false }">
              <button
                @click="open = !open"
                class="w-full flex items-center justify-between px-2 py-3 text-sm transition-colors hover:bg-[var(--background-alt)]"
                style="color: var(--foreground);"
              >
                {{ item.label }}
                <svg class="w-4 h-4 transition-transform duration-200" style="color: var(--foreground-subtle);" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>
              <div x-show="open" x-collapse class="pl-2 ml-2" style="border-left: 1px solid var(--border);">
                {% for column in item.megamenu.columns %}
                  {% if column.header %}
                    <p class="text-[10px] font-medium uppercase tracking-widest px-2 pt-3 pb-1" style="color: var(--foreground-subtle);">{{ column.header }}</p>
                  {% endif %}
                  {% for link in column.items %}
                    <a
                      href="{{ link.url }}"
                      class="flex items-center gap-2 px-2 py-2 text-sm transition-colors hover:bg-[var(--background-alt)]"
                      style="color: var(--foreground-muted);"
                      @click="mobileMenuOpen = false"
                    >
                      <span>{{ link.label }}</span>
                    </a>
                  {% endfor %}
                {% endfor %}
              </div>
            </div>
          {% else %}
            <!-- Mobile Regular Link -->
            <a
              href="{{ item.url }}"
              class="px-2 py-3 text-sm transition-colors hover:bg-[var(--background-alt)]"
              style="color: var(--foreground);"
              @click="mobileMenuOpen = false"
            >
              {{ item.label }}
            </a>
          {% endif %}
        {% endfor %}

        <!-- Divider -->
        <div class="my-2" style="border-top: 1px solid var(--border);"></div>

        <!-- Mobile About & Contact -->
        <a href="/about/" class="px-2 py-3 text-sm transition-colors hover:bg-[var(--background-alt)]" style="color: var(--foreground);" @click="mobileMenuOpen = false">About</a>
        <a href="/contact/" class="px-2 py-3 text-sm transition-colors hover:bg-[var(--background-alt)]" style="color: var(--foreground);" @click="mobileMenuOpen = false">Contact</a>

        <!-- Mobile CTA -->
        <div class="mt-4 px-2">
          <a
            href="/contact/"
            class="flex items-center justify-center gap-2 w-full py-3 text-sm font-medium text-white bg-zunkiree-600 hover:bg-zunkiree-700 transition-colors"
            @click="mobileMenuOpen = false"
          >
            Schedule a call
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>

        <!-- Mobile Theme Toggle -->
        <button
          @click="toggleTheme()"
          class="flex items-center gap-2 px-2 py-3 mt-2 text-sm transition-colors hover:bg-[var(--background-alt)]"
          style="color: var(--foreground);"
        >
          <svg x-show="darkMode" x-cloak class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
          </svg>
          <svg x-show="!darkMode" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
          </svg>
          <span x-text="darkMode ? 'Light mode' : 'Dark mode'"></span>
        </button>
      </div>
    </div>
  </div>
</header>
