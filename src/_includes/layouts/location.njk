---
layout: base.njk
---

{# =====================================================
   LOCATION PAGE LAYOUT
   For city/region landing pages with LocalBusiness schema
   ===================================================== #}

{% set location = null %}
{% for loc in locations %}
  {% if loc.id == locationId %}
    {% set location = loc %}
  {% endif %}
{% endfor %}

{# =====================================================
   LOCAL BUSINESS SCHEMA
   ===================================================== #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "{{ site.url }}/locations/{{ location.id }}/#localbusiness",
  "name": "Zunkiree Labs - {{ location.name }}",
  "description": "{{ location.description }}",
  "url": "{{ site.url }}/locations/{{ location.id }}/",
  "telephone": "{{ location.phone | default(site.phone) }}",
  "email": "{{ location.email | default(site.email) }}",
  "image": "{{ site.url }}/assets/images/zunkireelabs-logo-round.svg",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "{{ location.name }}",
    "addressRegion": "{{ location.region }}",
    "addressCountry": "{{ location.countryCode }}"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "27.7172",
    "longitude": "85.3240"
  },
  "parentOrganization": {
    "@type": "Organization",
    "@id": "{{ site.url }}/#organization"
  },
  "areaServed": {
    "@type": "City",
    "name": "{{ location.name }}"
  }
}
</script>

{# =====================================================
   HERO SECTION
   ===================================================== #}
<section class="pt-16 pb-12 md:pt-20 md:pb-16 bg-white">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    {# Breadcrumb #}
    <nav class="flex items-center gap-2 text-sm mb-8" aria-label="Breadcrumb">
      <a href="/" class="text-zunkiree-600 hover:underline">Home</a>
      <span class="text-warm-400">/</span>
      <a href="/locations/" class="text-zunkiree-600 hover:underline">Locations</a>
      <span class="text-warm-400">/</span>
      <span class="text-warm-600">{{ location.name }}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      {# Left: Content #}
      <div>
        <p class="text-xs uppercase tracking-widest text-zunkiree-600 font-medium mb-4">
          {% if location.isHeadquarters %}Headquarters{% else %}Service Area{% endif %}
        </p>
        <h1 class="text-4xl sm:text-5xl font-normal text-gray-900 tracking-tight leading-tight mb-6">
          AI Development in {{ location.name }}
        </h1>
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed mb-8">
          {{ location.intro }}
        </p>

        {# CTAs #}
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact/" class="inline-flex items-center justify-center px-6 py-3 bg-zunkiree-600 text-white font-medium hover:bg-zunkiree-700 transition-colors">
            Contact Us
          </a>
          <a href="/services/" class="inline-flex items-center justify-center px-6 py-3 border border-gray-300 text-gray-700 font-medium hover:bg-gray-50 transition-colors">
            View Services
          </a>
        </div>
      </div>

      {# Right: Map or Contact Card #}
      <div class="bg-gray-50 rounded-lg p-6">
        {% if location.mapEmbed %}
        <div class="aspect-[4/3] w-full mb-6 rounded overflow-hidden">
          <iframe
            src="{{ location.mapEmbed }}"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Zunkiree Labs {{ location.name }} location"
          ></iframe>
        </div>
        {% endif %}

        <h3 class="font-medium text-gray-900 mb-4">Contact Information</h3>
        <ul class="space-y-3 text-gray-600">
          {% if location.address %}
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-zunkiree-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span>{{ location.address.city }}, {{ location.address.country }}</span>
          </li>
          {% endif %}
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-zunkiree-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <a href="tel:{{ location.phone | default(site.phone) }}" class="hover:text-zunkiree-600">
              {{ location.phone | default(site.phone) }}
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-zunkiree-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <a href="mailto:{{ location.email | default(site.email) }}" class="hover:text-zunkiree-600">
              {{ location.email | default(site.email) }}
            </a>
          </li>
        </ul>

        {% if location.hours %}
        <div class="mt-6 pt-6 border-t border-gray-200">
          <h4 class="font-medium text-gray-900 mb-3">Business Hours</h4>
          <ul class="space-y-1 text-sm text-gray-600">
            <li class="flex justify-between">
              <span>Monday - Friday</span>
              <span>{{ location.hours.weekdays }}</span>
            </li>
            <li class="flex justify-between">
              <span>Saturday</span>
              <span>{{ location.hours.saturday }}</span>
            </li>
            <li class="flex justify-between">
              <span>Sunday</span>
              <span>{{ location.hours.sunday }}</span>
            </li>
          </ul>
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{# =====================================================
   ABOUT SECTION
   ===================================================== #}
{% if location.content %}
<section class="py-12 md:py-16 bg-gray-50">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-normal text-gray-900 mb-6">
        About Zunkiree Labs in {{ location.name }}
      </h2>
      <div class="prose prose-lg prose-gray">
        {{ location.content | safe }}
      </div>
    </div>
  </div>
</section>
{% endif %}

{# =====================================================
   SERVICES GRID
   ===================================================== #}
<section class="py-12 md:py-16 bg-white">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl md:text-3xl font-normal text-gray-900 mb-8">
      Services in {{ location.name }}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {% for service in services %}
      <a href="/locations/{{ location.id }}/{{ service.id }}/" class="group block p-6 bg-gray-50 rounded-lg hover:bg-zunkiree-600 transition-colors">
        <h3 class="font-medium text-gray-900 group-hover:text-white mb-2">
          {{ service.title }}
        </h3>
        <p class="text-sm text-gray-600 group-hover:text-white/80 line-clamp-2">
          {{ service.description }}
        </p>
        <div class="mt-4 flex items-center gap-2 text-sm font-medium text-zunkiree-600 group-hover:text-white">
          Learn more
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

{# =====================================================
   FAQs
   ===================================================== #}
{% if location.faqs and location.faqs.length > 0 %}
<section class="py-12 md:py-16 bg-gray-50">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl md:text-3xl font-normal text-gray-900 mb-8">
      Frequently Asked Questions
    </h2>

    <div class="max-w-3xl" x-data="{ activeIndex: null }">
      {% for faq in location.faqs %}
      <div class="border-b border-gray-200">
        <button
          @click="activeIndex = activeIndex === {{ loop.index }} ? null : {{ loop.index }}"
          class="w-full py-5 flex items-center justify-between text-left"
        >
          <span class="font-medium text-gray-900 pr-4">{{ faq.question }}</span>
          <svg
            class="w-5 h-5 text-gray-400 transition-transform"
            :class="{ 'rotate-180': activeIndex === {{ loop.index }} }"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
        <div
          x-show="activeIndex === {{ loop.index }}"
          x-transition
          class="pb-5 text-gray-600"
        >
          {{ faq.answer }}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# FAQPage Schema for location FAQs #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in location.faqs %}
    {
      "@type": "Question",
      "name": "{{ faq.question }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ faq.answer }}"
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

{# =====================================================
   NEARBY LOCATIONS
   ===================================================== #}
{% if location.nearbyCities and location.nearbyCities.length > 0 %}
<section class="py-12 md:py-16 bg-white">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-xl font-normal text-gray-900 mb-6">
      Also Serving
    </h2>
    <div class="flex flex-wrap gap-3">
      {% for cityId in location.nearbyCities %}
        {% for loc in locations %}
          {% if loc.id == cityId %}
          <a href="/locations/{{ loc.id }}/" class="inline-flex items-center px-4 py-2 bg-gray-100 text-gray-700 rounded-full hover:bg-zunkiree-100 hover:text-zunkiree-700 transition-colors">
            {{ loc.name }}
          </a>
          {% endif %}
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# =====================================================
   CTA
   ===================================================== #}
<section class="py-16 md:py-24 bg-gradient-to-br from-zunkiree-600 to-zunkiree-800 text-white">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl font-normal mb-4">
      Ready to build with AI in {{ location.name }}?
    </h2>
    <p class="text-lg text-white/80 mb-8 max-w-2xl mx-auto">
      Let's discuss how AI can transform your business.
    </p>
    <a href="/contact/" class="inline-flex items-center justify-center px-8 py-4 bg-white text-zunkiree-700 font-medium hover:bg-gray-100 transition-colors">
      Schedule a Discovery Call
    </a>
  </div>
</section>
