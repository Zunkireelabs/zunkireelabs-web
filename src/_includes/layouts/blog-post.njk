---
layout: base.njk
schemaType: article
---

{# =====================================================
   BLOG POST LAYOUT
   Single article view with author, date, TOC
   ===================================================== #}

{% set author = authors[authorId] if authorId else authors["zunkiree-team"] %}

{# =====================================================
   ARTICLE SCHEMA
   ===================================================== #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": "{{ site.url }}{{ page.url }}#article",
  "headline": "{{ title }}",
  "description": "{{ description }}",
  "image": "{{ site.url }}{{ featuredImage | default(site.meta.ogImage) }}",
  "datePublished": "{{ date | date('%Y-%m-%d') }}",
  "dateModified": "{{ lastUpdated | default(date) | date('%Y-%m-%d') }}",
  "author": {
    "@type": "Person",
    "name": "{{ author.name }}",
    "url": "{{ author.social.linkedin | default(site.url + '/about/') }}"
  },
  "publisher": {
    "@type": "Organization",
    "@id": "{{ site.url }}/#organization",
    "name": "Zunkiree Labs",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ site.url }}/assets/images/zunkireelabs-logo-round.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.url }}{{ page.url }}"
  }
}
</script>

{# =====================================================
   HERO SECTION
   ===================================================== #}
<section class="pt-16 pb-8 md:pt-20 md:pb-12 bg-white">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    {# Breadcrumb #}
    <nav class="flex items-center gap-2 text-sm mb-8" aria-label="Breadcrumb">
      <a href="/" class="text-zunkiree-600 hover:underline">Home</a>
      <span class="text-warm-400">/</span>
      <a href="/blog/" class="text-zunkiree-600 hover:underline">Blog</a>
      <span class="text-warm-400">/</span>
      <span class="text-warm-600">{{ title | truncate(40) }}</span>
    </nav>

    {# Category + Read time #}
    <div class="flex items-center gap-4 mb-6">
      {% if category %}
      <span class="inline-flex items-center px-3 py-1 text-xs font-medium bg-zunkiree-100 text-zunkiree-700 rounded-full">
        {{ category }}
      </span>
      {% endif %}
      {% if readTime %}
      <span class="text-sm text-gray-500">{{ readTime }} min read</span>
      {% endif %}
    </div>

    {# Title #}
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-normal text-gray-900 tracking-tight leading-tight mb-6 max-w-4xl">
      {{ title }}
    </h1>

    {# Description #}
    {% if description %}
    <p class="text-lg md:text-xl text-gray-600 leading-relaxed mb-8 max-w-3xl">
      {{ description }}
    </p>
    {% endif %}

    {# Author + Date #}
    <div class="flex items-center gap-4 pt-6 border-t border-gray-200">
      {% if author.avatar %}
      <img
        src="{{ author.avatar }}"
        alt="{{ author.name }}"
        class="w-12 h-12 rounded-full object-cover"
        loading="lazy"
      />
      {% endif %}
      <div>
        <p class="font-medium text-gray-900">{{ author.name }}</p>
        <p class="text-sm text-gray-500">
          <time datetime="{{ date | date('%Y-%m-%d') }}">{{ date | date('%B %d, %Y') }}</time>
          {% if lastUpdated %}
          <span class="mx-2">·</span>
          Updated <time datetime="{{ lastUpdated | date('%Y-%m-%d') }}">{{ lastUpdated | date('%B %d, %Y') }}</time>
          {% endif %}
        </p>
      </div>
    </div>
  </div>
</section>

{# =====================================================
   FEATURED IMAGE
   ===================================================== #}
{% if featuredImage %}
<section class="pb-8 md:pb-12 bg-white">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    <img
      src="{{ featuredImage }}"
      alt="{{ featuredImageAlt | default(title) }}"
      class="w-full aspect-[2/1] object-cover rounded-lg"
    />
  </div>
</section>
{% endif %}

{# =====================================================
   ARTICLE CONTENT
   ===================================================== #}
<article class="pb-16 md:pb-24 bg-white">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

      {# Main Content #}
      <div class="lg:col-span-8">
        <div class="prose prose-lg prose-gray max-w-none
          prose-headings:font-normal prose-headings:tracking-tight
          prose-h2:text-2xl prose-h2:md:text-3xl prose-h2:mt-12 prose-h2:mb-6
          prose-h3:text-xl prose-h3:md:text-2xl prose-h3:mt-8 prose-h3:mb-4
          prose-p:leading-relaxed prose-p:text-gray-600
          prose-a:text-zunkiree-600 prose-a:no-underline hover:prose-a:underline
          prose-strong:font-medium prose-strong:text-gray-900
          prose-ul:my-6 prose-li:my-2
          prose-img:rounded-lg
          prose-blockquote:border-l-zunkiree-500 prose-blockquote:bg-gray-50 prose-blockquote:py-1 prose-blockquote:px-6 prose-blockquote:not-italic
        ">
          {{ content | safe }}
        </div>

        {# Tags #}
        {% if tags and tags.length > 1 %}
        <div class="mt-12 pt-8 border-t border-gray-200">
          <p class="text-sm text-gray-500 mb-3">Topics:</p>
          <div class="flex flex-wrap gap-2">
            {% for tag in tags %}
            {% if tag != "blog" %}
            <span class="inline-flex items-center px-3 py-1 text-sm bg-gray-100 text-gray-700 rounded-full">
              {{ tag }}
            </span>
            {% endif %}
            {% endfor %}
          </div>
        </div>
        {% endif %}

        {# Author Bio #}
        <div class="mt-12 p-6 bg-gray-50 rounded-lg">
          <div class="flex items-start gap-4">
            {% if author.avatar %}
            <img
              src="{{ author.avatar }}"
              alt="{{ author.name }}"
              class="w-16 h-16 rounded-full object-cover flex-shrink-0"
              loading="lazy"
            />
            {% endif %}
            <div>
              <p class="font-medium text-gray-900 mb-1">{{ author.name }}</p>
              <p class="text-sm text-gray-500 mb-3">{{ author.role }}</p>
              <p class="text-gray-600">{{ author.bio }}</p>
            </div>
          </div>
        </div>
      </div>

      {# Sidebar - Table of Contents placeholder #}
      <aside class="lg:col-span-4 hidden lg:block">
        <div class="sticky top-24">
          <p class="text-sm font-medium text-gray-900 mb-4">On this page</p>
          <nav class="text-sm text-gray-600" id="toc">
            {# TOC will be generated by JS if needed #}
          </nav>

          {# CTA #}
          <div class="mt-8 p-6 bg-gradient-to-br from-zunkiree-500 to-zunkiree-700 rounded-lg text-white">
            <p class="font-medium mb-2">Need AI solutions?</p>
            <p class="text-sm text-white/80 mb-4">Let's discuss how AI can transform your business.</p>
            <a href="/contact/" class="inline-flex items-center justify-center w-full px-4 py-2 bg-white text-zunkiree-700 font-medium text-sm rounded hover:bg-gray-100 transition-colors">
              Schedule a Call
            </a>
          </div>
        </div>
      </aside>

    </div>
  </div>
</article>

{# =====================================================
   RELATED POSTS (if available)
   ===================================================== #}
{% set relatedPosts = collections.blog | rejectattr("url", "equalto", page.url) | head(3) %}
{% if relatedPosts.length > 0 %}
<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl md:text-3xl font-normal text-gray-900 mb-8">More from the blog</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {% for post in relatedPosts %}
      <a href="{{ post.url }}" class="group block bg-white rounded-lg overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
        {% if post.data.featuredImage %}
        <div class="aspect-[16/9] overflow-hidden">
          <img
            src="{{ post.data.featuredImage }}"
            alt="{{ post.data.title }}"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            loading="lazy"
          />
        </div>
        {% endif %}
        <div class="p-6">
          <p class="text-sm text-gray-500 mb-2">{{ post.date | date('%B %d, %Y') }}</p>
          <h3 class="text-lg font-medium text-gray-900 group-hover:text-zunkiree-600 transition-colors">
            {{ post.data.title }}
          </h3>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
