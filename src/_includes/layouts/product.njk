---
layout: base.njk
schemaType: product
---

{# =====================================================
   PRODUCT PAGE LAYOUT
   Based on service.njk design patterns
   Sections: Hero, Stats, Overview, Benefits, Use Cases, Case Studies, Resources, CTA+FAQ
   ===================================================== #}

{% set product = productsDetails[productId] %}
{% set stories = productsStories %}

{# Product Secondary Nav with Login CTA #}
{% include "components/product-nav.njk" %}

{# =====================================================
   SECTION 1: HERO / LEADSPACE
   Dark background with animated search demo
   ===================================================== #}
<section class="relative pt-20 pb-8 md:pt-24 md:pb-10 overflow-hidden bg-[#161616]">
  {# Subtle gradient overlay #}
  <div class="absolute inset-0 bg-gradient-to-br from-white/[0.02] to-transparent"></div>

  <div class="relative max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center min-h-[500px] md:min-h-[550px]">

      {# Left: Content #}
      <div class="flex flex-col justify-center z-10">
        {# Breadcrumb #}
        <nav class="flex items-center gap-2 text-sm mb-8" data-reveal aria-label="Breadcrumb">
          <a href="/" class="text-zunkiree-400 hover:underline">Home</a>
          <span class="text-white/40">/</span>
          <a href="/products/" class="text-zunkiree-400 hover:underline">Products</a>
          <span class="text-white/40">/</span>
          <span class="text-white/70">{{ product.title }}</span>
        </nav>

        {# Coming Soon Badge #}
        {% if product.status == "coming-soon" %}
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-amber-500/20 rounded-full mb-6" data-reveal>
          <span class="w-2 h-2 bg-amber-400 rounded-full animate-pulse"></span>
          <span class="text-sm font-medium text-amber-400">Coming Soon</span>
        </div>
        {% endif %}

        {# Title #}
        <h1 class="text-4xl sm:text-5xl md:text-[56px] lg:text-[64px] font-normal text-white tracking-[-0.04em] leading-[1.05] mb-6" data-reveal>
          {{ product.tagline }}
        </h1>

        {# Description #}
        <p class="text-lg md:text-xl text-white/70 leading-relaxed tracking-[-0.01em] mb-10 max-w-lg" data-reveal>
          {{ product.description }}
        </p>

        {# CTAs #}
        <div class="flex flex-col sm:flex-row items-start gap-4" data-reveal>
          <a href="{{ product.cta.primaryButton.url }}" class="inline-flex items-center justify-center px-7 py-3.5 bg-zunkiree-600 text-white font-medium hover:bg-zunkiree-700 transition-colors">
            {{ product.cta.primaryButton.text }}
          </a>
          <a href="{{ product.cta.secondaryButton.url }}" class="inline-flex items-center justify-center px-7 py-3.5 border border-white/50 text-white font-medium hover:bg-white/10 transition-colors">
            {{ product.cta.secondaryButton.text }}
          </a>
        </div>
      </div>

      {# Right: Hero Visual - Conditional based on product type #}
      {% if product.id == 'search' %}
      {# Zunkiree Search: Animated Search Demo #}
      <div class="hidden lg:flex lg:flex-col lg:justify-center" x-data="searchDemo()" x-init="startAnimation()">
        <div class="relative flex flex-col">

          {# Results Card (TOP) - Glassmorphic - Dynamic Content #}
          <div class="bg-white/[0.07] backdrop-blur-xl rounded-2xl overflow-hidden shadow-2xl border border-white/[0.15] transform transition-all duration-700 mb-4"
               :class="{ 'translate-y-0 opacity-100': showResults, '-translate-y-8 opacity-0': !showResults }">
            {# Results Header #}
            <div class="p-5 border-b border-white/10">
              <h3 class="text-white font-medium" x-text="currentQuery.resultTitle"></h3>
            </div>

            {# Results Data - Dynamic #}
            <div class="p-5 space-y-4">
              <template x-for="(item, index) in currentQuery.data" :key="index">
                <div class="flex items-center justify-between transition-all duration-500"
                     :style="'transition-delay: ' + (index * 100 + 100) + 'ms'"
                     :class="{ 'translate-x-0 opacity-100': showData, '-translate-x-4 opacity-0': !showData }">
                  <div>
                    <p class="text-white font-medium" x-text="item.label"></p>
                    <p class="text-white/50 text-sm" x-text="item.value"></p>
                  </div>
                  <span class="px-3 py-1 rounded-full text-sm font-medium"
                        :class="item.positive ? 'bg-emerald-500/20 text-emerald-400' : 'bg-amber-500/20 text-amber-400'"
                        x-text="item.badge"></span>
                </div>
              </template>
            </div>

            {# Sources - Dynamic #}
            <div class="px-5 pb-5 transition-all duration-500"
                 :class="{ 'opacity-100': showSources, 'opacity-0': !showSources }">
              <div class="flex items-center gap-2 mb-3">
                <svg class="w-4 h-4 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                </svg>
                <span class="text-white/40 text-sm">Sources</span>
              </div>
              <div class="flex flex-wrap gap-2">
                <template x-for="source in currentQuery.sources" :key="source">
                  <span class="px-3 py-1.5 bg-white/5 border border-white/10 rounded-lg text-white/70 text-xs flex items-center gap-1.5">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                    <span x-text="source"></span>
                  </span>
                </template>
              </div>
            </div>
          </div>

          {# Powered by badge (MIDDLE) #}
          <div class="flex items-center justify-end gap-2 mb-4 transition-all duration-300"
               :class="{ 'opacity-100': showPowered, 'opacity-0': !showPowered }">
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <span class="text-white/50 text-sm">Powered by</span>
            <span class="text-blue-400 text-sm font-medium">Zunkiree AI</span>
          </div>

          {# Search Input Card (BOTTOM) - ALWAYS VISIBLE - Glassmorphic #}
          <div class="bg-white/[0.07] backdrop-blur-xl rounded-2xl p-4 shadow-2xl border border-white/[0.15]">
            <div class="flex items-center gap-3">
              {# Chat icon #}
              <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              </div>
              {# Typing text / Placeholder #}
              <div class="flex-1 min-h-[28px] flex items-center">
                <span x-show="typedText === '' && !isTyping" class="text-white/40 text-base">Ask anything...</span>
                <span x-show="typedText !== '' || isTyping" class="text-white text-base" x-text="typedText"></span>
                <span class="inline-block w-0.5 h-5 bg-white/70 ml-0.5 animate-pulse" x-show="isTyping"></span>
              </div>
              {# Search button #}
              <button class="px-5 py-2.5 bg-blue-500 text-white rounded-xl font-medium flex items-center gap-2 transition-all hover:bg-blue-600"
                      :class="{ 'opacity-100': showButton, 'opacity-60': !showButton }">
                Search
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </button>
            </div>
          </div>

        </div>
      </div>
      {% else %}
      {# Other Products: Hero SVG Image #}
      <div class="hidden lg:flex lg:items-center lg:justify-center" data-reveal>
        <div class="relative w-full max-w-xl">
          <img src="{{ product.heroImage }}" alt="{{ product.title }} interface preview" class="w-full h-auto" />
        </div>
      </div>
      {% endif %}

    </div>
  </div>
</section>

{# Alpine.js Search Demo Component #}
<script>
  function searchDemo() {
    return {
      typedText: '',
      isTyping: false,
      showButton: false,
      showPowered: false,
      showResults: false,
      showData: false,
      showSources: false,
      currentQueryIndex: 0,

      // Multiple queries to cycle through
      queries: [
        {
          text: 'Show me sales data for Q4',
          resultTitle: 'Fastest growing regions (Q4 YoY):',
          data: [
            { label: 'APAC', value: '$580K', badge: '+45%', positive: true },
            { label: 'EMEA', value: '$720K', badge: '+32%', positive: true },
            { label: 'Americas', value: '$1.1M', badge: '+21%', positive: true }
          ],
          sources: ['Regional Sales', 'YoY Growth Data']
        },
        {
          text: 'Which products have highest return rates?',
          resultTitle: 'Return rates by category:',
          data: [
            { label: 'Electronics', value: '2,340 units', badge: '12%', positive: false },
            { label: 'Apparel', value: '1,890 units', badge: '8%', positive: false },
            { label: 'Home & Garden', value: '567 units', badge: '3%', positive: true }
          ],
          sources: ['Returns Database', 'Product Analytics']
        },
        {
          text: 'Compare this quarter vs last year',
          resultTitle: 'Revenue comparison (QoQ vs YoY):',
          data: [
            { label: 'Q1 2026', value: '$2.4M', badge: '+18%', positive: true },
            { label: 'Q2 2026', value: '$3.1M', badge: '+24%', positive: true },
            { label: 'Q3 2026', value: '$4.2M', badge: '+31%', positive: true }
          ],
          sources: ['Financial Reports', 'Revenue Dashboard']
        },
        {
          text: 'Find customers at risk of churn',
          resultTitle: 'Customer churn risk analysis:',
          data: [
            { label: 'High Risk', value: '23 accounts', badge: 'Urgent', positive: false },
            { label: 'Medium Risk', value: '45 accounts', badge: 'Monitor', positive: false },
            { label: 'Low Risk', value: '180 accounts', badge: 'Healthy', positive: true }
          ],
          sources: ['CRM Data', 'Engagement Metrics']
        }
      ],

      get currentQuery() {
        return this.queries[this.currentQueryIndex];
      },

      async startAnimation() {
        // Initial delay
        await this.delay(800);

        // Start typing (chat bar is always visible)
        this.isTyping = true;
        await this.delay(200);

        // Type the query
        await this.typeText();
        this.isTyping = false;
        this.showButton = true;

        // Simulate "searching"
        await this.delay(600);

        // Show results sliding down from top
        this.showResults = true;
        await this.delay(200);
        this.showPowered = true;

        await this.delay(300);
        this.showData = true;

        await this.delay(400);
        this.showSources = true;

        // Hold for viewing
        await this.delay(4000);

        // Transition to next query
        this.nextQuery();
      },

      async typeText() {
        const text = this.currentQuery.text;
        for (let i = 0; i <= text.length; i++) {
          this.typedText = text.slice(0, i);
          await this.delay(45 + Math.random() * 25);
        }
      },

      async nextQuery() {
        // Fade out results
        this.showSources = false;
        await this.delay(100);
        this.showData = false;
        await this.delay(100);
        this.showResults = false;
        await this.delay(100);
        this.showPowered = false;

        // Clear text with backspace effect
        await this.clearText();

        // Move to next query
        this.currentQueryIndex = (this.currentQueryIndex + 1) % this.queries.length;

        // Reset button state
        this.showButton = false;

        // Small pause before next query
        await this.delay(500);

        // Start typing next query
        this.isTyping = true;
        await this.typeText();
        this.isTyping = false;
        this.showButton = true;

        // Show results
        await this.delay(600);
        this.showResults = true;
        await this.delay(200);
        this.showPowered = true;
        await this.delay(300);
        this.showData = true;
        await this.delay(400);
        this.showSources = true;

        // Hold and loop
        await this.delay(4000);
        this.nextQuery();
      },

      async clearText() {
        const text = this.typedText;
        for (let i = text.length; i >= 0; i--) {
          this.typedText = text.slice(0, i);
          await this.delay(20);
        }
      },

      delay(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
      }
    }
  }
</script>

{# =====================================================
   SECTION 1B: WHY ZUNKIREE SEARCH (Dark Features)
   Seamless continuation of hero - same dark background
   ===================================================== #}
<section class="relative pt-8 pb-16 md:pt-12 md:pb-20 bg-[#161616] overflow-hidden">
  {# Match hero gradient overlay #}
  <div class="absolute inset-0 bg-gradient-to-br from-white/[0.02] to-transparent"></div>

  {# SVG Gradient Definition for Icons #}
  <svg width="0" height="0" class="absolute">
    <defs>
      <linearGradient id="why-icon-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color:#ff6b5c;stop-opacity:1" />
        <stop offset="100%" style="stop-color:#eb1600;stop-opacity:1" />
      </linearGradient>
    </defs>
  </svg>

  <div class="relative max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
    {# Section Header #}
    <div class="mb-10 md:mb-12" data-reveal>
      <h2 class="text-3xl sm:text-4xl md:text-[44px] font-normal text-white tracking-[-0.03em] leading-[1.1]">
        Built for accuracy.<br class="hidden sm:block"> Designed for scale.
      </h2>
    </div>

    {# 4-Column Feature Grid #}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-6">

      {# Feature 1: Semantic Understanding #}
      <div class="group" data-reveal>
        <div class="mb-5">
          <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-white/[0.05] border border-white/[0.08] group-hover:border-white/20 transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="url(#why-icon-gradient)" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"/>
            </svg>
          </div>
        </div>
        <h3 class="text-lg font-medium text-white mb-3">Semantic Understanding</h3>
        <p class="text-white/60 leading-relaxed text-sm">
          Understands meaning, not just keywords. Delivers relevant results even with typos or natural phrasing.
        </p>
      </div>

      {# Feature 2: Instant Answers #}
      <div class="group" data-reveal>
        <div class="mb-5">
          <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-white/[0.05] border border-white/[0.08] group-hover:border-white/20 transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="url(#why-icon-gradient)" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
            </svg>
          </div>
        </div>
        <h3 class="text-lg font-medium text-white mb-3">Instant Answers</h3>
        <p class="text-white/60 leading-relaxed text-sm">
          Generates direct answers from your content. Reduces support queries by eliminating endless clicking.
        </p>
      </div>

      {# Feature 3: Enterprise Security #}
      <div class="group" data-reveal>
        <div class="mb-5">
          <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-white/[0.05] border border-white/[0.08] group-hover:border-white/20 transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="url(#why-icon-gradient)" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
            </svg>
          </div>
        </div>
        <h3 class="text-lg font-medium text-white mb-3">Enterprise Security</h3>
        <p class="text-white/60 leading-relaxed text-sm">
          SOC 2 compliant, data encrypted at rest and in transit. Your data stays yours.
        </p>
      </div>

      {# Feature 4: 5-Minute Integration #}
      <div class="group" data-reveal>
        <div class="mb-5">
          <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-white/[0.05] border border-white/[0.08] group-hover:border-white/20 transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="url(#why-icon-gradient)" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 01-.657.643 48.39 48.39 0 01-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 01-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 00-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 01-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 00.657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 01-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 005.427-.63 48.05 48.05 0 00.582-4.717.532.532 0 00-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.959.401v0a.656.656 0 00.658-.663 48.422 48.422 0 00-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 01-.61-.58z"/>
            </svg>
          </div>
        </div>
        <h3 class="text-lg font-medium text-white mb-3">5-Minute Integration</h3>
        <p class="text-white/60 leading-relaxed text-sm">
          Drop-in SDK with 50+ connectors. Works with your existing stack—no migration needed.
        </p>
      </div>

    </div>
  </div>
</section>

{# =====================================================
   SECTION 2: SOCIAL PROOF + STATS BAR
   ===================================================== #}
<section class="py-6 bg-white border-y border-gray-200">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-center">

      {# Left: Trust Text with Divider #}
      <div class="lg:col-span-2 flex items-center gap-4">
        <p class="text-xs text-gray-500 uppercase tracking-wider leading-relaxed">Trusted by industry leaders</p>
        <div class="hidden lg:block w-px h-8 bg-gray-200"></div>
      </div>

      {# Middle: Client Logos #}
      <div class="lg:col-span-5 flex items-center gap-8 overflow-x-auto">
        {% if product.clients and stories %}
        {% for clientId in product.clients %}
          {% for story in stories %}
            {% if story.id == clientId %}
            <div class="flex-shrink-0">
              <img src="{{ story.logo }}" alt="{{ story.name }}" class="h-6 md:h-8 w-auto object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300" />
            </div>
            {% endif %}
          {% endfor %}
        {% endfor %}
        {% endif %}
      </div>

      {# Right: Stats #}
      <div class="lg:col-span-5 flex items-center justify-end gap-6 md:gap-8">
        {% for stat in product.stats %}
        <div class="text-center">
          <p class="text-xl md:text-2xl font-medium bg-gradient-to-r from-[#ff6b5c] to-[#eb1600] bg-clip-text text-transparent">{{ stat.value }}</p>
          <p class="text-xs text-gray-500">{{ stat.label }}</p>
        </div>
        {% endfor %}
      </div>

    </div>
  </div>
</section>

{# =====================================================
   SECTION 3: OVERVIEW / VALUE PROP (Two-column)
   ===================================================== #}
<section class="py-12 md:py-20 bg-white ">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start">
      {# Left: Large benefit-focused headline #}
      <div>
        <h2 class="text-3xl sm:text-4xl md:text-[44px] lg:text-[52px] font-normal leading-[1.1] tracking-[-0.03em] bg-gradient-to-r from-[#ff6b5c] to-[#eb1600] bg-clip-text text-transparent">
          {{ product.definition.heading }}
        </h2>
      </div>

      {# Right: Supporting paragraph #}
      <div class="lg:pt-2">
        <p class="text-lg md:text-xl text-gray-600  leading-relaxed">
          {{ product.definition.content }}
        </p>
      </div>
    </div>
  </div>
</section>

{# =====================================================
   SECTION 4: KEY BENEFITS (IBM-style minimal)
   ===================================================== #}
<section class="py-12 md:py-20 bg-white ">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
      {# Left: Large "Benefits" title #}
      <div class="lg:col-span-3">
        <h2 class="text-4xl md:text-5xl font-normal text-gray-900  tracking-[-0.02em]">
          Benefits
        </h2>
      </div>

      {# Right: Benefits grid #}
      <div class="lg:col-span-9">
        {# SVG Gradient Definition #}
        <svg width="0" height="0" style="position:absolute;">
          <defs>
            <linearGradient id="benefit-icon-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" style="stop-color:#ff6b5c;stop-opacity:1" />
              <stop offset="100%" style="stop-color:#eb1600;stop-opacity:1" />
            </linearGradient>
          </defs>
        </svg>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
          {% for benefit in product.benefits %}
          <div>
            {# Icon #}
            <div class="mb-6">
              {% if benefit.icon == "search" %}
              <svg class="w-12 h-12" fill="none" stroke="url(#benefit-icon-gradient)" viewBox="0 0 24 24" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              {% elif benefit.icon == "speed" %}
              <svg class="w-12 h-12" fill="none" stroke="url(#benefit-icon-gradient)" viewBox="0 0 24 24" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
              {% elif benefit.icon == "integrate" %}
              <svg class="w-12 h-12" fill="none" stroke="url(#benefit-icon-gradient)" viewBox="0 0 24 24" stroke-width="1">
                <circle cx="12" cy="12" r="3"/>
                <circle cx="4" cy="8" r="2"/>
                <circle cx="20" cy="8" r="2"/>
                <circle cx="4" cy="16" r="2"/>
                <circle cx="20" cy="16" r="2"/>
                <path d="M6 8h3M15 8h3M6 16h3M15 16h3"/>
              </svg>
              {% elif benefit.icon == "factory" %}
              <svg class="w-12 h-12" fill="none" stroke="url(#benefit-icon-gradient)" viewBox="0 0 24 24" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
              {% elif benefit.icon == "calendar" %}
              <svg class="w-12 h-12" fill="none" stroke="url(#benefit-icon-gradient)" viewBox="0 0 24 24" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              {% elif benefit.icon == "chat" %}
              <svg class="w-12 h-12" fill="none" stroke="url(#benefit-icon-gradient)" viewBox="0 0 24 24" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              {% elif benefit.icon == "bell" %}
              <svg class="w-12 h-12" fill="none" stroke="url(#benefit-icon-gradient)" viewBox="0 0 24 24" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
              </svg>
              {% elif benefit.icon == "users" %}
              <svg class="w-12 h-12" fill="none" stroke="url(#benefit-icon-gradient)" viewBox="0 0 24 24" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
              {% else %}
              <svg class="w-12 h-12" fill="none" stroke="url(#benefit-icon-gradient)" viewBox="0 0 24 24" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/>
              </svg>
              {% endif %}
            </div>
            {# Title #}
            <h3 class="text-lg font-normal text-gray-900  mb-3">
              {{ benefit.title }}
            </h3>
            {# Description #}
            <p class="text-gray-600  leading-relaxed">
              {{ benefit.description }}
            </p>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{# =====================================================
   SECTION 5: USE CASES (IBM-style Tabbed Interface)
   ===================================================== #}
<section class="py-12 md:py-20 bg-white " x-data="{ activeTab: '{{ product.useCases[0].id }}' }">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
    {# Left-aligned title #}
    <h2 class="text-4xl md:text-5xl font-normal text-gray-900  tracking-[-0.02em] mb-8">
      Use cases
    </h2>

    {# Tab Navigation - Rounded with gradient active #}
    <div class="flex flex-wrap gap-2 mb-12">
      {% for useCase in product.useCases %}
      <button
        @click="activeTab = '{{ useCase.id }}'"
        :class="activeTab === '{{ useCase.id }}' ? 'bg-gradient-to-r from-[#ff6b5c] to-[#eb1600] text-white shadow-md border-transparent' : 'bg-gray-100 text-gray-700 hover:bg-gray-200 border-gray-200'"
        class="px-6 py-3 rounded-lg font-medium text-sm border transition-all duration-200"
      >
        {{ useCase.title }}
      </button>
      {% endfor %}
    </div>

    {# Tab Content #}
    {% for useCase in product.useCases %}
    <div
      x-show="activeTab === '{{ useCase.id }}'"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start"
    >
      {# Content #}
      <div class="pt-4">
        <h3 class="text-2xl md:text-3xl font-normal text-gray-900  tracking-[-0.02em] mb-4">
          {{ useCase.headline }}
        </h3>
        <p class="text-lg text-gray-600  leading-relaxed mb-6">
          {{ useCase.description }}
        </p>
        {# Features list #}
        {% if useCase.features %}
        <ul class="space-y-2 mb-6">
          {% for feature in useCase.features %}
          <li class="flex items-center gap-2 text-gray-600">
            <svg class="w-4 h-4 text-zunkiree-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            {{ feature }}
          </li>
          {% endfor %}
        </ul>
        {% endif %}
        <a href="/contact/" class="inline-flex items-center gap-2 text-blue-600 font-medium hover:gap-3 transition-all duration-200">
          Learn more
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>

      {# Image #}
      <div class="relative">
        <div class="aspect-[16/9] overflow-hidden">
          {% if useCase.image %}
          <img
            src="{{ useCase.image }}"
            alt="{{ useCase.headline }}"
            class="w-full h-full object-cover"
            loading="lazy"
          >
          {% else %}
          <div class="w-full h-full bg-gray-100 flex items-center justify-center">
            <span class="text-gray-400">{{ useCase.headline }}</span>
          </div>
          {% endif %}
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

{# =====================================================
   SECTION 6: CLIENT STORIES / CASE STUDIES
   ===================================================== #}
{% set clientStories = [] %}
{% if product.clients and stories %}
{% for clientId in product.clients %}
  {% for story in stories %}
    {% if story.id == clientId %}
      {% set clientStories = (clientStories.push(story), clientStories) %}
    {% endif %}
  {% endfor %}
{% endfor %}
{% endif %}

{% if clientStories.length > 0 %}
<section class="py-12 md:py-20 bg-gray-50" x-data="{ currentSlide: 0, totalSlides: Math.ceil({{ clientStories.length }} / 2) }">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
    {# Header with logos #}
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between mb-12">
      <div class="mb-6 lg:mb-0">
        <p class="text-xs uppercase tracking-widest text-zunkiree-600 font-medium mb-4">Case Studies</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-normal text-gray-900 tracking-[-0.02em]">
          See {{ product.title }} in action
        </h2>
      </div>

      {# Client Logos #}
      <div class="flex flex-wrap items-center gap-6">
        {% for story in clientStories %}
        <img
          src="{{ story.logo }}"
          alt="{{ story.name }}"
          class="h-6 md:h-8 w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-200"
          loading="lazy"
        >
        {% endfor %}
      </div>
    </div>

    {# Story Cards Slider - 2 per view #}
    <div class="relative overflow-hidden">
      <div
        class="flex transition-transform duration-500 ease-out"
        :style="'transform: translateX(-' + (currentSlide * 100) + '%)'"
      >
        {% for story in clientStories %}
        <div class="w-full md:w-1/2 flex-shrink-0 px-2">
          {# Card Container #}
          <div class="bg-white border border-gray-200 overflow-hidden h-full flex flex-col">
            {# Card Top - Content + Image #}
            <div class="p-8 flex flex-col md:flex-row gap-6 flex-1">
              {# Content - Left side #}
              <div class="flex-1 flex flex-col order-2 md:order-1">
                <h3 class="text-xl md:text-2xl font-normal text-gray-900 tracking-[-0.02em] mb-3">
                  {{ story.headline }}
                </h3>
                <p class="text-gray-600 leading-relaxed mb-5 text-sm md:text-base flex-1">
                  {{ story.description }}
                </p>

                {# Stat Highlight #}
                <div class="flex items-baseline gap-2 mb-5">
                  <span class="text-3xl md:text-4xl font-medium bg-gradient-to-r from-[#ff6b5c] to-[#eb1600] bg-clip-text text-transparent">{{ story.stat }}</span>
                  <span class="text-gray-500 text-sm">{{ story.statLabel }}</span>
                </div>

                <a href="{{ story.ctaUrl }}" class="inline-flex items-center gap-2 text-zunkiree-600 font-medium hover:gap-3 transition-all duration-200">
                  {{ story.ctaText }}
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                  </svg>
                </a>
              </div>

              {# Divider #}
              <div class="hidden md:block w-px bg-gray-200 order-2"></div>

              {# Image - Right side #}
              <div class="flex-shrink-0 md:w-[45%] order-1 md:order-3 self-stretch">
                <div class="h-full min-h-[200px] overflow-hidden bg-gray-100">
                  <img
                    src="{{ story.image }}"
                    alt="{{ story.name }} project"
                    class="w-full h-full object-cover"
                    loading="lazy"
                  >
                </div>
              </div>
            </div>

            {# Card Bottom - Client Logo #}
            <div class="border-t border-gray-200 px-8 py-5">
              <div class="flex items-center justify-end">
                <img
                  src="{{ story.logo }}"
                  alt="{{ story.name }}"
                  class="h-5 w-auto object-contain"
                />
              </div>
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>

    {# Navigation #}
    {% if clientStories.length > 2 %}
    <div class="flex items-center justify-center gap-6 mt-8">
      <button
        @click="currentSlide = currentSlide > 0 ? currentSlide - 1 : totalSlides - 1"
        class="w-12 h-12 flex items-center justify-center border border-gray-300 text-gray-600 hover:border-gray-900 hover:text-gray-900 transition-colors rounded-lg"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <div class="flex items-center gap-2">
        <template x-for="i in totalSlides" :key="i">
          <button
            @click="currentSlide = i - 1"
            class="w-2.5 h-2.5 rounded-full transition-colors"
            :class="currentSlide === (i - 1) ? 'bg-zunkiree-600' : 'bg-gray-300 hover:bg-gray-400'"
          ></button>
        </template>
      </div>

      <button
        @click="currentSlide = currentSlide < totalSlides - 1 ? currentSlide + 1 : 0"
        class="w-12 h-12 flex items-center justify-center border border-gray-300 text-gray-600 hover:border-gray-900 hover:text-gray-900 transition-colors rounded-lg"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>
    {% endif %}
  </div>
</section>
{% endif %}

{# =====================================================
   SECTION 7: RESOURCES (Databricks-style cards)
   ===================================================== #}
{% if product.resources %}
<section class="py-12 md:py-20 bg-white">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
    {# Header #}
    <div class="mb-12">
      <p class="text-xs uppercase tracking-widest text-zunkiree-600 font-medium mb-4">Resources</p>
      <h2 class="text-3xl md:text-4xl font-normal text-gray-900  tracking-[-0.02em]">
        Learn more about {{ product.title }}
      </h2>
    </div>

    {# Resources Grid - Databricks style #}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {% for resource in product.resources %}
      <a href="{{ resource.url }}" class="group bg-[#EDF2F8] rounded-none p-6 shadow-sm hover:shadow-lg transition-all duration-300 flex flex-col">
        {# Top Row: Icon + Label + Arrow #}
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-2.5">
            {# Small colored icon #}
            <div class="w-6 h-6 flex items-center justify-center">
              {% if resource.icon == "book" %}
              <svg class="w-5 h-5 text-zunkiree-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
              {% elif resource.icon == "code" %}
              <svg class="w-5 h-5 text-zunkiree-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
              {% elif resource.icon == "briefcase" %}
              <svg class="w-5 h-5 text-zunkiree-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
              {% elif resource.icon == "terminal" %}
              <svg class="w-5 h-5 text-zunkiree-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              {% else %}
              <svg class="w-5 h-5 text-zunkiree-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
              </svg>
              {% endif %}
            </div>
            {# Category label #}
            <span class="text-xs font-medium uppercase tracking-wider text-gray-500">Zunkiree</span>
          </div>
          {# Arrow icon - top right #}
          <svg class="w-5 h-5 text-gray-400 group-hover:text-zunkiree-600 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10"></path>
          </svg>
        </div>

        {# Title #}
        <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-zunkiree-600 transition-colors">
          {{ resource.title }}
        </h3>

        {# Description #}
        <p class="text-gray-500 text-sm leading-relaxed">
          {{ resource.description }}
        </p>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# =====================================================
   SECTION 8: CTA + FAQ (IBM Vertical Stack)
   ===================================================== #}
<section class="py-12 md:py-20 bg-gray-50">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">

    {# TOP: CTA Block #}
    <div class="mb-16">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-normal text-gray-900 mb-6 leading-tight tracking-[-0.02em]">
        Take the next step
      </h2>
      <p class="text-lg md:text-xl text-gray-600 mb-8 max-w-2xl">
        {{ product.cta.description }}
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="{{ product.cta.primaryButton.url }}" class="inline-flex items-center justify-center gap-2 px-5 py-3 bg-zunkiree-600 text-white font-medium text-sm hover:bg-zunkiree-700 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z"/>
          </svg>
          {{ product.cta.primaryButton.text }}
        </a>
        <a href="{{ product.cta.secondaryButton.url }}" class="inline-flex items-center justify-center gap-2 px-5 py-3 border border-zunkiree-600 text-zunkiree-600 font-medium text-sm hover:bg-zunkiree-50 transition-colors">
          {{ product.cta.secondaryButton.text }}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>

    {# BOTTOM: FAQ Accordion #}
    <div x-data="{ activeIndex: null, expandAll: false }">
      {# Header #}
      <div class="flex items-center justify-between mb-6 border-b border-gray-300 pb-4">
        <h3 class="text-2xl md:text-3xl font-normal text-gray-900">Frequently asked questions</h3>
        <button
          @click="expandAll = !expandAll; activeIndex = expandAll ? 'all' : null"
          class="text-sm text-blue-600 hover:text-blue-800 transition-colors"
        >
          <span x-text="expandAll ? 'Collapse All' : 'Expand All'"></span>
        </button>
      </div>

      {# FAQ Items #}
      <div class="divide-y divide-gray-200">
        {% for faq in product.faq %}
        <div class="py-5">
          <button
            @click="activeIndex = (activeIndex === {{ loop.index }} && !expandAll) ? null : {{ loop.index }}"
            class="w-full flex items-center justify-between text-left group"
          >
            <span class="text-lg font-medium text-gray-900 group-hover:text-blue-600 transition-colors pr-4">
              {{ faq.question }}
            </span>
            <span class="flex-shrink-0 text-gray-400">
              <svg
                class="w-5 h-5 transition-transform duration-200"
                :class="{ 'rotate-45': activeIndex === {{ loop.index }} || expandAll }"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
            </span>
          </button>
          <div
            x-show="activeIndex === {{ loop.index }} || expandAll"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 -translate-y-2"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 -translate-y-2"
            class="overflow-hidden"
          >
            <p class="pt-4 text-gray-600 leading-relaxed">
              {{ faq.answer }}
            </p>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>

  </div>
</section>
