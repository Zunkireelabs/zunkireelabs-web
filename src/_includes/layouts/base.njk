<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <!-- Google Analytics -->
  {% if env.GA_MEASUREMENT_ID %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ env.GA_MEASUREMENT_ID }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ env.GA_MEASUREMENT_ID }}');
  </script>
  {% endif %}

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or site.meta.title }}</title>
  <meta name="description" content="{{ description or site.description }}">

  <!-- Robots: noindex for non-production environments -->
  {% if env.ELEVENTY_ENV != 'production' %}
  <meta name="robots" content="noindex, nofollow">
  {% endif %}

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title or site.meta.title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:image" content="{{ site.url }}{{ site.meta.ogImage }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="en_US">
  <meta property="og:site_name" content="{{ site.name }}">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or site.meta.title }}">
  <meta name="twitter:description" content="{{ description or site.description }}">
  <meta name="twitter:image" content="{{ site.url }}{{ site.meta.ogImage }}">

  <!-- Canonical URL -->
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Schema.org Structured Data - Organization (Global) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "{{ site.url }}/#organization",
    "name": "Zunkiree Labs",
    "url": "{{ site.url }}",
    "logo": "{{ site.url }}/assets/images/zunkireelabs-logo-round.svg",
    "description": "AI infrastructure company building custom AI systems, RAG pipelines, AI agents, and enterprise software. Headquartered in Kathmandu, Nepal.",
    "foundingDate": "2018",
    "founder": {
      "@type": "Person",
      "name": "Sadin Shrestha"
    },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Kathmandu",
      "addressRegion": "Bagmati Province",
      "addressCountry": "NP"
    },
    "sameAs": [
      "{{ site.social.twitter }}",
      "{{ site.social.linkedin }}",
      "{{ site.social.github }}"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "sales",
      "email": "{{ site.email }}",
      "telephone": "{{ site.phone }}",
      "url": "{{ site.url }}/contact/"
    }
  }
  </script>

  <!-- Schema.org - WebSite (Homepage only) -->
  {% if page.url == "/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Zunkiree Labs",
    "url": "{{ site.url }}/",
    "description": "{{ site.description }}"
  }
  </script>
  <!-- Schema.org - LocalBusiness (Homepage only) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "{{ site.url }}/#localbusiness",
    "name": "Zunkiree Labs",
    "description": "AI development company in Kathmandu, Nepal. Custom AI systems, AI agents, RAG pipelines, and enterprise software.",
    "url": "{{ site.url }}",
    "telephone": "{{ site.phone }}",
    "email": "{{ site.email }}",
    "logo": "{{ site.url }}/assets/images/zunkireelabs-logo-round.svg",
    "image": "{{ site.url }}/assets/images/og-image.svg",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Kathmandu",
      "addressRegion": "Bagmati",
      "addressCountry": "NP"
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "09:00",
        "closes": "18:00"
      }
    ],
    "priceRange": "$$"
  }
  </script>
  {% endif %}

  <!-- Schema.org - Page-specific (Product/Service/Article) -->
  {% if schemaType == "product" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "{{ title }}",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "{{ description }}",
    "url": "{{ site.url }}{{ page.url }}",
    "provider": {
      "@type": "Organization",
      "name": "Zunkiree Labs",
      "url": "{{ site.url }}"
    }
  }
  </script>
  {% endif %}

  {% if schemaType == "service" and serviceId %}
  {%- set serviceData = servicesDetails[serviceId] -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": "{{ site.url }}{{ page.url }}#service",
    "name": "{{ serviceData.title }}",
    "description": "{{ serviceData.description }}",
    "url": "{{ site.url }}{{ page.url }}",
    "serviceType": "{{ serviceData.category }}",
    "provider": {
      "@type": "Organization",
      "@id": "{{ site.url }}/#organization",
      "name": "Zunkiree Labs",
      "url": "{{ site.url }}"
    },
    "areaServed": {
      "@type": "Country",
      "name": "Nepal"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "{{ serviceData.title }} Services",
      "itemListElement": [
        {% for useCase in serviceData.useCases %}
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "{{ useCase.title }}",
            "description": "{{ useCase.description }}"
          }
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
    }
  }
  </script>
  {% endif %}

  {# FAQPage schema - supports both explicit faqs and service page FAQs #}
  {%- set pageFaqs = faqs if faqs else (servicesDetails[serviceId].faq if serviceId and servicesDetails[serviceId] else null) -%}
  {% if pageFaqs %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for faq in pageFaqs %}
      {
        "@type": "Question",
        "name": "{{ faq.question }}",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "{{ faq.answer }}"
        }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
  {% endif %}

  <!-- Schema.org - BreadcrumbList (all pages except homepage) -->
  {% if page.url != "/" %}
  {%- set urlParts = page.url | split("/") -%}
  {%- set breadcrumbPath = "" -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{ site.url }}/"
      }{% if urlParts.length > 0 %},{% endif %}
      {% for part in urlParts %}
      {%- set breadcrumbPath = breadcrumbPath + "/" + part -%}
      {
        "@type": "ListItem",
        "position": {{ loop.index + 1 }},
        "name": "{{ part | titleCase }}"{% if not loop.last %},
        "item": "{{ site.url }}{{ breadcrumbPath }}/"{% endif %}
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
  {% endif %}

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/favicon.png">

  <!-- Fonts - DM Sans + DM Mono from Google -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400;1,9..40,500&display=swap" rel="stylesheet">

</head>
<body class="font-sans antialiased overflow-x-hidden">

  <!-- Skip to main content link for accessibility -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  {% include "partials/header.njk" %}

  <main id="main-content">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <!-- Main JS + CSS (bundled via Vite) -->
  <script type="module" src="/assets/js/main.js"></script>

  {# Zunkiree Search Widget - loads on all pages #}
  <script
    src="https://zunkiree-search-v1.vercel.app/zunkiree-widget.iife.js"
    data-site-id="zunkireelabs"
    data-api-url="https://api.zunkireelabs.com">
  </script>
  <script>
    function openZunkireeWidget() {
      var fab = document.querySelector('.zk-fab');
      if (fab) fab.click();
    }
  </script>

</body>
</html>
