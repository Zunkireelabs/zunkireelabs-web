---
layout: base.njk
---

{# =====================================================
   SHARED CATALOG LAYOUT
   Used for: Services page, Products page
   Inner pages — white/light bg, homepage brand colors as accents
   ===================================================== #}

{% set items = products if catalogType == "products" else services %}
{% set categories = catalogCategories | default([]) %}

{# =====================================================
   SECTION 1: HERO — Dark split layout with hero image (matches stage)
   ===================================================== #}
<section class="relative overflow-hidden" style="background: #0a1f2b; min-height: 340px;">

  {# Hero image — right half, fills the section #}
  {% if heroImage %}
  <div class="absolute inset-y-0 right-0 w-1/2 pointer-events-none" aria-hidden="true">
    <img
      src="{{ heroImage }}"
      alt=""
      class="w-full h-full object-cover object-center"
      style="opacity: 0.55;"
    />
    {# Left fade so image blends into dark bg #}
    <div style="position:absolute;inset:0;background:linear-gradient(to right, #0a1f2b 0%, transparent 55%);"></div>
  </div>
  {% endif %}

  {# Subtle sage/blue blobs for depth #}
  <div aria-hidden="true" style="position:absolute;bottom:-20%;left:-5%;width:420px;height:420px;background:radial-gradient(ellipse,rgba(144,169,89,0.18) 0%,transparent 70%);filter:blur(48px);border-radius:50%;pointer-events:none;"></div>

  {# Hero content — left aligned #}
  <div
    class="catalog-hero-content relative z-10 max-w-screen-2xl mx-auto px-6 sm:px-8 lg:px-10 pt-32 pb-16 md:pt-36 md:pb-20"
    style="opacity: 0; transform: translateY(36px);"
  >
    <nav class="sr-only" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm">
        <li><a href="/" class="text-zunkiree-400 hover:text-zunkiree-300 transition-colors">Home</a></li>
        <li style="color:rgba(255,255,255,0.3)">/</li>
        <li style="color:rgba(255,255,255,0.55)">{{ heroLabel | default(heroTitle) }}</li>
      </ol>
    </nav>

    <h1 class="text-4xl md:text-[3.5rem] font-bold leading-[1.08] tracking-[-0.02em] text-white max-w-xl">
      {{ heroTitle }}
    </h1>

    <p class="text-lg md:text-xl max-w-lg mt-5 leading-relaxed font-light" style="color:rgba(255,255,255,0.65);">
      {{ heroTagline }}
    </p>
  </div>

</section>

{# Hero entrance animation #}
<script>
(function () {
  var _ran = false;
  function runHero() {
    if (_ran || !window.gsap) return;
    _ran = true;
    window.gsap.to('.catalog-hero-content', { y: 0, opacity: 1, duration: 0.85, delay: 0.1, ease: 'power2.out' });
  }
  function tryRun() {
    if (_ran) return;
    if (window.gsap) { runHero(); return; }
    setTimeout(tryRun, 80);
  }
  document.addEventListener('DOMContentLoaded', tryRun);
  window.addEventListener('load', tryRun);
})();
</script>

{# =====================================================
   SECTION 2: SIMPLE INTRO — white bg, heading + subtitle
   ===================================================== #}
<section class="pt-10 pb-4 px-4 sm:px-6 lg:px-8 bg-white" data-reveal>
  <div class="max-w-screen-2xl mx-auto">
    <h2 class="text-3xl md:text-[2.25rem] font-bold leading-[1.08] tracking-tight mb-4" style="color:#032D42;">
      {{ introHeadline }}
    </h2>
    {% if introDescription %}
    <p class="text-base md:text-lg leading-relaxed" style="color:#1d1d1d;">
      {{ introDescription }}
    </p>
    {% endif %}
  </div>
</section>

{# =====================================================
   SECTION 4: TAB NAV + CATALOG CARDS — white bg
   ===================================================== #}
<section
  class="py-12 md:py-16 px-4 sm:px-6 lg:px-8 bg-white"
  x-data="{ activeTab: 'all' }"
  data-reveal
>
  <div class="max-w-screen-2xl mx-auto">

    {% if categories.length > 0 %}
    <div class="border-b border-gray-200 mb-0">
      <nav class="flex gap-8 -mb-px overflow-x-auto" aria-label="{{ catalogType | capitalize }} categories">
        <button
          @click="activeTab = 'all'"
          class="pb-4 text-base font-medium border-b-2 transition-colors whitespace-nowrap"
          :class="activeTab === 'all' ? 'border-zunkiree-600 text-zunkiree-600' : 'border-transparent text-gray-400 hover:text-gray-700 hover:border-gray-300'"
        >
          All {{ catalogType | capitalize }}
        </button>
        {% for category in categories %}
        <button
          @click="activeTab = '{{ category.id }}'"
          class="pb-4 text-base font-medium border-b-2 transition-colors whitespace-nowrap"
          :class="activeTab === '{{ category.id }}' ? 'border-zunkiree-600 text-zunkiree-600' : 'border-transparent text-gray-400 hover:text-gray-700 hover:border-gray-300'"
        >
          {{ category.label }}
        </button>
        {% endfor %}
      </nav>
    </div>
    {% endif %}

    {# 3-col card grid — ServiceNow-style image-first cards #}
    <div class="{% if categories.length > 0 %}mt-10{% else %}mt-8{% endif %}">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10" style="gap: 40px;">
        {% for item in items %}
          <article
            class="group flex flex-col"
            {% if categories.length > 0 %}
            x-show="activeTab === 'all'{% for category in categories %} || (activeTab === '{{ category.id }}' && '{{ item.category }}' === '{{ category.label }}'){% endfor %}"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            {% endif %}
          >
            {# Mockup image area — rounded image block sits directly on page #}
            <a href="{{ item.url }}" class="block relative overflow-hidden" style="border-radius: 32px; background: linear-gradient(135deg, #0d2137 0%, #1a3a5c 50%, #0f2d4a 100%); min-height: 260px;">
              {% if item.mockup %}
              <img
                src="{{ item.mockup }}"
                alt="{{ item.title }} interface"
                class="w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03]"
                style="height: 260px;"
                loading="lazy"
              />
              {% else %}
              {# Icon placeholder when no mockup image #}
              <div class="flex items-center justify-center" style="min-height: 200px;">
                <div class="w-20 h-20 rounded-2xl flex items-center justify-center" style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);">
                  {% if item.icon == "search" %}
                  <svg class="w-10 h-10 text-white opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-4.35-4.35"/></svg>
                  {% elif item.icon == "cart" %}
                  <svg class="w-10 h-10 text-white opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                  {% elif item.icon == "calendar" %}
                  <svg class="w-10 h-10 text-white opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  {% elif item.icon == "users" %}
                  <svg class="w-10 h-10 text-white opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
                  {% elif item.icon == "factory" %}
                  <svg class="w-10 h-10 text-white opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 21h18M3 10h18M3 7l9-4 9 4M4 10v11M20 10v11M8 14v3M12 14v3M16 14v3"/></svg>
                  {% elif item.icon == "tooth" %}
                  <svg class="w-10 h-10 text-white opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2C9.5 2 7 4 7 6.5c0 1.5.5 3 .5 4.5 0 3-1 5-1 8 0 1.5.5 3 2 3s2-2 3.5-2 2 2 3.5 2 2-1.5 2-3c0-3-1-5-1-8 0-1.5.5-3 .5-4.5C17 4 14.5 2 12 2z"/></svg>
                  {% else %}
                  <svg class="w-10 h-10 text-white opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path stroke-linecap="round" stroke-width="1.5" d="M8 21h8M12 17v4"/></svg>
                  {% endif %}
                </div>
              </div>
              {% endif %}
              {# Subtle bottom fade #}
              <div style="position:absolute;bottom:0;left:0;right:0;height:40px;background:linear-gradient(to top,rgba(13,33,55,0.4),transparent);pointer-events:none;"></div>
            </a>

            {# Card body — no container, text sits directly below image #}
            <div class="flex flex-col flex-1 pt-5 pb-2">
              <h3 class="text-2xl font-bold mb-2 group-hover:text-zunkiree-700 transition-colors" style="color:#032D42;">{{ item.title }}</h3>
              <p class="text-lg line-clamp-3 flex-grow mb-6" style="color:#1d1d1d;line-height:1.5;">{{ item.description }}</p>
              <a href="{{ item.url }}" class="inline-flex items-center gap-2 text-sm font-semibold text-gray-900 hover:text-zunkiree-700 transition-colors mt-auto">
                {{ item.cta | default('Learn More') }}
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>

  </div>
</section>

{# =====================================================
   SECTION 5: CTA BAND — homepage design style
   ===================================================== #}
<section class="relative py-16 md:py-24 px-4 sm:px-6 lg:px-8 overflow-hidden" style="background:#0a1228;" data-reveal>

  {# Purple glow — top right #}
  <div aria-hidden="true" style="position:absolute;top:-20%;right:-5%;width:520px;height:520px;background:radial-gradient(ellipse,rgba(110,60,200,0.45) 0%,transparent 65%);filter:blur(72px);border-radius:50%;pointer-events:none;"></div>
  {# Purple glow — bottom left #}
  <div aria-hidden="true" style="position:absolute;bottom:-25%;left:-8%;width:460px;height:460px;background:radial-gradient(ellipse,rgba(90,40,180,0.35) 0%,transparent 65%);filter:blur(72px);border-radius:50%;pointer-events:none;"></div>

  <div class="relative z-10 max-w-screen-2xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

      {# Left — eyebrow + headline + description #}
      <div>
        <p class="text-xs font-semibold tracking-widest uppercase mb-4" style="color:#76b900;">Custom Engagements</p>
        <h2 class="text-4xl md:text-[3.5rem] font-bold leading-[1.08] tracking-[-0.02em] mb-5" style="color:#ffffff;">
          {{ ctaHeadline | default('Ready to get started?') | replace('. ', '.<br>') | safe }}
        </h2>
        <p class="text-base md:text-lg leading-relaxed" style="color:#ffffff;">
          {{ ctaDescription | default('Let\'s discuss how we can help you achieve your goals.') }}
        </p>
      </div>

      {# Right — glass panel with two action rows #}
      <div class="cta-band-panel">

        <a href="{{ ctaButtonUrl | default('/contact/') }}" class="cta-band-row group">
          <div class="cta-band-icon">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 18v-6a9 9 0 0118 0v6"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-base font-semibold text-white mb-1">{{ ctaButtonText | default('Schedule a Call') }}</p>
            <p class="text-sm leading-snug" style="color:rgba(255,255,255,0.60);">Tell us what you're trying to solve — we'll tell you exactly whether we can help, and what it would take.</p>
          </div>
          <div class="cta-band-arrow">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </div>
        </a>

        <div class="mx-5 border-t border-white/10" aria-hidden="true"></div>

        <a href="/services/" class="cta-band-row group">
          <div class="cta-band-icon">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-base font-semibold text-white mb-1">See all services</p>
            <p class="text-sm leading-snug" style="color:rgba(255,255,255,0.60);">Browse our full catalogue — AI systems, custom software, SaaS, web, mobile, and AEO.</p>
          </div>
          <div class="cta-band-arrow">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </div>
        </a>

      </div>
    </div>
  </div>
  </div>
</section>


{# =====================================================
   SECTION 7: CTA + FAQ partial
   ===================================================== #}
{% set pageFaqData = servicesFaq if catalogType == "services" else (productsFaq if catalogType == "products" else faq) %}
{% set faq = pageFaqData if pageFaqData else faq %}
{# {% set ctaLightTheme = true %}
{% include "partials/cta-faq.njk" %} #}

{# =====================================================
   SCHEMA MARKUP
   ===================================================== #}
{% if schemaType %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "{{ schemaType }}",
  "name": "{{ heroTitle }} - Zunkiree Labs",
  "description": "{{ description }}",
  "provider": { "@type": "Organization", "name": "Zunkiree Labs", "url": "https://zunkireelabs.com" }
  {% if catalogType == "services" %},
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "{{ heroTitle }}",
    "itemListElement": [
      {% for item in items %}
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "{{ item.title }}", "description": "{{ item.description }}" } }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  {% elif catalogType == "products" %},
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "{{ heroTitle }}",
    "itemListElement": [
      {% for item in items %}
      { "@type": "Offer", "itemOffered": { "@type": "SoftwareApplication", "name": "{{ item.title }}", "description": "{{ item.description }}", "applicationCategory": "BusinessApplication" } }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  {% endif %}
}
</script>
{% endif %}

{% set schemaFaq = servicesFaq if catalogType == "services" else (productsFaq if catalogType == "products" else faq) %}
{% if schemaFaq and schemaFaq.length > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in schemaFaq %}
    { "@type": "Question", "name": "{{ item.question }}", "acceptedAnswer": { "@type": "Answer", "text": "{{ item.answer }}" } }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}
