---
layout: base.njk
---

{# =====================================================
   SHARED CATALOG LAYOUT
   Used for: Services page, Products page
   Inner pages — white/light bg, homepage brand colors as accents
   ===================================================== #}

{% set items = products if catalogType == "products" else services %}
{% set categories = catalogCategories | default([]) %}

{# =====================================================
   SECTION 1: HERO — Gradient mesh aurora (white bg)
   ===================================================== #}
<section class="relative min-h-[62vh] flex flex-col items-center justify-center overflow-hidden bg-white">

  {# Two blobs blended across the full bottom width #}
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">

    {# Sage — left half, bleeds to center #}
    <div class="catalog-blob-sage-tl" style="
      position: absolute;
      bottom: -15%; left: -5%;
      width: 65%; height: 500px;
      background: radial-gradient(ellipse at 40% 80%, rgba(144,169,89,0.55) 0%, transparent 65%);
      filter: blur(32px);
      border-radius: 50%;
      will-change: transform;
    "></div>

    {# Blue — right half, bleeds to center #}
    <div class="catalog-blob-blue-tr" style="
      position: absolute;
      bottom: -15%; right: -5%;
      width: 65%; height: 500px;
      background: radial-gradient(ellipse at 60% 80%, rgba(61,143,212,0.42) 0%, transparent 65%);
      filter: blur(36px);
      border-radius: 50%;
      will-change: transform;
    "></div>

    {# White fade from top — keeps heading area clean #}
    <div style="position: absolute; top: 0; left: 0; right: 0; height: 50%; background: linear-gradient(to bottom, #ffffff, transparent);"></div>

    {# Thin bottom fade — just enough to blend the hard edge #}
    <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 18%; background: linear-gradient(to top, #ffffff, transparent);"></div>

  </div>

  {# Hero content #}
  <div
    class="catalog-hero-content relative z-10 flex flex-col items-center text-center w-full max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-6 pt-36 pb-20 md:pt-40 md:pb-24"
    style="opacity: 0; transform: translateY(48px);"
  >
    <nav class="mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center justify-center gap-2 text-sm">
        <li><a href="/" class="text-zunkiree-600 hover:text-zunkiree-700 transition-colors">Home</a></li>
        <li class="text-gray-300">/</li>
        <li class="text-gray-500">{{ heroLabel | default(heroTitle) }}</li>
      </ol>
    </nav>

    {% if heroLabel %}
    <p class="inline-flex items-center gap-2 text-xs font-semibold tracking-widest uppercase text-zunkiree-600 mb-5 px-3 py-1 rounded-full bg-zunkiree-50 border border-zunkiree-200">
      <span class="w-1.5 h-1.5 rounded-full bg-zunkiree-500 inline-block"></span>
      {{ heroLabel }}
    </p>
    {% endif %}

    <h1 class="text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight leading-[1.04] max-w-3xl mx-auto text-gray-900 text-center">
      {{ heroTitle }}
    </h1>

    <p class="text-xl md:text-2xl max-w-2xl mx-auto text-gray-500 mt-6 text-center leading-relaxed font-light">
      {{ heroTagline }}
    </p>
  </div>

</section>

{# Hero entrance + blob float animations #}
<script>
(function () {
  var _ran = false;
  function runHero() {
    if (_ran || !window.gsap) return;
    _ran = true;
    var g = window.gsap;

    g.to('.catalog-hero-content', { y: 0, opacity: 1, duration: 0.85, delay: 0.1, ease: 'power2.out' });

    g.to('.catalog-blob-sage-tl', { x: 24, y: 18, duration: 7, repeat: -1, yoyo: true, ease: 'sine.inOut' });
    g.to('.catalog-blob-blue-tr', { x: -20, y: 22, duration: 9, repeat: -1, yoyo: true, ease: 'sine.inOut', delay: 1.2 });
    g.to('.catalog-blob-sage-c',  { x: 16, y: -14, duration: 8, repeat: -1, yoyo: true, ease: 'sine.inOut', delay: 0.6 });
    g.to('.catalog-blob-navy-b',  { x: -18, y: -10, duration: 10, repeat: -1, yoyo: true, ease: 'sine.inOut', delay: 2 });
  }
  function tryRun() {
    if (_ran) return;
    if (window.gsap) { runHero(); return; }
    setTimeout(tryRun, 80);
  }
  document.addEventListener('DOMContentLoaded', tryRun);
  window.addEventListener('load', tryRun);
})();
</script>

{# =====================================================
   SECTION 2+3: INTRO + DEFINITION BLOCK — white bg, glass card
   ===================================================== #}
<section class="pt-4 pb-16 md:pt-6 md:pb-20 px-4 sm:px-6 lg:px-8 bg-white" data-reveal>
  <div class="max-w-screen-2xl mx-auto">

    {# Glass card — navy base + glass effect #}
    <div style="
      position: relative;
      overflow: hidden;
      background: rgba(10,31,43,0.82);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 1.25rem;
      padding: 2.5rem 2.5rem;
      box-shadow: 0 8px 40px 0 rgba(10,31,43,0.18), 0 1px 0 0 rgba(255,255,255,0.04) inset;
    ">

      {# Sage blob — bottom left corner #}
      <div aria-hidden="true" style="
        position: absolute; bottom: -40%; left: -10%;
        width: 420px; height: 420px;
        background: radial-gradient(ellipse, rgba(144,169,89,0.28) 0%, transparent 70%);
        filter: blur(40px);
        border-radius: 50%;
        pointer-events: none;
      "></div>

      {# Blue blob — right corner #}
      <div aria-hidden="true" style="
        position: absolute; top: -40%; right: -10%;
        width: 380px; height: 380px;
        background: radial-gradient(ellipse, rgba(61,143,212,0.22) 0%, transparent 70%);
        filter: blur(44px);
        border-radius: 50%;
        pointer-events: none;
      "></div>

      {# Intro two-column — right col stacks description + definition card #}
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-20 items-start">

        {# Left — eyebrow, headline, illustration #}
        <div class="text-left">
          <p class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: #90a959;">What We Build</p>
          <h2 class="text-3xl sm:text-4xl md:text-[40px] font-bold tracking-tight leading-[1.12] text-white text-left mb-4">
            {{ introHeadline }}
          </h2>
          {% if catalogType == "products" %}
          <div id="lottie-product-intro" class="w-full max-w-xs mx-auto block mt-2" style="min-height:200px;"></div>
          {% else %}
          <img
            src="/assets/images/hand-coding.webp"
            alt="Hand coding illustration"
            class="w-full max-w-xs opacity-90 mx-auto block mt-2"
          />
          {% endif %}
        </div>

        {# Right — description then definition card directly below #}
        <div class="lg:pt-1 flex flex-col gap-6">
          <p class="text-lg leading-relaxed" style="color: rgba(255,255,255,0.70);">
            {{ introDescription }}
          </p>

          {% if definitionBlock %}
          <div style="
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255,255,255,0.06);
            border-top: 1px solid rgba(255,255,255,0.12);
            border-radius: 0.875rem;
            padding: 1.5rem 1.75rem;
            box-shadow: 0 4px 32px rgba(0,0,0,0.25), inset 0 1px 0 rgba(255,255,255,0.06);
          ">
            <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #90a959;">Quick Definition</p>
            <h3 class="text-base font-semibold mb-2 text-white">{{ definitionBlock.question }}</h3>
            <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.60);">{{ definitionBlock.answer }}</p>
          </div>
          {% endif %}
        </div>

      </div>

    </div>
  </div>
</section>

{# =====================================================
   SECTION 4: TAB NAV + CATALOG CARDS — white bg
   ===================================================== #}
<section
  class="py-12 md:py-16 px-4 sm:px-6 lg:px-8 bg-white"
  x-data="{ activeTab: 'all' }"
  data-reveal
>
  <div class="max-w-screen-2xl mx-auto">

    {% if categories.length > 0 %}
    <div class="border-b border-gray-200 mb-0">
      <nav class="flex gap-8 -mb-px overflow-x-auto" aria-label="{{ catalogType | capitalize }} categories">
        <button
          @click="activeTab = 'all'"
          class="pb-4 text-sm font-medium border-b-2 transition-colors whitespace-nowrap"
          :class="activeTab === 'all' ? 'border-zunkiree-600 text-zunkiree-600' : 'border-transparent text-gray-400 hover:text-gray-700 hover:border-gray-300'"
        >
          All {{ catalogType | capitalize }}
        </button>
        {% for category in categories %}
        <button
          @click="activeTab = '{{ category.id }}'"
          class="pb-4 text-sm font-medium border-b-2 transition-colors whitespace-nowrap"
          :class="activeTab === '{{ category.id }}' ? 'border-zunkiree-600 text-zunkiree-600' : 'border-transparent text-gray-400 hover:text-gray-700 hover:border-gray-300'"
        >
          {{ category.label }}
        </button>
        {% endfor %}
      </nav>
    </div>
    {% endif %}

    {# 3-col grid — 3×3 for 9 services, 2×3 for 6 products, no orphan cards #}
    <div class="border-l border-gray-200 {% if categories.length > 0 %}mt-0{% else %}mt-8{% endif %}">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
        {% for item in items %}
          <article
            class="group flex flex-col p-6 md:p-8 border-b border-r border-gray-200 transition-colors hover:bg-[#f8faf5]"
            {% if categories.length > 0 %}
            x-show="activeTab === 'all'{% for category in categories %} || (activeTab === '{{ category.id }}' && '{{ item.category }}' === '{{ category.label }}'){% endfor %}"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            {% endif %}
          >
            {% if item.category %}
            <span class="text-xs font-medium mb-3 text-gray-400 uppercase tracking-wide">{{ item.category }}</span>
            {% elif item.status %}
            <span class="inline-flex items-center gap-1.5 text-xs font-medium mb-3 {% if item.status == 'Available' %}text-green-600{% elif item.status == 'Coming Soon' %}text-amber-600{% else %}text-blue-600{% endif %}">
              {% if item.status == 'Available' %}
              <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
              {% elif item.status == 'Coming Soon' %}
              <span class="w-1.5 h-1.5 bg-amber-500 rounded-full animate-pulse"></span>
              {% endif %}
              {{ item.status }}
            </span>
            {% endif %}

            <h3 class="text-lg font-semibold mb-2 text-gray-900 group-hover:text-zunkiree-700 transition-colors">{{ item.title }}</h3>

            {% if item.tagline %}
            <p class="text-sm font-medium text-zunkiree-600 mb-3">{{ item.tagline }}</p>
            {% endif %}

            <p class="text-sm leading-relaxed mb-8 flex-grow text-gray-500">{{ item.description }}</p>

            <div class="flex items-center justify-between mt-auto">
              <a href="{{ item.url }}" class="text-sm font-medium text-zunkiree-600 hover:text-zunkiree-700 transition-colors">
                {{ item.cta | default('Learn more') }}
              </a>
              <a href="{{ item.url }}" class="text-zunkiree-600 hover:text-zunkiree-700 hover:translate-x-1 transition-all" aria-label="Learn more about {{ item.title }}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </a>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>

  </div>
</section>

{# =====================================================
   SECTION 5: CTA BAND — homepage design style
   ===================================================== #}
<section class="relative py-16 md:py-24 px-4 sm:px-6 lg:px-8 overflow-hidden" style="background: #0a1f2b;" data-reveal>

  {# Sage blob — bottom left #}
  <div aria-hidden="true" style="position:absolute;bottom:-30%;left:-8%;width:500px;height:500px;background:radial-gradient(ellipse,rgba(144,169,89,0.22) 0%,transparent 70%);filter:blur(60px);border-radius:50%;pointer-events:none;"></div>
  {# Blue blob — top right #}
  <div aria-hidden="true" style="position:absolute;top:-20%;right:-5%;width:440px;height:440px;background:radial-gradient(ellipse,rgba(61,143,212,0.18) 0%,transparent 70%);filter:blur(60px);border-radius:50%;pointer-events:none;"></div>

  <div class="relative z-10 max-w-screen-2xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-[2fr_3fr] gap-10 lg:gap-16 items-center">

      {# Left — eyebrow + headline + description #}
      <div>
        <p class="text-xs font-semibold tracking-widest uppercase mb-4" style="color:#90a959;">Custom Engagements</p>
        <h2 class="text-4xl md:text-5xl font-bold leading-tight mb-5">
          <span style="color:#90a959;">{{ ctaHeadline | default('Ready to get started?') | replace('. ', '.<br>') | safe }}</span>
        </h2>
        <p class="text-base md:text-lg leading-relaxed max-w-sm" style="color:rgba(255,255,255,0.65);">
          {{ ctaDescription | default('Let\'s discuss how we can help you achieve your goals.') }}
        </p>
      </div>

      {# Right — glass panel with two action rows #}
      <div class="cta-band-panel">

        <a href="{{ ctaButtonUrl | default('/contact/') }}" class="cta-band-row group">
          <div class="cta-band-icon">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 18v-6a9 9 0 0118 0v6"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-base font-semibold text-white mb-1">{{ ctaButtonText | default('Schedule a Call') }}</p>
            <p class="text-sm leading-snug" style="color:rgba(255,255,255,0.60);">Tell us what you're trying to solve — we'll tell you exactly whether we can help, and what it would take.</p>
          </div>
          <div class="cta-band-arrow">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </div>
        </a>

        <div class="mx-5 border-t border-white/10" aria-hidden="true"></div>

        <a href="/services/" class="cta-band-row group">
          <div class="cta-band-icon">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-base font-semibold text-white mb-1">See all services</p>
            <p class="text-sm leading-snug" style="color:rgba(255,255,255,0.60);">Browse our full catalogue — AI systems, custom software, SaaS, web, mobile, and AEO.</p>
          </div>
          <div class="cta-band-arrow">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </div>
        </a>

      </div>
    </div>
  </div>
  </div>
</section>


{# =====================================================
   SECTION 7: CTA + FAQ partial
   ===================================================== #}
{% set pageFaqData = servicesFaq if catalogType == "services" else (productsFaq if catalogType == "products" else faq) %}
{% set faq = pageFaqData if pageFaqData else faq %}
{# {% set ctaLightTheme = true %}
{% include "partials/cta-faq.njk" %} #}

{# =====================================================
   SCHEMA MARKUP
   ===================================================== #}
{% if schemaType %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "{{ schemaType }}",
  "name": "{{ heroTitle }} - Zunkiree Labs",
  "description": "{{ description }}",
  "provider": { "@type": "Organization", "name": "Zunkiree Labs", "url": "https://zunkireelabs.com" }
  {% if catalogType == "services" %},
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "{{ heroTitle }}",
    "itemListElement": [
      {% for item in items %}
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "{{ item.title }}", "description": "{{ item.description }}" } }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  {% elif catalogType == "products" %},
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "{{ heroTitle }}",
    "itemListElement": [
      {% for item in items %}
      { "@type": "Offer", "itemOffered": { "@type": "SoftwareApplication", "name": "{{ item.title }}", "description": "{{ item.description }}", "applicationCategory": "BusinessApplication" } }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  {% endif %}
}
</script>
{% endif %}

{% set schemaFaq = servicesFaq if catalogType == "services" else (productsFaq if catalogType == "products" else faq) %}
{% if schemaFaq and schemaFaq.length > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in schemaFaq %}
    { "@type": "Question", "name": "{{ item.question }}", "acceptedAnswer": { "@type": "Answer", "text": "{{ item.answer }}" } }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}
