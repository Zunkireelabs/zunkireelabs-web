---
layout: base.njk
schemaType: service
---

{# =====================================================
   SERVICE PAGE LAYOUT — Redesigned to match homepage theme
   Dark navy sections, sage accents, glass cards
   ===================================================== #}

{% set service = servicesDetails[serviceId] %}
{% set stories = servicesStories %}

{# =====================================================
   SECTION 1: HERO / LEADSPACE + LOGO MARQUEE — shared bg so glow bleeds through
   ===================================================== #}
<div class="relative" style="background-color:#0a1f2b; overflow-x:clip;">
<section class="relative min-h-[85vh] flex flex-col justify-center">

  {# Sage glow — sits low so it bleeds into the section below #}
  <div id="service-hero-blob" class="absolute pointer-events-none" aria-hidden="true" style="
    bottom: -30%; left: 50%; transform: translateX(-50%);
    width: 1000px; height: 700px;
    background: radial-gradient(ellipse at center, rgba(144,169,89,0.30) 0%, rgba(95,125,70,0.12) 45%, transparent 70%);
    filter: blur(56px);
  "></div>

  <div class="relative z-10 max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 w-full pt-36 pb-16 md:pt-40 md:pb-20">
    <div class="grid grid-cols-1 lg:grid-cols-[3fr_1.7fr] gap-8 lg:gap-12 items-center">

      {# Left: Content #}
      <div class="flex flex-col justify-center">

        {# Breadcrumb #}
        <nav class="flex items-center gap-2 text-sm mb-8" aria-label="Breadcrumb">
          <a href="/" class="text-white/50 hover:text-white transition-colors">Home</a>
          <span class="text-white/20">/</span>
          <a href="/services/" class="text-white/50 hover:text-white transition-colors">Services</a>
          <span class="text-white/20">/</span>
          <span class="text-white/40">{{ service.title }}</span>
        </nav>

        {# Eyebrow #}
        <span class="inline-block text-xs font-medium tracking-widest uppercase text-white/60 mb-6">{{ service.title }}</span>

        {# Title #}
        <h1 class="text-4xl sm:text-5xl md:text-[3.5rem] font-bold text-white tracking-[-0.02em] leading-[1.08] mb-6">
          {{ service.tagline }}
        </h1>

        {# Description #}
        <p class="text-lg md:text-xl text-white leading-relaxed mb-10 max-w-xl text-justify">
          {{ service.description }}
        </p>

        {# CTAs — match homepage exactly #}
        <div class="flex flex-col sm:flex-row items-start gap-4">
          <a href="{{ service.cta.primaryButton.url }}" class="inline-flex items-center justify-center px-7 py-3.5 rounded-full bg-zunkiree-600 hover:bg-zunkiree-700 text-white font-medium transition-all duration-200" data-track="cta" data-cta-id="service-hero-primary">
            {{ service.cta.primaryButton.text }}
          </a>
          <a href="{{ service.cta.secondaryButton.url }}" class="hero-btn-glow inline-flex items-center justify-center px-7 py-3.5 rounded-full border border-white/60 text-white font-medium hover:bg-white/10 transition-all duration-200" data-track="cta" data-cta-id="service-hero-secondary">
            {{ service.cta.secondaryButton.text }}
          </a>
        </div>
      </div>

      {# Right: empty spacer — gradient fills the space #}
      <div class="hidden lg:block"></div>

    </div>
  </div>
</section>

{# =====================================================
   SECTION 2: LOGO MARQUEE — matches homepage social proof
   ===================================================== #}
<section class="pt-8 pb-16" data-reveal>

  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-[2.25rem] font-bold leading-[1.08] tracking-tight text-white text-center mb-14 md:mb-16">
      Teams already building with <span style="color:#90a959;">Zunkiree.</span>
    </h2>
  </div>

  {# Logo Marquee — full-bleed, seamless loop #}
  <div id="logo-marquee" class="w-full relative overflow-hidden mb-16 md:mb-20 min-[1920px]:max-w-[1920px] min-[1920px]:mx-auto">
    <div id="logo-marquee-track" class="flex items-center gap-10 animate-marquee-scroll">
      {# First set #}
      <div class="w-40 h-10 flex items-center justify-center flex-shrink-0">
        <img src="/images/clients/mach24orbital.webp" alt="Mach24 Orbitals" class="max-w-full max-h-full object-contain brightness-0 invert" loading="lazy" width="128" height="32" />
      </div>
      <div class="w-40 h-10 flex items-center justify-center flex-shrink-0">
        <img src="/images/clients/corecloud365.svg" alt="Corecloud365" class="max-w-full max-h-full object-contain brightness-0 invert" loading="lazy" width="128" height="32" />
      </div>
      <div class="w-40 h-10 flex items-center justify-center flex-shrink-0">
        <img src="/images/clients/rapid-investment.svg" alt="Rapid Investment" class="max-w-full max-h-full object-contain brightness-0 invert" loading="lazy" width="128" height="32" />
      </div>
      <div class="w-40 h-10 flex items-center justify-center flex-shrink-0">
        <img src="/images/clients/khushbu-nirman-sewa.webp" alt="Khushbu Nirman Sewa" class="max-w-full max-h-full object-contain brightness-0 invert" loading="lazy" width="128" height="32" />
      </div>
      <div class="w-40 h-10 flex items-center justify-center flex-shrink-0">
        <img src="/images/clients/cms-group.webp" alt="CMS Group" class="max-w-full max-h-full object-contain brightness-0 invert" loading="lazy" width="128" height="32" />
      </div>
      <div class="w-40 h-10 flex items-center justify-center flex-shrink-0">
        <img src="/images/clients/admizz.webp" alt="Admizz" class="max-w-full max-h-full object-contain brightness-0 invert" loading="lazy" width="128" height="32" />
      </div>
      <div class="w-40 h-10 flex items-center justify-center flex-shrink-0">
        <img src="/images/clients/khems-cleaning.webp" alt="Khems Cleaning" class="max-w-full max-h-full object-contain brightness-0 invert" loading="lazy" width="128" height="32" />
      </div>
      {# Duplicate set for seamless loop #}
      <div class="w-40 h-10 flex items-center justify-center flex-shrink-0">
        <img src="/images/clients/mach24orbital.webp" alt="Mach24 Orbitals" class="max-w-full max-h-full object-contain brightness-0 invert" loading="lazy" width="128" height="32" />
      </div>
      <div class="w-40 h-10 flex items-center justify-center flex-shrink-0">
        <img src="/images/clients/corecloud365.svg" alt="Corecloud365" class="max-w-full max-h-full object-contain brightness-0 invert" loading="lazy" width="128" height="32" />
      </div>
      <div class="w-40 h-10 flex items-center justify-center flex-shrink-0">
        <img src="/images/clients/rapid-investment.svg" alt="Rapid Investment" class="max-w-full max-h-full object-contain brightness-0 invert" loading="lazy" width="128" height="32" />
      </div>
      <div class="w-40 h-10 flex items-center justify-center flex-shrink-0">
        <img src="/images/clients/khushbu-nirman-sewa.webp" alt="Khushbu Nirman Sewa" class="max-w-full max-h-full object-contain brightness-0 invert" loading="lazy" width="128" height="32" />
      </div>
      <div class="w-40 h-10 flex items-center justify-center flex-shrink-0">
        <img src="/images/clients/cms-group.webp" alt="CMS Group" class="max-w-full max-h-full object-contain brightness-0 invert" loading="lazy" width="128" height="32" />
      </div>
      <div class="w-40 h-10 flex items-center justify-center flex-shrink-0">
        <img src="/images/clients/admizz.webp" alt="Admizz" class="max-w-full max-h-full object-contain brightness-0 invert" loading="lazy" width="128" height="32" />
      </div>
      <div class="w-40 h-10 flex items-center justify-center flex-shrink-0">
        <img src="/images/clients/khems-cleaning.webp" alt="Khems Cleaning" class="max-w-full max-h-full object-contain brightness-0 invert" loading="lazy" width="128" height="32" />
      </div>
    </div>
  </div>

</section>

  {# Bottom blend — fades wrapper into the overview section below #}
  <div class="absolute bottom-0 left-0 right-0 h-20 pointer-events-none" aria-hidden="true" style="background: linear-gradient(to bottom, transparent 0%, #0c1f08 100%);"></div>

</div>{# /hero+marquee shared bg wrapper #}

{# =====================================================
   SECTION 3: OVERVIEW / VALUE PROP — Glass + sage gradient
   ===================================================== #}
<section class="py-8 md:py-12 px-4 sm:px-6 lg:px-8">

  <div class="max-w-screen-2xl mx-auto">

    {# Card — gradient + glow contained inside the border-radius #}
    <div class="relative overflow-hidden" style="
      border: 1px solid rgba(144,169,89,0.22);
      border-radius: 1rem;
      padding: 2.5rem 3rem;
      background: linear-gradient(135deg, #0c1f08 0%, rgba(42,76,18,0.55) 50%, #0c1f08 100%);
    ">

      {# Sage radial glow — clipped inside the card #}
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="
        background: radial-gradient(ellipse at 70% 50%, rgba(111,155,52,0.20) 0%, rgba(95,125,70,0.07) 45%, transparent 70%);
      "></div>

      <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start">

        {# Left: Large benefit headline #}
        <div data-reveal>
          <h2 class="text-3xl sm:text-4xl md:text-[44px] lg:text-[52px] font-bold leading-[1.08] tracking-tight text-white">
            {{ service.definition.heading }}
          </h2>
        </div>

        {# Right: Supporting paragraph #}
        <div class="lg:pt-2" data-reveal>
          <p class="text-lg md:text-xl text-white/70 leading-relaxed">
            {{ service.definition.content }}
          </p>
        </div>

      </div>
    </div>

  </div>
</section>

{# =====================================================
   SECTION 4: KEY BENEFITS — Cream white, sage + blue blobs
   ===================================================== #}
<section class="py-12 md:py-20 px-4 sm:px-6 lg:px-8" style="background:#eff4e8;">

  <div class="max-w-screen-2xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">

      {# Left: "Benefits" label #}
      <div class="lg:col-span-3" data-reveal>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight" style="color:#0a1f2b;">
          Benefits
        </h2>
      </div>

      {# Right: Benefits grid #}
      <div class="lg:col-span-9">
        {# SVG Gradient — sage #}
        <svg width="0" height="0" style="position:absolute;">
          <defs>
            <linearGradient id="benefit-icon-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" style="stop-color:#90a959;stop-opacity:1" />
              <stop offset="100%" style="stop-color:#6f9b34;stop-opacity:1" />
            </linearGradient>
          </defs>
        </svg>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
          {% for benefit in service.benefits %}
          <div style="background:#ffffff; border:1px solid rgba(0,0,0,0.07); border-radius:0.875rem; padding:1.5rem;" data-reveal>

            {# Icon container #}
            <div class="w-14 h-14 rounded-xl flex items-center justify-center mb-5" style="background:rgba(111,155,52,0.10); border:1px solid rgba(111,155,52,0.22);">
              {% if benefit.icon == "workflow" %}
              <svg class="w-7 h-7" fill="none" stroke="url(#benefit-icon-gradient)" viewBox="0 0 24 24" stroke-width="1.5">
                <circle cx="6" cy="6" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="6" cy="18" r="2"/><circle cx="18" cy="18" r="2"/><circle cx="12" cy="12" r="2"/>
                <path d="M6 8v2M6 14v2M18 8v2M18 14v2M8 6h2M14 6h2M8 18h2M14 18h2M8 12h2M14 12h2M12 8v2M12 14v2"/>
              </svg>
              {% elif benefit.icon == "speed" %}
              <svg class="w-7 h-7" fill="none" stroke="url(#benefit-icon-gradient)" viewBox="0 0 24 24" stroke-width="1.5">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/><circle cx="12" cy="12" r="3"/>
              </svg>
              {% elif benefit.icon == "integrate" %}
              <svg class="w-7 h-7" fill="none" stroke="url(#benefit-icon-gradient)" viewBox="0 0 24 24" stroke-width="1.5">
                <circle cx="12" cy="12" r="3"/><circle cx="4" cy="8" r="2"/><circle cx="20" cy="8" r="2"/><circle cx="4" cy="16" r="2"/><circle cx="20" cy="16" r="2"/>
                <path d="M6 8h3M15 8h3M6 16h3M15 16h3"/>
              </svg>
              {% else %}
              <svg class="w-7 h-7" fill="none" stroke="url(#benefit-icon-gradient)" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/>
              </svg>
              {% endif %}
            </div>

            <h3 class="text-base font-semibold mb-3" style="color:#0a1f2b;">{{ benefit.title }}</h3>
            <p class="text-sm leading-relaxed" style="color:#4a5568;">{{ benefit.description }}</p>
          </div>
          {% endfor %}
        </div>
      </div>

    </div>
  </div>
</section>

{# =====================================================
   SECTION 5: USE CASES — Dark navy, sage tabs
   ===================================================== #}
<section class="py-12 md:py-20 px-4 sm:px-6 lg:px-8" style="background:#0a1f2b;" x-data="{ activeTab: '{{ service.useCases[0].id }}' }">
  <div class="max-w-screen-2xl mx-auto">

    <div data-reveal>
      <h2 class="text-4xl md:text-5xl font-bold text-white tracking-tight mb-8">
        Use cases
      </h2>
    </div>

    {# Tab Navigation — sage active #}
    <div class="flex flex-wrap gap-2 mb-12">
      {% for useCase in service.useCases %}
      <button
        @click="activeTab = '{{ useCase.id }}'"
        :class="activeTab === '{{ useCase.id }}'
          ? 'text-white border-transparent'
          : 'text-white/60 hover:text-white hover:border-white/20'"
        :style="activeTab === '{{ useCase.id }}' ? 'background:linear-gradient(135deg,#6f9b34,#90a959);border-color:transparent;' : 'background:rgba(255,255,255,0.06);border-color:rgba(255,255,255,0.10);'"
        class="px-6 py-3 rounded-lg font-medium text-sm border transition-all duration-200"
      >
        {{ useCase.title }}
      </button>
      {% endfor %}
    </div>

    {# Tab Content #}
    {% for useCase in service.useCases %}
    <div
      x-show="activeTab === '{{ useCase.id }}'"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start"
    >
      {# Content #}
      <div class="pt-4">
        <h3 class="text-2xl md:text-3xl font-semibold text-white tracking-tight mb-4">
          {{ useCase.headline }}
        </h3>
        <p class="text-lg text-white/70 leading-relaxed mb-6">
          {{ useCase.description }}
        </p>
        <a href="/contact/" class="inline-flex items-center gap-2 text-zunkiree-400 hover:text-zunkiree-300 font-medium hover:gap-3 transition-all duration-200">
          Learn more
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>

      {# Image #}
      <div class="relative">
        <div class="aspect-[16/9] overflow-hidden rounded-xl">
          {% if useCase.image %}
          <img
            src="{{ useCase.image }}"
            alt="{{ useCase.headline }}"
            class="w-full h-full object-cover"
            loading="lazy"
          >
          {% else %}
          <div class="w-full h-full flex items-center justify-center rounded-xl" style="background:rgba(255,255,255,0.06);">
            <span class="text-white/30 text-sm">{{ useCase.headline }}</span>
          </div>
          {% endif %}
        </div>
      </div>
    </div>
    {% endfor %}

  </div>
</section>

{# =====================================================
   SECTION 6: CLIENT STORIES — Dark slightly lighter, glass cards
   ===================================================== #}
{% set clientStories = [] %}
{% for clientId in service.clients %}
  {% for story in stories %}
    {% if story.id == clientId %}
      {% set clientStories = clientStories.concat([story]) %}
    {% endif %}
  {% endfor %}
{% endfor %}

{% if clientStories.length > 0 %}
<section class="py-12 md:py-20 px-4 sm:px-6 lg:px-8" style="background:#0f2438;" x-data="{ currentSlide: 0, totalSlides: Math.ceil({{ clientStories.length }} / 2) }" data-reveal>
  <div class="max-w-screen-2xl mx-auto">

    {# Header #}
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between mb-12">
      <div class="mb-6 lg:mb-0">
        <p class="text-xs uppercase tracking-widest text-zunkiree-400 font-medium mb-4">Case Studies</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white tracking-tight">
          See how our clients build with Zunkiree
        </h2>
      </div>

      {# Client Logos #}
      <div class="flex flex-wrap items-center gap-6">
        {% for story in clientStories %}
        <img
          src="{{ story.logo }}"
          alt="{{ story.name }}"
          class="h-6 md:h-8 w-auto object-contain grayscale opacity-40 hover:grayscale-0 hover:opacity-90 transition-all duration-200"
          loading="lazy"
        >
        {% endfor %}
      </div>
    </div>

    {# Story Cards Slider #}
    <div class="relative overflow-hidden">
      <div
        class="flex transition-transform duration-500 ease-out"
        :style="'transform: translateX(-' + (currentSlide * 100) + '%)'"
      >
        {% for story in clientStories %}
        <div class="w-full md:w-1/2 flex-shrink-0 px-2">
          <div class="overflow-hidden h-full flex flex-col" style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:0.75rem;">

            <div class="p-8 flex flex-col md:flex-row gap-6 flex-1">
              {# Content #}
              <div class="flex-1 flex flex-col order-2 md:order-1">
                <h3 class="text-xl md:text-2xl font-semibold text-white tracking-tight mb-3">
                  {{ story.headline }}
                </h3>
                <p class="text-white/70 leading-relaxed mb-5 text-sm md:text-base flex-1">
                  {{ story.description }}
                </p>

                {# Stat #}
                <div class="flex items-baseline gap-2 mb-5">
                  <span class="text-3xl md:text-4xl font-bold text-zunkiree-400">{{ story.stat }}</span>
                  <span class="text-white/50 text-sm">{{ story.statLabel }}</span>
                </div>

                <a href="{{ story.ctaUrl }}" class="inline-flex items-center gap-2 text-zunkiree-400 font-medium hover:gap-3 hover:text-zunkiree-300 transition-all duration-200">
                  {{ story.ctaText }}
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                  </svg>
                </a>
              </div>

              {# Divider #}
              <div class="hidden md:block w-px order-2" style="background:rgba(255,255,255,0.10);"></div>

              {# Image #}
              <div class="flex-shrink-0 md:w-[45%] order-1 md:order-3 self-stretch">
                <div class="h-full min-h-[200px] overflow-hidden rounded-lg bg-white/5">
                  <img
                    src="{{ story.image }}"
                    alt="{{ story.name }} project"
                    class="w-full h-full object-cover"
                    loading="lazy"
                  >
                </div>
              </div>
            </div>

            {# Card Bottom #}
            <div class="px-8 py-5" style="border-top:1px solid rgba(255,255,255,0.08);">
              <div class="flex items-center justify-end">
                <img src="{{ story.logo }}" alt="{{ story.name }}" class="h-5 w-auto object-contain opacity-50" />
              </div>
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>

    {# Navigation #}
    {% if clientStories.length > 2 %}
    <div class="flex items-center justify-center gap-6 mt-8">
      <button
        @click="currentSlide = currentSlide > 0 ? currentSlide - 1 : totalSlides - 1"
        class="w-12 h-12 flex items-center justify-center rounded-lg text-white/60 hover:text-white transition-colors"
        style="border:1px solid rgba(255,255,255,0.15);"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <div class="flex items-center gap-2">
        <template x-for="i in totalSlides" :key="i">
          <button
            @click="currentSlide = i - 1"
            class="w-2.5 h-2.5 rounded-full transition-colors"
            :class="currentSlide === (i - 1) ? 'bg-zunkiree-500' : 'bg-white/20 hover:bg-white/40'"
          ></button>
        </template>
      </div>

      <button
        @click="currentSlide = currentSlide < totalSlides - 1 ? currentSlide + 1 : 0"
        class="w-12 h-12 flex items-center justify-center rounded-lg text-white/60 hover:text-white transition-colors"
        style="border:1px solid rgba(255,255,255,0.15);"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>
    {% endif %}

  </div>
</section>
{% endif %}

{# =====================================================
   SECTION 7: TECH STACK — Dark navy, glass chips
   ===================================================== #}
<section class="py-12 md:py-20 px-4 sm:px-6 lg:px-8" style="background:#0a1f2b;">
  <div class="max-w-screen-2xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">

      {# Left: Title #}
      <div class="lg:col-span-3" data-reveal>
        <p class="text-xs uppercase tracking-widest text-zunkiree-400 font-medium mb-4">Technology</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white tracking-tight">
          Technologies we use
        </h2>
      </div>

      {# Right: Tech Grid #}
      <div class="lg:col-span-9">
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
          {% for tech in service.techStack %}
          <div class="p-5 text-center transition-all duration-200 hover:border-zunkiree-400/40" style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.10); border-radius:0.5rem;" data-reveal>
            {% if tech.logo %}
            <div class="h-10 flex items-center justify-center mb-3">
              <img
                src="{{ tech.logo }}"
                alt="{{ tech.name }}"
                class="max-h-8 max-w-[100px] object-contain opacity-70"
                loading="lazy"
              />
            </div>
            {% endif %}
            <p class="font-medium text-white/80 text-sm mb-0.5">{{ tech.name }}</p>
            <p class="text-xs text-zunkiree-400 mb-0.5">{{ tech.category }}</p>
            <p class="text-[11px] text-white/50">{{ tech.description }}</p>
          </div>
          {% endfor %}
        </div>
      </div>

    </div>
  </div>
</section>

{# =====================================================
   SECTION 8: RELATED SERVICES — Dark slightly lighter
   ===================================================== #}
{% if service.relatedServices.length > 0 %}
<section class="py-12 md:py-20 px-4 sm:px-6 lg:px-8" style="background:#0f2438;">
  <div class="max-w-screen-2xl mx-auto">

    <div class="mb-12" data-reveal>
      <p class="text-xs uppercase tracking-widest text-zunkiree-400 font-medium mb-4">Related Services</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white tracking-tight">
        You might also need
      </h2>
    </div>

    {# SVG Gradient — sage #}
    <svg width="0" height="0" style="position:absolute;">
      <defs>
        <linearGradient id="related-icon-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#90a959;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#6f9b34;stop-opacity:1" />
        </linearGradient>
      </defs>
    </svg>

    {# Grid #}
    <div class="grid grid-cols-1 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
      {% for relatedId in service.relatedServices %}
      {% set related = services | find("id", relatedId) %}
      {% if related %}
      <a href="{{ related.url }}" class="group relative flex flex-col justify-between p-6 transition-all duration-300 min-h-[220px] {% if not loop.last %}md:border-r{% endif %}" style="background:rgba(255,255,255,0.04); border-bottom:1px solid rgba(255,255,255,0.08); border-right-color:rgba(255,255,255,0.08);" onmouseover="this.style.background='linear-gradient(135deg,#6f9b34,#5a8029)'" onmouseout="this.style.background='rgba(255,255,255,0.04)'">
        <div>
          <h3 class="text-base font-medium text-white group-hover:opacity-0 transition-opacity duration-300">{{ related.title }}</h3>
          <p class="text-base font-medium text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 absolute top-6 left-6 right-6">{{ related.description }}</p>
        </div>
        <div class="flex items-end justify-between mt-auto">
          {# Icon #}
          {% if related.icon == "ai" %}
          <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24">
            <path stroke="url(#related-icon-gradient)" class="group-hover:stroke-white" stroke-linecap="round" stroke-linejoin="round" stroke-width="0.75" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
          </svg>
          {% elif related.icon == "chat" %}
          <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24">
            <path stroke="url(#related-icon-gradient)" class="group-hover:stroke-white" stroke-linecap="round" stroke-linejoin="round" stroke-width="0.75" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
          {% elif related.icon == "data" %}
          <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24">
            <path stroke="url(#related-icon-gradient)" class="group-hover:stroke-white" stroke-linecap="round" stroke-linejoin="round" stroke-width="0.75" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path>
          </svg>
          {% elif related.icon == "code" %}
          <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24">
            <path stroke="url(#related-icon-gradient)" class="group-hover:stroke-white" stroke-linecap="round" stroke-linejoin="round" stroke-width="0.75" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
          </svg>
          {% elif related.icon == "cloud" %}
          <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24">
            <path stroke="url(#related-icon-gradient)" class="group-hover:stroke-white" stroke-linecap="round" stroke-linejoin="round" stroke-width="0.75" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path>
          </svg>
          {% elif related.icon == "globe" %}
          <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24">
            <path stroke="url(#related-icon-gradient)" class="group-hover:stroke-white" stroke-linecap="round" stroke-linejoin="round" stroke-width="0.75" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
          </svg>
          {% elif related.icon == "mobile" %}
          <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24">
            <path stroke="url(#related-icon-gradient)" class="group-hover:stroke-white" stroke-linecap="round" stroke-linejoin="round" stroke-width="0.75" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
          </svg>
          {% elif related.icon == "search" %}
          <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24">
            <path stroke="url(#related-icon-gradient)" class="group-hover:stroke-white" stroke-linecap="round" stroke-linejoin="round" stroke-width="0.75" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          {% else %}
          <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24">
            <path stroke="url(#related-icon-gradient)" class="group-hover:stroke-white" stroke-linecap="round" stroke-linejoin="round" stroke-width="0.75" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          {% endif %}
          {# Arrow #}
          <svg class="w-5 h-5 text-white/30 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </div>
      </a>
      {% endif %}
      {% endfor %}
    </div>

  </div>
</section>
{% endif %}

{# =====================================================
   SECTION 9: LOCATIONS — Dark navy, glass pills
   ===================================================== #}
<section class="py-12 md:py-16 px-4 sm:px-6 lg:px-8" style="background:#0a1f2b;" data-reveal>
  <div class="max-w-screen-2xl mx-auto">
    <p class="text-xs uppercase tracking-widest text-zunkiree-400 font-medium mb-4">Service Locations</p>
    <h2 class="text-2xl md:text-3xl font-semibold text-white mb-6">
      {{ service.title }} available in
    </h2>
    <div class="flex flex-wrap gap-3">
      {% for location in locations %}
      <a href="/locations/{{ location.id }}/{{ serviceId }}/" class="inline-flex items-center px-5 py-2.5 text-white/70 hover:text-white transition-colors rounded-lg" style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12);" onmouseover="this.style.borderColor='rgba(144,169,89,0.5)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.12)'">
        {{ location.name }}
        <svg class="w-4 h-4 ml-2 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

{# =====================================================
   SECTION 10: CTA + FAQ — Dark slightly lighter
   ===================================================== #}
<section class="py-12 md:py-20 px-4 sm:px-6 lg:px-8" style="background:#0f2438;">
  <div class="max-w-screen-2xl mx-auto">

    {# CTA Block #}
    <div class="mb-16" data-reveal>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight tracking-tight">
        Take the next step
      </h2>
      <p class="text-lg md:text-xl text-white/70 mb-8 max-w-2xl">
        {{ service.cta.description }}
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="{{ service.cta.primaryButton.url }}" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-zunkiree-600 hover:bg-zunkiree-700 text-white font-medium rounded-full transition-colors" data-track="cta" data-cta-id="service-bottom-primary">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z"/>
          </svg>
          {{ service.cta.primaryButton.text }}
        </a>
        <a href="{{ service.cta.secondaryButton.url }}" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 border border-white/20 hover:border-white/40 text-white font-medium rounded-full transition-colors" data-track="cta" data-cta-id="service-bottom-secondary">
          {{ service.cta.secondaryButton.text }}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>

    {# FAQ Accordion #}
    <div x-data="{ activeIndex: null, expandAll: false }">
      <div class="flex items-center justify-between mb-6 pb-4" style="border-bottom:1px solid rgba(255,255,255,0.10);">
        <h3 class="text-2xl md:text-3xl font-semibold text-white">Get to know {{ service.title }}</h3>
        <button
          @click="expandAll = !expandAll; activeIndex = expandAll ? 'all' : null"
          class="text-sm text-zunkiree-400 hover:text-zunkiree-300 transition-colors"
        >
          <span x-text="expandAll ? 'Collapse All' : 'Expand All'"></span>
        </button>
      </div>

      <div class="divide-y divide-white/10">
        {% for faq in service.faq %}
        <div class="py-5">
          <button
            @click="activeIndex = (activeIndex === {{ loop.index }} && !expandAll) ? null : {{ loop.index }}"
            class="w-full flex items-center justify-between text-left group"
          >
            <span class="text-lg font-medium text-white/90 group-hover:text-zunkiree-400 transition-colors pr-4">
              {{ faq.question }}
            </span>
            <span class="flex-shrink-0 text-white/40">
              <svg
                class="w-5 h-5 transition-transform duration-200"
                :class="{ 'rotate-45': activeIndex === {{ loop.index }} || expandAll }"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
            </span>
          </button>
          <div
            x-show="activeIndex === {{ loop.index }} || expandAll"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 -translate-y-2"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 -translate-y-2"
            class="overflow-hidden"
          >
            <p class="pt-4 text-white/60 leading-relaxed">
              {{ faq.answer }}
            </p>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>

  </div>
</section>
