---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- for page in collections.all %}
{%- if page.url and not page.data.excludeFromSitemap and not page.data.canonicalUrl %}
{%- set priority = "0.5" %}
{%- set changefreq = "monthly" %}
{%- if page.url == "/" %}
  {%- set priority = "1.0" %}
  {%- set changefreq = "weekly" %}
{%- elif "/services/" in page.url and page.url != "/services/" %}
  {%- set priority = "0.9" %}
  {%- set changefreq = "weekly" %}
{%- elif page.url == "/services/" %}
  {%- set priority = "0.9" %}
  {%- set changefreq = "weekly" %}
{%- elif "/products/" in page.url and page.url != "/products/" %}
  {%- set priority = "0.8" %}
  {%- set changefreq = "weekly" %}
{%- elif page.url == "/products/" %}
  {%- set priority = "0.8" %}
  {%- set changefreq = "weekly" %}
{%- elif "/resources/" in page.url %}
  {%- set priority = "0.7" %}
  {%- set changefreq = "monthly" %}
{%- elif page.url == "/about/" or page.url == "/contact/" %}
  {%- set priority = "0.6" %}
  {%- set changefreq = "monthly" %}
{%- elif page.url == "/careers/" or page.url == "/customers/" or page.url == "/projects/" %}
  {%- set priority = "0.6" %}
  {%- set changefreq = "monthly" %}
{%- elif page.url == "/pricing/" or page.url == "/team/" %}
  {%- set priority = "0.7" %}
  {%- set changefreq = "monthly" %}
{%- elif page.url == "/blog/" %}
  {%- set priority = "0.7" %}
  {%- set changefreq = "weekly" %}
{%- elif "/blog/" in page.url %}
  {%- set priority = "0.6" %}
  {%- set changefreq = "monthly" %}
{%- elif page.url == "/glossary/" %}
  {%- set priority = "0.6" %}
  {%- set changefreq = "monthly" %}
{%- elif "/glossary/" in page.url %}
  {%- set priority = "0.5" %}
  {%- set changefreq = "monthly" %}
{%- elif page.url == "/compare/" %}
  {%- set priority = "0.7" %}
  {%- set changefreq = "monthly" %}
{%- elif "/compare/" in page.url %}
  {%- set priority = "0.6" %}
  {%- set changefreq = "monthly" %}
{%- elif page.url == "/locations/" %}
  {%- set priority = "0.5" %}
  {%- set changefreq = "monthly" %}
{%- elif "/locations/" in page.url %}
  {%- set priority = "0.4" %}
  {%- set changefreq = "monthly" %}
{%- endif %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    <lastmod>{{ page.date | date("%Y-%m-%d") }}</lastmod>
    <changefreq>{{ changefreq }}</changefreq>
    <priority>{{ priority }}</priority>
  </url>
{%- endif %}
{%- endfor %}
</urlset>
