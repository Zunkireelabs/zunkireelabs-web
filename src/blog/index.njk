---
layout: base.njk
title: "AI & Technology Blog | Insights from Zunkiree Labs"
description: "Expert insights on AI development, RAG pipelines, machine learning, and building AI systems. Practical guides from Nepal's leading AI company."
permalink: /blog/
---

{# =====================================================
   BLOG LISTING PAGE
   ===================================================== #}

{# =====================================================
   HERO SECTION
   ===================================================== #}
<section class="pt-16 pb-12 md:pt-20 md:pb-16 bg-white">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    {# Breadcrumb #}
    <nav class="flex items-center gap-2 text-sm mb-8" aria-label="Breadcrumb">
      <a href="/" class="text-zunkiree-600 hover:underline">Home</a>
      <span class="text-warm-400">/</span>
      <span class="text-warm-600">Blog</span>
    </nav>

    <h1 class="text-4xl sm:text-5xl md:text-6xl font-normal text-gray-900 tracking-tight leading-tight mb-6">
      Insights & Guides
    </h1>
    <p class="text-lg md:text-xl text-gray-600 leading-relaxed max-w-2xl">
      Practical insights on AI development, RAG systems, and building production-grade AI infrastructure. From the team at Zunkiree Labs.
    </p>
  </div>
</section>

{# =====================================================
   BLOG POSTS GRID
   ===================================================== #}
<section class="pb-16 md:pb-24 bg-white">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">

    {% set posts = collections.blog | reverse %}

    {% if posts.length > 0 %}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for post in posts %}
      <a href="{{ post.url }}" class="group block bg-white rounded-lg overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
        {# Featured Image #}
        {% if post.data.featuredImage %}
        <div class="aspect-[16/9] overflow-hidden bg-gray-100">
          <img
            src="{{ post.data.featuredImage }}"
            alt="{{ post.data.title }}"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            loading="lazy"
          />
        </div>
        {% else %}
        <div class="aspect-[16/9] bg-gradient-to-br from-zunkiree-500 to-zunkiree-700 flex items-center justify-center">
          <svg class="w-12 h-12 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
          </svg>
        </div>
        {% endif %}

        {# Content #}
        <div class="p-6">
          {# Category + Date #}
          <div class="flex items-center gap-3 mb-3">
            {% if post.data.category %}
            <span class="text-xs font-medium text-zunkiree-600">{{ post.data.category }}</span>
            <span class="text-gray-300">·</span>
            {% endif %}
            <time class="text-sm text-gray-500" datetime="{{ post.date | date('%Y-%m-%d') }}">
              {{ post.date | date('%B %d, %Y') }}
            </time>
          </div>

          {# Title #}
          <h2 class="text-lg font-medium text-gray-900 group-hover:text-zunkiree-600 transition-colors mb-3 line-clamp-2">
            {{ post.data.title }}
          </h2>

          {# Description #}
          {% if post.data.description %}
          <p class="text-gray-600 text-sm line-clamp-2">
            {{ post.data.description }}
          </p>
          {% endif %}

          {# Read more #}
          <div class="mt-4 flex items-center gap-2 text-sm font-medium text-zunkiree-600 group-hover:gap-3 transition-all">
            Read article
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </div>
        </div>
      </a>
      {% endfor %}
    </div>

    {% else %}
    {# Empty state #}
    <div class="text-center py-16">
      <svg class="w-16 h-16 text-gray-300 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
      </svg>
      <h2 class="text-xl font-medium text-gray-900 mb-2">Coming soon</h2>
      <p class="text-gray-600 mb-8">We're working on our first articles. Check back soon.</p>
      <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-zunkiree-600 text-white font-medium hover:bg-zunkiree-700 transition-colors">
        Back to Home
      </a>
    </div>
    {% endif %}

  </div>
</section>

{# =====================================================
   CTA SECTION
   ===================================================== #}
<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl font-normal text-gray-900 mb-4">
      Want to build with AI?
    </h2>
    <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
      Let's discuss how AI can transform your business operations.
    </p>
    <a href="/contact/" class="inline-flex items-center justify-center px-8 py-4 bg-zunkiree-600 text-white font-medium hover:bg-zunkiree-700 transition-colors">
      Schedule a Discovery Call
    </a>
  </div>
</section>
