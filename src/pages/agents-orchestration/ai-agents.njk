  <style>
    .hw-section { padding: 52px 0 64px; }
    @keyframes hw-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
    @keyframes hw-pulse { 0%{transform:scale(1);opacity:0.8} 100%{transform:scale(2.8);opacity:0} }
    @keyframes hw-blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
    @media(max-width:1024px){
      .hw-story-inner{grid-template-columns:1fr!important;}
      .hw-story-inner > div:first-child{border-right:none!important;border-bottom:1px solid #F3F4F6;}
    }
    @media(max-width:768px){
      .hw-section{padding:40px 0 52px;}
      [style*="grid-template-columns:1fr 1fr"]{grid-template-columns:1fr!important;}
      [style*="max-width:1200px"]{padding-left:20px!important;padding-right:20px!important;}
      /* headline grid: collapse and hide robot illustration column */
      [style*="grid-template-columns:1fr 1fr"][style*="gap:48px"] > div:last-child{display:none!important;}
      [style*="grid-template-columns:1fr 1fr"][style*="gap:48px"]{gap:0!important;margin-bottom:32px!important;}
    }
    @media(max-width:640px){
      /* process timeline: keep 5 cols, just compact the items */
      [style*="grid-template-columns:repeat(5,1fr)"]{grid-template-columns:repeat(5,1fr)!important;gap:6px 0!important;}
      [style*="grid-template-columns:repeat(5,1fr)"] button{gap:3px!important;padding:0 1px!important;}
      [style*="grid-template-columns:repeat(5,1fr)"] button [style*="width:42px"]{width:30px!important;height:30px!important;}
      [style*="grid-template-columns:repeat(5,1fr)"] button [style*="width:42px"] svg{width:13px!important;height:13px!important;}
      [style*="grid-template-columns:repeat(5,1fr)"] button p[style*="font-size:13px"]{font-size:11px!important;}
      [style*="grid-template-columns:repeat(5,1fr)"] button p[style*="font-size:10px"]{font-size:9px!important;}
      [style*="grid-template-columns:repeat(5,1fr)"] button p[style*="font-size:11px"]{display:none!important;}
      /* story card stacks already at 1024px via .hw-story-inner */
      .hw-story-inner > div:first-child{padding:24px 18px!important;}
      /* insight card text and stage description */
      .hw-section [style*="font-size:12px"]{font-size:16px!important;}
      .hw-section [style*="font-size:14px;color:#6B7280"]{font-size:16px!important;}
      .hw-section [style*="font-size:10px;text-transform:uppercase"]{font-size:12px!important;}
    }
    @media(prefers-reduced-motion:reduce){
      .hw-section *{animation:none!important;}
    }
  </style>

