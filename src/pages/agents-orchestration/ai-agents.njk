{# Collapse + scroll-reveal styles for the framework wrapper #}
<style>
  .fw-wrap {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      max-height 1.2s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.6s ease 0.2s;
  }
  .fw-wrap.is-revealed {
    max-height: 9000px;
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .fw-wrap { max-height: none !important; opacity: 1 !important; transition: none !important; }
  }
</style>

<script>
  (function () {
    var solvedSection = document.querySelector('.sl-section');
    var wrap = document.getElementById('fw-wrap');
    if (!solvedSection || !wrap) return;

    var revealed = false;
    function checkScroll() {
      if (revealed) return;
      var rect = solvedSection.getBoundingClientRect();
      // Reveal as soon as the user is scrolling past the section — fires when
      // the section's bottom edge has scrolled up to 75% of viewport.
      if (rect.bottom < window.innerHeight * 0.75) {
        wrap.style.maxHeight = '12000px';
        wrap.style.opacity = '1';
        wrap.classList.add('is-revealed');
        revealed = true;
        window.removeEventListener('scroll', checkScroll);
      }
    }
    window.addEventListener('scroll', checkScroll, { passive: true });
    checkScroll();
  })();
</script>

