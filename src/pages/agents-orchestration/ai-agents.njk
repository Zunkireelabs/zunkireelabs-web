    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
      <div data-reveal>
        <p class="text-xs uppercase tracking-widest text-zunkiree-600 font-medium mb-4">FAQ</p>
        <h2 class="text-3xl md:text-4xl font-normal text-gray-900 tracking-tight mb-6">Common questions about AI agents</h2>
        <p class="text-lg text-gray-500 mb-8">Everything enterprises need to know before deploying their first agent.</p>
        <a href="/contact/" class="inline-flex items-center gap-2 text-zunkiree-600 font-medium hover:gap-3 transition-all duration-200 text-sm">
          Have more questions? Talk to us
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
      <div x-data="{ activeIndex: 0, expandAll: false }">
        <div class="flex items-center justify-end mb-4">
          <button @click="expandAll = !expandAll; activeIndex = expandAll ? 'all' : 0" class="text-sm text-gray-400 hover:text-gray-900 transition-colors">
            <span x-text="expandAll ? 'Collapse All' : 'Expand All'"></span>
          </button>
        </div>
        <div class="divide-y divide-gray-200">
          {% for item in faqs %}
          <div class="py-5" data-reveal>
            <button @click="activeIndex = (activeIndex === {{ loop.index }} && !expandAll) ? null : {{ loop.index }}" class="w-full flex items-center justify-between text-left group">
              <span class="text-base font-medium text-gray-900 group-hover:text-zunkiree-600 transition-colors pr-4">{{ item.question }}</span>
              <span class="flex-shrink-0 text-gray-400">
                <svg class="w-5 h-5 transition-transform duration-200" :class="{ 'rotate-45': activeIndex === {{ loop.index }} || expandAll }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
              </span>
            </button>
            <div x-show="activeIndex === {{ loop.index }} || expandAll" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-y-2" x-transition:enter-end="opacity-100 translate-y-0" class="overflow-hidden">
              <p class="pt-4 text-gray-500 leading-relaxed text-sm">{{ item.answer }}</p>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

