<section style="background:#faf9f7;font-family:'DM Sans',system-ui,sans-serif;">
  <div style="max-width:1200px;margin:0 auto;padding:52px clamp(20px,4vw,48px);" x-data="{ activeIndex: null, expandAll: false }">

    {# Header row #}
    <div class="faq-hdr" style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:0;">
      <h2 style="font-size:clamp(22px,2.4vw,32px);font-weight:600;color:#111827;letter-spacing:-0.02em;margin:0;">Frequently asked questions</h2>
      <button @click="expandAll=!expandAll; if(!expandAll) activeIndex=null"
              style="font-size:13px;color:#6366f1;background:none;border:none;cursor:pointer;padding:0;font-family:inherit;font-weight:500;white-space:nowrap;"
              onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">
        <span x-text="expandAll ? 'Collapse All' : 'Expand All'">Expand All</span>
      </button>
    </div>

    <div style="border-top:1px solid #e5e7eb;margin-top:28px;">
      {% for faq in faqs %}
      <div style="border-bottom:1px solid #e5e7eb;">
        <button @click="activeIndex = activeIndex === {{ loop.index }} ? null : {{ loop.index }}"
                style="width:100%;display:flex;align-items:center;justify-content:space-between;text-align:left;background:none;border:none;cursor:pointer;padding:22px 0;gap:24px;font-family:inherit;">
          <span style="font-size:16px;font-weight:500;color:#111827;line-height:1.4;">{{ faq.question }}</span>
          <svg width="20" height="20" fill="none" stroke="#9ca3af" stroke-width="1.8"
               stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"
               style="flex-shrink:0;transition:transform 0.2s ease;"
               :style="(expandAll || activeIndex === {{ loop.index }}) ? 'transform:rotate(45deg)' : 'transform:rotate(0deg)'">
            <path d="M12 4v16m8-8H4"/>
          </svg>
        </button>
        <div x-show="expandAll || activeIndex === {{ loop.index }}" x-collapse>
          <p style="margin:0 0 22px;font-size:15px;color:#6b7280;line-height:1.75;max-width:780px;">{{ faq.answer }}</p>
        </div>
      </div>
      {% endfor %}
    </div>

  </div>
</section>





