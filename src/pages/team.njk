        </div>
      </div>
    </div>
  </div>
</section>

{# =====================================================
   JOIN THE TEAM CTA
   ===================================================== #}
<section class="py-16 md:py-24 bg-gradient-to-br from-zunkiree-600 to-zunkiree-800 text-white">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl font-normal mb-4">
      Join our team
    </h2>
    <p class="text-lg text-white/80 mb-8 max-w-2xl mx-auto">
      We're always looking for talented engineers who want to build world-class AI products from Nepal.
    </p>
    <a href="/careers/" class="inline-flex items-center justify-center px-8 py-4 bg-white text-zunkiree-700 font-medium hover:bg-gray-100 transition-colors">
      View Open Positions
    </a>
  </div>
</section>
