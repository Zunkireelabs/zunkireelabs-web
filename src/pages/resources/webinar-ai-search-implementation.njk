            <img src="{{ resource.coverImage }}" alt="{{ resource.title }}" class="w-full h-full object-cover" />
          {% else %}
            <div class="w-full h-full bg-gradient-to-br from-gray-900 to-gray-800 flex items-center justify-center">
              <span class="text-white/30 text-4xl font-bold">{{ resource.type }}</span>
            </div>
          {% endif %}
