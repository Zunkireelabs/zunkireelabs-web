{% set resource = resources.items | find("slug", "khushbu-nirman-case-study") %}

{# HERO SECTION #}
<section class="bg-white pt-28 md:pt-36 pb-8 md:pb-12 px-4 md:px-6">
  <div class="max-w-screen-2xl mx-auto">
    <div class="mb-8">
      <span class="inline-block px-3 py-1 bg-orange-600 text-white text-xs font-medium tracking-wide mb-4">
        Case Study
      </span>
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-[56px] font-medium text-warm-black tracking-[-0.03em] leading-[1.1] mb-5" data-reveal>
        {{ resource.title }}
      </h1>
      <p class="text-lg md:text-xl text-warm-600 leading-relaxed tracking-[-0.01em] mb-4" data-reveal>
        {{ resource.subtitle }}
      </p>
      <div class="flex flex-wrap gap-4 text-sm text-warm-500" data-reveal>
        <span><strong>Client:</strong> {{ resource.client }}</span>
        <span><strong>Industry:</strong> {{ resource.industry }}</span>
        <span><strong>Location:</strong> {{ resource.location }}</span>
      </div>
    </div>

    {# Results Bar #}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 py-8 border-y border-gray-200 mb-8" data-reveal>
      {% for result in resource.results %}
      <div class="text-center md:text-left">
        <p class="text-2xl md:text-3xl font-medium text-zunkiree-600 mb-1">{{ result | replace('NPR ', '₨') }}</p>
      </div>
      {% endfor %}
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
      <div class="lg:col-span-7" data-reveal>
        <div class="aspect-[16/9] overflow-hidden bg-gray-100">
          {% if resource.coverImage %}
            <img src="{{ resource.coverImage }}" alt="{{ resource.title }}" class="w-full h-full object-cover" />
          {% else %}
            <div class="w-full h-full bg-gradient-to-br from-orange-500 to-orange-700 flex items-center justify-center">
              <span class="text-white/30 text-4xl font-bold">{{ resource.type }}</span>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="lg:col-span-5" data-reveal>
        <h3 class="text-sm font-semibold text-warm-black tracking-wide mb-6">Related Resources</h3>
        <div class="space-y-6">
          <a href="/resources/state-of-ai-nepal-2026/" class="block group">
            <p class="text-base text-zunkiree-600 group-hover:text-zunkiree-700 leading-snug mb-2">
              State of AI in Nepal 2026
            </p>
            <span class="inline-flex items-center text-warm-black">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </span>
          </a>
          <hr class="border-warm-200">
          <a href="/resources/ai-implementation-guide-nepal/" class="block group">
            <p class="text-base text-zunkiree-600 group-hover:text-zunkiree-700 leading-snug mb-2">
              AI Implementation Guide for Nepal SMEs
            </p>
            <span class="inline-flex items-center text-warm-black">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </span>
          </a>
          <hr class="border-warm-200">
          <a href="/resources/admizz-case-study/" class="block group">
            <p class="text-base text-zunkiree-600 group-hover:text-zunkiree-700 leading-snug mb-2">
              Case Study: Admizz Education
            </p>
            <span class="inline-flex items-center text-warm-black">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

{# CONTENT SECTION #}
<section class="relative bg-white px-4 md:px-6 py-12 md:py-16 lg:py-20">
  <div class="max-w-screen-2xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">

      <div class="lg:col-span-7">
        <div class="mb-10" data-reveal>
          <h2 class="text-2xl font-medium text-warm-black mb-4">About Khushbu Nirman Sewa</h2>
          <p class="text-warm-600 text-base md:text-lg leading-relaxed">
            <strong>Khushbu Nirman Sewa</strong> is a leading construction company based in Kathmandu, Nepal. With over 15 active construction sites across Kathmandu Valley, they manage residential buildings, commercial complexes, and infrastructure projects. Founded in 2015, the company has grown to 200+ employees and is known for delivering quality construction on schedule.
          </p>
        </div>

        <div class="mb-10" data-reveal>
          <h2 class="text-2xl font-medium text-warm-black mb-4">The challenge</h2>
          <p class="text-warm-600 text-base md:text-lg leading-relaxed mb-6">
            {{ resource.challenge }}
          </p>
          <div class="p-6 bg-red-50 border-l-4 border-red-500">
            <p class="text-warm-600">
              <strong>Key pain points:</strong>
            </p>
            <ul class="mt-2 space-y-2 text-warm-600">
              <li>• Site supervisors used paper forms, causing 2-3 day delays in reporting</li>
              <li>• No visibility into resource utilization across sites</li>
              <li>• Material wastage averaged 15% due to poor tracking</li>
              <li>• Project delays were common, averaging 20% over schedule</li>
            </ul>
          </div>
        </div>

        <div class="mb-10" data-reveal>
          <h2 class="text-2xl font-medium text-warm-black mb-4">The solution</h2>
          <p class="text-warm-600 text-base md:text-lg leading-relaxed mb-6">
            {{ resource.solution }}
          </p>
          <div class="space-y-4">
            <div class="p-4 bg-gray-50">
              <p class="font-medium text-warm-black mb-1">Mobile data collection</p>
              <p class="text-warm-600 text-sm">Site supervisors use a mobile app to log daily progress, issues, and resource usage in real-time.</p>
            </div>
            <div class="p-4 bg-gray-50">
              <p class="font-medium text-warm-black mb-1">AI-powered resource optimization</p>
              <p class="text-warm-600 text-sm">Machine learning algorithms predict resource needs and suggest optimal allocation across sites.</p>
            </div>
            <div class="p-4 bg-gray-50">
              <p class="font-medium text-warm-black mb-1">Predictive delay alerts</p>
              <p class="text-warm-600 text-sm">AI analyzes patterns to predict potential delays 2-3 weeks in advance, allowing proactive intervention.</p>
            </div>
            <div class="p-4 bg-gray-50">
              <p class="font-medium text-warm-black mb-1">Centralized dashboard</p>
              <p class="text-warm-600 text-sm">Management has real-time visibility into all 15+ sites from a single dashboard.</p>
            </div>
          </div>
        </div>

        <div class="mb-10" data-reveal>
          <h2 class="text-2xl font-medium text-warm-black mb-4">The results</h2>
          <div class="grid grid-cols-2 gap-6">
            {% for result in resource.results %}
            <div class="p-6 bg-green-50 border-l-4 border-green-500">
              <p class="text-xl font-medium text-warm-black">{{ result }}</p>
            </div>
            {% endfor %}
          </div>
        </div>

        <div class="mb-10" data-reveal>
          <h2 class="text-2xl font-medium text-warm-black mb-4">Key takeaways</h2>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <span class="text-zunkiree-600 mt-1 font-bold">1.</span>
              <p class="text-warm-600"><strong>Start with data collection:</strong> The foundation of AI is good data. Mobile apps for field workers were the critical first step.</p>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-zunkiree-600 mt-1 font-bold">2.</span>
              <p class="text-warm-600"><strong>Predictive > reactive:</strong> AI's real value is predicting problems before they occur, not just reporting on what happened.</p>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-zunkiree-600 mt-1 font-bold">3.</span>
              <p class="text-warm-600"><strong>ROI is measurable:</strong> NPR 2.5 crore saved in the first year made the business case clear for expansion.</p>
            </div>
          </div>
        </div>

        {# Quote #}
        <div class="mb-10 p-8 bg-gray-50" data-reveal>
          <blockquote class="text-xl text-warm-black italic mb-4">
            "We went from managing construction sites with phone calls and paper to having real-time visibility across everything. The AI predictions have changed how we plan projects."
          </blockquote>
          <p class="text-warm-600">
            <strong>Ram Prasad Shrestha</strong><br>
            Managing Director, Khushbu Nirman Sewa
          </p>
        </div>
      </div>

      <div class="lg:col-span-5" data-reveal>
        <div class="lg:sticky lg:top-24">
          {% set formTitle = resource.formTitle %}
          {% set ctaText = resource.ctaText %}
          {% include "components/lead-capture-form.njk" %}
        </div>
      </div>

    </div>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ resource.title }}",
  "description": "{{ resource.description }}",
  "datePublished": "{{ resource.publishDate }}",
  "author": {
    "@type": "Organization",
    "name": "Zunkiree Labs"
  },
  "about": {
    "@type": "Organization",
    "name": "Khushbu Nirman Sewa",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Kathmandu",
      "addressCountry": "Nepal"
    }
  }
}
</script>
