{# =====================================================
   SECTION 8: CTA + FAQ
   ===================================================== #}
<section class="py-12 md:py-20 bg-white">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16" x-data="{ ctaHeight: null }" x-init="$nextTick(() => { ctaHeight = $refs.faqSection.offsetHeight })">

      {# Left Side - CTA Box #}
      <div
        class="relative p-10 md:p-14 lg:p-16 flex flex-col justify-center overflow-hidden"
        :style="ctaHeight ? 'height: ' + ctaHeight + 'px' : ''"
        data-reveal
      >
        {# Background Image #}
        <img
          src="/assets/images/cta-background.svg"
          alt=""
          class="absolute inset-0 w-full h-full object-cover"
          aria-hidden="true"
        />
        {# Content overlay #}
        <div class="relative z-10">
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-normal text-gray-900 mb-8 leading-tight">
            Ready to build<br>something great?
          </h2>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact/" class="inline-flex items-center justify-center px-7 py-3.5 bg-zunkiree-600 text-white font-medium hover:bg-zunkiree-700 transition-colors">
              Contact Us
            </a>
            <a href="/products/" class="inline-flex items-center justify-center px-7 py-3.5 border border-gray-900 text-gray-900 font-medium hover:bg-gray-900 hover:text-white transition-colors">
              See Our Products
            </a>
          </div>
        </div>
      </div>

      {# Right Side - FAQ Accordion #}
      <div x-ref="faqSection">
      <div x-data="{ activeIndex: null, expandAll: false }">
        {# Header #}
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-2xl md:text-3xl font-medium text-gray-900">About Zunkiree Labs</h3>
          <button
            @click="expandAll = !expandAll; activeIndex = expandAll ? 'all' : null"
            class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
          >
            <span x-text="expandAll ? 'Collapse All' : 'Expand All'"></span>
          </button>
        </div>

        {# FAQ Items #}
        <div class="divide-y divide-gray-200">
          {% for item in aboutFaq %}
          <div class="py-5">
            <button
              @click="activeIndex = (activeIndex === {{ loop.index }} && !expandAll) ? null : {{ loop.index }}"
              class="w-full flex items-center justify-between text-left group"
            >
              <span class="text-lg font-medium text-gray-900 group-hover:text-zunkiree-600 transition-colors pr-4">
                {{ item.question }}
              </span>
              <span class="flex-shrink-0 text-gray-400">
                <svg
                  class="w-5 h-5 transition-transform duration-200"
                  :class="{ 'rotate-45': activeIndex === {{ loop.index }} || expandAll }"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
              </span>
            </button>
            <div
              x-show="activeIndex === {{ loop.index }} || expandAll"
              x-transition:enter="transition ease-out duration-200"
              x-transition:enter-start="opacity-0 -translate-y-2"
              x-transition:enter-end="opacity-100 translate-y-0"
              x-transition:leave="transition ease-in duration-150"
              x-transition:leave-start="opacity-100 translate-y-0"
              x-transition:leave-end="opacity-0 -translate-y-2"
              class="overflow-hidden"
            >
              <p class="pt-4 text-gray-600 leading-relaxed">
                {{ item.answer }}
              </p>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
      </div>

    </div>
  </div>
</section>

{# =====================================================
   SCHEMA MARKUP (JSON-LD) - Organization
   ===================================================== #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Zunkiree Labs",
  "url": "https://zunkiree.com",
  "logo": "https://zunkiree.com/assets/images/zunkiree-logo.png",
  "description": "Zunkiree Labs is a product-first AI and software engineering company from Kathmandu, Nepal. We build intelligent platforms like Zunkiree Search and Gaamma ERP.",
  "foundingDate": "2018",
  "foundingLocation": {
    "@type": "Place",
    "name": "Kathmandu, Nepal"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Kathmandu",
    "addressCountry": "Nepal"
  },
  "sameAs": [],
  "knowsAbout": [
    "Artificial Intelligence",
    "Machine Learning",
    "Data Engineering",
    "Custom Software Development",
    "AI Integration",
    "Platform Engineering"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Products & Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "SoftwareApplication",
          "name": "Zunkiree Search",
          "description": "AI-native search and interaction platform"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "SoftwareApplication",
          "name": "Gaamma",
          "description": "Enterprise resource planning platform for manufacturing"
        }
      }
    ]
  }
}
</script>

{# FAQPage Schema #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in aboutFaq %}
    {
      "@type": "Question",
      "name": "{{ item.question }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ item.answer }}"
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
