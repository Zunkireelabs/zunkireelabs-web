---
layout: base.njk
title: "Saved Plan | Zunkiree Labs"
description: "View your saved EMI plan — product, bank, tenure, and monthly payment at a glance."
permalink: /plan/
---

<section class="min-h-screen bg-gray-50 py-12 px-4">
  <div class="max-w-lg mx-auto" x-data="planPage()" x-init="init()">

    {# Loading #}
    <div x-show="loading" class="flex flex-col items-center justify-center py-24 gap-4">
      <div class="w-10 h-10 border-2 border-zunkiree-600 border-t-transparent rounded-full animate-spin"></div>
      <p class="text-sm text-gray-500">Loading plan...</p>
    </div>

    {# Not found #}
    <div x-show="!loading && error" class="text-center py-24">
      <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <h1 class="text-xl font-medium text-gray-900 mb-2">Plan not found</h1>
      <p class="text-gray-500 text-sm mb-6" x-text="error"></p>
      <a href="/agents-orchestration/ai-agents/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-zunkiree-600 text-white text-sm font-medium hover:bg-zunkiree-700 transition-colors rounded-lg">
        Start a new plan
      </a>
    </div>

    {# Plan card #}
    <div x-show="!loading && plan" x-transition>

      {# Header #}
      <div class="text-center mb-8">
        <div class="inline-flex items-center gap-2 bg-green-50 border border-green-200 text-green-700 text-xs font-medium px-3 py-1.5 rounded-full mb-4">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          Saved Plan
        </div>
        <h1 class="text-2xl font-medium text-gray-900" x-text="plan.product_name"></h1>
        <p class="text-gray-500 text-sm mt-1">Plan ID: <span class="font-mono font-medium" x-text="plan.short_id"></span></p>
      </div>

      {# Main summary card #}
      <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm mb-4">

        {# Price row #}
        <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
          <span class="text-sm text-gray-500">Product Price</span>
          <span class="text-lg font-semibold text-gray-900" x-text="fmt(plan.product_price)"></span>
        </div>

        {# Down payment #}
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
          <div>
            <span class="text-sm text-gray-500">Down Payment</span>
            <span class="ml-2 text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full" x-text="plan.down_payment_pct + '%'"></span>
          </div>
          <span class="text-sm font-medium text-gray-900" x-text="fmt(Math.round(plan.product_price * plan.down_payment_pct / 100))"></span>
        </div>

        {# Loan amount #}
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 bg-gray-50">
          <span class="text-sm text-gray-500">Loan Amount</span>
          <span class="text-sm font-medium text-gray-900" x-text="fmt(plan.product_price - Math.round(plan.product_price * plan.down_payment_pct / 100))"></span>
        </div>

        {# Bank #}
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
          <span class="text-sm text-gray-500">Bank</span>
          <span class="text-sm font-medium text-gray-900" x-text="plan.bank_name"></span>
        </div>

        {# Tenure #}
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
          <span class="text-sm text-gray-500">Tenure</span>
          <span class="text-sm font-medium text-gray-900" x-text="plan.tenure_months + ' months'"></span>
        </div>

        {# Monthly EMI — highlighted #}
        <div class="flex items-center justify-between px-6 py-5 bg-zunkiree-600 text-white">
          <span class="text-sm font-medium opacity-80">Monthly EMI</span>
          <span class="text-2xl font-bold" x-text="fmt(plan.emi_amount)"></span>
        </div>
      </div>

      {# Affordability status #}
      <div
        class="rounded-xl px-5 py-4 mb-6 flex items-center gap-3"
        :class="affordabilityClass"
      >
        <svg class="w-5 h-5 flex-shrink-0" :class="affordabilityIconClass" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="text-sm" x-text="affordabilityText"></p>
      </div>

      {# Festival discount banner #}
      <div
        x-show="festivalInfo"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 -translate-y-1"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="rounded-xl px-5 py-4 mb-4 text-sm"
        :class="festivalInfo?.urgent
          ? 'bg-red-50 border border-red-200'
          : 'bg-amber-50 border border-amber-200'"
      >
        <div class="flex items-start gap-3">
          <span class="text-xl leading-none mt-0.5">🎉</span>
          <div class="flex-1 min-w-0">
            {# Urgent: sale may be live #}
            <p
              x-show="festivalInfo?.urgent"
              class="font-medium text-red-800"
              x-text="festivalInfo?.festival?.name + ' sale may already be live — check with your dealer before paying full price.'"
            ></p>

            {# Upcoming: days away #}
            <div x-show="!festivalInfo?.urgent">
              <p class="font-medium text-amber-900">
                <span x-text="festivalInfo?.festival?.name"></span> is
                <span x-text="festivalInfo?.days"></span> days away —
                expect <span x-text="festivalInfo?.festival?.discount_min_pct + '–' + festivalInfo?.festival?.discount_max_pct + '%'"></span>
                discount on <span x-text="festivalInfo?.cats"></span>.
              </p>
              <div class="flex items-center justify-between mt-2 pt-2 border-t border-amber-200 flex-wrap gap-2">
                <span class="text-amber-800">
                  Estimated saving on this plan:
                  <strong>Rs. <span x-text="festivalInfo?.savingMin?.toLocaleString('en-IN')"></span> – Rs. <span x-text="festivalInfo?.savingMax?.toLocaleString('en-IN')"></span></strong>
                </span>
                <button
                  @click="alertsExpanded = true; $nextTick(() => document.querySelector('[x-data]').querySelector('input[type=tel]')?.focus())"
                  class="text-xs font-medium text-amber-700 underline underline-offset-2 whitespace-nowrap"
                >Set a reminder →</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      {# Status badge + created #}
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-2">
          <span class="text-xs text-gray-500">Status:</span>
          <span
            class="text-xs font-medium px-2.5 py-1 rounded-full capitalize"
            :class="{
              'bg-blue-50 text-blue-700': plan.status === 'saved',
              'bg-purple-50 text-purple-700': plan.status === 'shared',
              'bg-green-50 text-green-700': plan.status === 'approved'
            }"
            x-text="plan.status"
          ></span>
        </div>
        <p class="text-xs text-gray-400" x-text="'Saved ' + formatDate(plan.created_at)"></p>
      </div>

      {# Actions #}
      <div class="flex gap-3 mb-3">
        <button
          @click="copyLink()"
          class="flex-1 flex items-center justify-center gap-2 px-4 py-3 border border-gray-200 text-sm font-medium text-gray-700 rounded-xl hover:bg-gray-50 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
          <span x-text="copied ? 'Copied!' : 'Copy Link'"></span>
        </button>
        <a
          href="/agents-orchestration/ai-agents/"
          class="flex-1 flex items-center justify-center gap-2 px-4 py-3 bg-zunkiree-600 text-white text-sm font-medium rounded-xl hover:bg-zunkiree-700 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          New Plan
        </a>
      </div>

      {# WhatsApp share #}
      <a
        :href="whatsappUrl"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 w-full px-4 py-3 bg-[#25D366] text-white text-sm font-medium rounded-xl hover:bg-[#1ebe5c] transition-colors mb-4"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.126.553 4.126 1.52 5.867L.058 23.486a.5.5 0 00.609.637l5.78-1.476A11.956 11.956 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.83 9.83 0 01-5.01-1.37l-.36-.214-3.427.876.907-3.305-.235-.38A9.818 9.818 0 012.182 12C2.182 6.58 6.58 2.182 12 2.182S21.818 6.58 21.818 12 17.42 21.818 12 21.818z"/>
        </svg>
        Share on WhatsApp
      </a>

      {# Approve section — shown to family members viewing the shared link #}
      <div
        x-show="plan.status !== 'approved' && !approvalDone"
        class="border-t border-gray-100 pt-4"
      >
        <p class="text-xs text-gray-500 text-center mb-3">Reviewing this plan as a family member?</p>

        <div x-show="!approveForm" class="text-center">
          <button
            @click="approveForm = true"
            class="inline-flex items-center gap-2 px-5 py-2.5 border-2 border-green-500 text-green-700 text-sm font-medium rounded-xl hover:bg-green-50 transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Approve this plan
          </button>
        </div>

        <div x-show="approveForm" class="space-y-3">
          <input
            x-model="approverName"
            type="text"
            placeholder="Your name (e.g. Dad, Mom)"
            class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-green-400 focus:ring-2 focus:ring-green-100 transition-colors"
          />
          <p x-show="approveError" class="text-xs text-red-500" x-text="approveError"></p>
          <div class="flex gap-2">
            <button
              @click="approveForm = false; approverName = ''"
              class="flex-1 py-2.5 border border-gray-200 text-sm text-gray-600 rounded-xl hover:bg-gray-50 transition-colors"
            >Cancel</button>
            <button
              @click="approvePlan()"
              :disabled="approving || !approverName.trim()"
              class="flex-1 py-2.5 bg-green-600 text-white text-sm font-medium rounded-xl hover:bg-green-700 disabled:opacity-40 disabled:cursor-not-allowed transition-colors flex items-center justify-center gap-2"
            >
              <svg x-show="approving" class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
              <span x-text="approving ? 'Sending...' : 'Confirm Approval'"></span>
            </button>
          </div>
        </div>
      </div>

      {# Already approved badge #}
      <div
        x-show="plan.status === 'approved' || approvalDone"
        class="border-t border-gray-100 pt-4"
      >
        <div class="flex items-center justify-center gap-2 text-green-700 bg-green-50 border border-green-200 rounded-xl px-4 py-3">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-sm font-medium" x-text="approvalDone ? 'You approved this plan!' : 'This plan has been approved'"></span>
        </div>
      </div>

      {# ── Price Alert section ── #}
      <div class="border-t border-gray-100 pt-4 mt-4">
        <button
          @click="alertsExpanded = !alertsExpanded"
          class="w-full flex items-center justify-between text-left"
        >
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 bg-zunkiree-50 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-3.5 h-3.5 text-zunkiree-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-900">Price Alerts</p>
              <p class="text-xs text-gray-400" x-text="alertTypes.length ? alertTypes.length + ' alert(s) active' : 'Get notified on price drops &amp; more'"></p>
            </div>
          </div>
          <svg
            class="w-4 h-4 text-gray-400 transition-transform"
            :class="alertsExpanded ? 'rotate-180' : ''"
            fill="none" stroke="currentColor" viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>

        <div
          x-show="alertsExpanded"
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 -translate-y-2"
          x-transition:enter-end="opacity-100 translate-y-0"
          class="mt-4 space-y-4"
        >
          {# Phone number #}
          <div>
            <label class="block text-xs font-medium text-gray-700 mb-1.5">
              WhatsApp / SMS number
            </label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm text-gray-400">+977</span>
              <input
                x-model="alertPhone"
                type="tel"
                placeholder="98XXXXXXXX"
                class="w-full pl-14 pr-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-zunkiree-400 focus:ring-2 focus:ring-zunkiree-100 transition-colors"
              />
            </div>
          </div>

          {# Alert type toggles #}
          <div class="space-y-2">
            <template x-for="opt in [
              { type: 'price_drop',   label: 'Price Drop',            desc: 'Notify when price falls ≥2%' },
              { type: 'festive',      label: 'Festive Discount',      desc: 'Reminder 30 days before major festivals' },
              { type: 'rate_change',  label: 'Bank Rate Drop',        desc: 'Alert when your bank lowers its rate' }
            ]" :key="opt.type">
              <label class="flex items-center justify-between bg-gray-50 rounded-xl px-4 py-3 cursor-pointer hover:bg-gray-100 transition-colors">
                <div>
                  <p class="text-sm font-medium text-gray-900" x-text="opt.label"></p>
                  <p class="text-xs text-gray-500" x-text="opt.desc"></p>
                </div>
                <div class="relative flex-shrink-0 ml-4">
                  <input type="checkbox" class="sr-only" :value="opt.type" x-model="alertTypes" />
                  <div
                    class="w-10 h-6 rounded-full transition-colors"
                    :class="alertTypes.includes(opt.type) ? 'bg-zunkiree-600' : 'bg-gray-200'"
                  ></div>
                  <div
                    class="absolute top-1 left-1 w-4 h-4 bg-white rounded-full shadow transition-transform"
                    :class="alertTypes.includes(opt.type) ? 'translate-x-4' : 'translate-x-0'"
                  ></div>
                </div>
              </label>
            </template>
          </div>

          <p x-show="alertsError" class="text-xs text-red-500" x-text="alertsError"></p>

          <button
            @click="saveAlerts()"
            :disabled="alertsSaving || alertTypes.length === 0"
            class="w-full py-2.5 bg-zunkiree-600 text-white text-sm font-medium rounded-xl hover:bg-zunkiree-700 disabled:opacity-40 disabled:cursor-not-allowed transition-colors flex items-center justify-center gap-2"
          >
            <svg x-show="alertsSaving" class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <svg x-show="alertsSaved && !alertsSaving" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span x-text="alertsSaved ? 'Alerts saved!' : alertsSaving ? 'Saving...' : 'Save Alert Preferences'"></span>
          </button>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
const FESTIVALS = {{ festival_discounts | dump | safe }};

function daysUntilDate(dateStr) {
  const today = new Date(); today.setHours(0, 0, 0, 0);
  return Math.ceil((new Date(dateStr) - today) / 86400000);
}

function nearestFestivalForPlan(category, windowDays = 45) {
  const cat = category || 'all';
  return FESTIVALS
    .filter(f => {
      const d = daysUntilDate(f.date);
      return d >= 0 && d <= windowDays &&
        (f.applies_to.includes('all') || f.applies_to.includes(cat));
    })
    .sort((a, b) => daysUntilDate(a.date) - daysUntilDate(b.date))[0] || null;
}

function planPage() {
  return {
    plan: null,
    loading: true,
    error: null,
    copied: false,

    // Approve state
    approveForm: false,
    approverName: '',
    approving: false,
    approveError: '',
    approvalDone: false,

    // Festival banner
    festivalInfo: null,

    // Alert state
    alertsExpanded: false,
    alertPhone: '',
    alertTypes: [],
    existingAlerts: [],
    alertsSaving: false,
    alertsSaved: false,
    alertsError: '',

    async init() {
      // Accept ?id=… (preferred, works without server rewrites)
      // or trailing-slug /plan/<id> (Vercel rewrites this to /plan/?short_id=…)
      const qs = new URLSearchParams(window.location.search);
      let shortId = qs.get('id') || qs.get('short_id');
      if (!shortId) {
        const parts = window.location.pathname.replace(/\/$/, '').split('/');
        const last = parts[parts.length - 1];
        if (last && last !== 'plan') shortId = last;
      }

      if (!shortId) {
        this.error = 'No plan ID in URL.';
        this.loading = false;
        return;
      }

      const loadFromLocalStorage = () => {
        try {
          const raw = localStorage.getItem(`emi_plan_${shortId}`);
          if (!raw) return null;
          const payload = JSON.parse(raw);
          // Adapt the locally-saved payload to the get-plan API shape so the existing template just works
          return {
            short_id: shortId,
            product_name: payload.product_name,
            product_price: payload.product_price,
            product_category: payload.product_category,
            down_payment_pct: payload.down_payment_pct,
            bank_name: payload.bank_name,
            bank_interest_rate: payload.bank_interest_rate,
            tenure_months: payload.tenure_months,
            monthly_income: payload.monthly_income,
            emi_amount: payload.emi_amount,
            status: 'saved',
            created_at: payload.saved_at || new Date().toISOString(),
            local: true
          };
        } catch (_) { return null; }
      };

      try {
        const res = await fetch(`/api/get-plan?id=${shortId}`);
        const text = await res.text();
        // Empty body / non-JSON / 404 → API unreachable → try localStorage
        if (!text || !res.ok) {
          const local = loadFromLocalStorage();
          if (local) { this.plan = local; }
          else { this.error = 'Plan not found'; this.loading = false; return; }
        } else {
          try { this.plan = JSON.parse(text); }
          catch {
            const local = loadFromLocalStorage();
            if (local) { this.plan = local; }
            else { this.error = 'Plan not found'; this.loading = false; return; }
          }
        }
        if (this.plan && !this.plan.local) {
          this.loadAlerts(this.plan.short_id);
        }
        this.festivalInfo = this._computeFestivalInfo(this.plan);
      } catch (e) {
        // Network/fetch failure → fall back to localStorage
        const local = loadFromLocalStorage();
        if (local) { this.plan = local; this.festivalInfo = this._computeFestivalInfo(this.plan); }
        else { this.error = e.message; }
      }
      this.loading = false;
    },

    async loadAlerts(planId) {
      try {
        const res = await fetch(`/api/alerts?plan_id=${planId}`);
        if (!res.ok) return;
        const text = await res.text();
        if (!text) return;
        try { this.existingAlerts = JSON.parse(text); } catch { return; }
        this.alertTypes = this.existingAlerts.filter(a => a.is_active).map(a => a.alert_type);
        if (this.existingAlerts.length > 0) {
          this.alertPhone = this.existingAlerts[0].phone_number;
        }
      } catch (_) {}
    },

    async saveAlerts() {
      if (!this.alertPhone.trim()) { this.alertsError = 'Enter a phone number first'; return; }
      this.alertsSaving = true;
      this.alertsError = '';
      try {
        const existing = Object.fromEntries(this.existingAlerts.map(a => [a.alert_type, a]));

        // Disable alerts that were toggled off
        for (const a of this.existingAlerts) {
          if (a.is_active && !this.alertTypes.includes(a.alert_type)) {
            await fetch('/api/alerts', {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: a.id, is_active: false })
            });
          }
        }

        // Enable/create alerts that are toggled on
        for (const type of this.alertTypes) {
          if (!existing[type] || !existing[type].is_active) {
            await fetch('/api/alerts', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                plan_id: this.plan.short_id,
                alert_type: type,
                phone_number: this.alertPhone.trim()
              })
            });
          }
        }

        await this.loadAlerts(this.plan.short_id);
        this.alertsSaved = true;
        setTimeout(() => this.alertsSaved = false, 3000);
      } catch (e) {
        this.alertsError = e.message;
      }
      this.alertsSaving = false;
    },

    _computeFestivalInfo(plan) {
      const festival = nearestFestivalForPlan(plan.product_category);
      if (!festival) return null;
      const days = daysUntilDate(festival.date);
      if (days <= 7) {
        return { urgent: true, festival, days, savingMin: 0, savingMax: 0 };
      }
      const savingMin = Math.round(plan.product_price * festival.discount_min_pct / 100);
      const savingMax = Math.round(plan.product_price * festival.discount_max_pct / 100);
      const cats = festival.applies_to.includes('all') ? 'all categories' : festival.applies_to.join(' & ');
      return { urgent: false, festival, days, savingMin, savingMax, cats };
    },

    get whatsappUrl() {
      if (!this.plan) return '#';
      const dp = Math.round(this.plan.product_price * this.plan.down_payment_pct / 100);
      const planLink = window.location.href;
      const text =
        `Hi! I found a great deal 🛒\n\n` +
        `*${this.plan.product_name}*\n` +
        `Price: Rs. ${Math.round(this.plan.product_price).toLocaleString('en-IN')}\n` +
        `Down Payment: Rs. ${dp.toLocaleString('en-IN')} (${this.plan.down_payment_pct}%)\n` +
        `Monthly EMI: Rs. ${Math.round(this.plan.emi_amount).toLocaleString('en-IN')}/month\n` +
        `Bank: ${this.plan.bank_name}\n` +
        `Tenure: ${this.plan.tenure_months} months\n\n` +
        `View full plan: ${planLink}`;
      return `https://wa.me/?text=${encodeURIComponent(text)}`;
    },

    async approvePlan() {
      this.approving = true;
      this.approveError = '';

      const approveLocally = () => {
        try {
          const key = `emi_plan_${this.plan.short_id}`;
          const raw = localStorage.getItem(key);
          const obj = raw ? JSON.parse(raw) : {};
          obj.status = 'approved';
          obj.approved_by = this.approverName.trim();
          obj.approved_at = new Date().toISOString();
          localStorage.setItem(key, JSON.stringify(obj));
        } catch (_) {}
        this.plan.status = 'approved';
        this.approvalDone = true;
        this.approveForm = false;
      };

      try {
        const res = await fetch('/api/approve-plan', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            short_id: this.plan.short_id,
            approver_name: this.approverName.trim()
          })
        });
        const text = await res.text();
        // Empty body / non-JSON / not-ok → API unreachable → approve locally
        if (!text) { approveLocally(); this.approving = false; return; }
        let data;
        try { data = JSON.parse(text); } catch { approveLocally(); this.approving = false; return; }
        if (!res.ok) throw new Error(data.error || 'Approval failed');
        this.approvalDone = true;
        this.approveForm = false;
      } catch (e) {
        if (e.name === 'TypeError') { approveLocally(); }
        else { this.approveError = e.message; }
      }
      this.approving = false;
    },

    get affordabilityClass() {
      if (!this.plan?.monthly_income) return 'bg-gray-50 border border-gray-200';
      const ratio = this.plan.emi_amount / this.plan.monthly_income;
      return ratio > 0.45
        ? 'bg-amber-50 border border-amber-200'
        : 'bg-green-50 border border-green-200';
    },

    get affordabilityIconClass() {
      if (!this.plan?.monthly_income) return 'text-gray-400';
      return this.plan.emi_amount / this.plan.monthly_income > 0.45
        ? 'text-amber-500' : 'text-green-500';
    },

    get affordabilityText() {
      if (!this.plan?.monthly_income) return 'Income not provided — affordability unknown.';
      const ratio = (this.plan.emi_amount / this.plan.monthly_income * 100).toFixed(0);
      return this.plan.emi_amount / this.plan.monthly_income > 0.45
        ? `EMI is ${ratio}% of monthly income — may stretch budget.`
        : `Affordable — EMI is only ${ratio}% of monthly income.`;
    },

    fmt(n) {
      return 'Rs. ' + Math.round(n).toLocaleString('en-IN');
    },

    formatDate(iso) {
      return new Date(iso).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
    },

    async copyLink() {
      await navigator.clipboard.writeText(window.location.href);
      this.copied = true;
      setTimeout(() => this.copied = false, 2000);
    }
  };
}
</script>
