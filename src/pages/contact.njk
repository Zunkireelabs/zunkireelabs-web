---
layout: base.njk
title: Contact Us | Zunkiree Labs
description: Get in touch with Zunkiree Labs. Let's discuss your project and how we can help bring your vision to life.
permalink: /contact/
---

{# =====================================================
   HERO SECTION - Dark with extra bottom padding for overlap
   ===================================================== #}
<section class="pt-28 pb-32 md:pt-36 md:pb-44 lg:pb-52" style="background-color: #EDF2F8;">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-6">
    <div class="max-w-2xl">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-normal text-gray-900 leading-tight mb-4">
        We'd love to hear from you
      </h1>
      <p class="text-lg text-gray-600">
        Fill out the form and a Zunkiree Labs team member will reach out
      </p>
    </div>
  </div>
</section>

{# =====================================================
   CONTACT FORM SECTION - Overlapping Two Column Layout
   ===================================================== #}
<section class="pb-12 md:pb-16 lg:pb-20 -mt-20 md:-mt-28 lg:-mt-36 relative overflow-hidden">
  {# Background SVG - Right aligned #}
  <div class="absolute top-0 right-0 w-1/2 h-full pointer-events-none hidden lg:block">
    <img src="/assets/images/contact-bg.svg" alt="" class="absolute top-1/2 right-0 -translate-y-1/2 w-auto h-[120%] max-w-none" aria-hidden="true">
  </div>
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-6 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

      {# Left: Contact Form (3/5 width) - Floating Card overlaps into hero #}
      <div class="lg:col-span-3">
        <form class="space-y-6 p-8 lg:p-10 bg-white shadow-xl" x-data="{ firstName: '', lastName: '', company: '', email: '', country: 'Nepal', phone: '', reason: '', message: '' }">

          {# Row 1: First Name + Last Name #}
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="firstName" class="block text-sm mb-2"><span class="text-zunkiree-600">*</span> <span class="text-gray-700">First Name</span></label>
              <input type="text" id="firstName" x-model="firstName" class="w-full px-4 py-3 bg-white border border-gray-300 text-gray-900 placeholder:text-gray-400 focus:border-zunkiree-600 focus:ring-1 focus:ring-zunkiree-600 outline-none transition-colors" required>
            </div>
            <div>
              <label for="lastName" class="block text-sm mb-2"><span class="text-zunkiree-600">*</span> <span class="text-gray-700">Last Name</span></label>
              <input type="text" id="lastName" x-model="lastName" class="w-full px-4 py-3 bg-white border border-gray-300 text-gray-900 placeholder:text-gray-400 focus:border-zunkiree-600 focus:ring-1 focus:ring-zunkiree-600 outline-none transition-colors" required>
            </div>
          </div>

          {# Row 2: Company + Email #}
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="company" class="block text-sm mb-2"><span class="text-zunkiree-600">*</span> <span class="text-gray-700">Company</span></label>
              <input type="text" id="company" x-model="company" class="w-full px-4 py-3 bg-white border border-gray-300 text-gray-900 placeholder:text-gray-400 focus:border-zunkiree-600 focus:ring-1 focus:ring-zunkiree-600 outline-none transition-colors" required>
            </div>
            <div>
              <label for="email" class="block text-sm mb-2"><span class="text-zunkiree-600">*</span> <span class="text-gray-700">Email</span></label>
              <input type="email" id="email" x-model="email" class="w-full px-4 py-3 bg-white border border-gray-300 text-gray-900 placeholder:text-gray-400 focus:border-zunkiree-600 focus:ring-1 focus:ring-zunkiree-600 outline-none transition-colors" required>
            </div>
          </div>

          {# Row 3: Country + Phone #}
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="country" class="block text-sm mb-2"><span class="text-zunkiree-600">*</span> <span class="text-gray-700">Country</span></label>
              <select id="country" x-model="country" class="w-full px-4 py-3 bg-white border border-gray-300 text-gray-900 focus:border-zunkiree-600 focus:ring-1 focus:ring-zunkiree-600 outline-none transition-colors" required>
                <option value="Nepal">Nepal</option>
                <option value="United States">United States</option>
                <option value="United Kingdom">United Kingdom</option>
                <option value="Canada">Canada</option>
                <option value="Australia">Australia</option>
                <option value="Germany">Germany</option>
                <option value="India">India</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div>
              <label for="phone" class="block text-sm text-gray-700 mb-2">Phone</label>
              <input type="tel" id="phone" x-model="phone" class="w-full px-4 py-3 bg-white border border-gray-300 text-gray-900 placeholder:text-gray-400 focus:border-zunkiree-600 focus:ring-1 focus:ring-zunkiree-600 outline-none transition-colors">
            </div>
          </div>

          {# Row 4: Contact Reason #}
          <div>
            <label for="reason" class="block text-sm mb-2"><span class="text-zunkiree-600">*</span> <span class="text-gray-700">Contact Reason</span></label>
            <select id="reason" x-model="reason" class="w-full px-4 py-3 bg-white border border-gray-300 text-gray-900 focus:border-zunkiree-600 focus:ring-1 focus:ring-zunkiree-600 outline-none transition-colors" required>
              <option value="">Select...</option>
              <option value="project">Start a new project</option>
              <option value="consultation">Request a consultation</option>
              <option value="partnership">Partnership inquiry</option>
              <option value="careers">Careers</option>
              <option value="support">Technical support</option>
              <option value="other">Other</option>
            </select>
          </div>

          {# Row 5: Message #}
          <div>
            <label for="message" class="block text-sm mb-2"><span class="text-zunkiree-600">*</span> <span class="text-gray-700">Message</span></label>
            <textarea id="message" x-model="message" rows="6" class="w-full px-4 py-3 bg-white border border-gray-300 text-gray-900 placeholder:text-gray-400 focus:border-zunkiree-600 focus:ring-1 focus:ring-zunkiree-600 outline-none transition-colors resize-none" required></textarea>
          </div>

          {# Privacy Notice #}
          <p class="text-sm text-gray-600 leading-relaxed">
            By submitting, I agree to the processing of my personal data in accordance with our <a href="/privacy/" class="text-gray-900 underline hover:text-zunkiree-600">Privacy Policy</a>.
          </p>

          {# Submit Button #}
          <button type="submit" class="w-full py-4 bg-zunkiree-600 text-white text-lg font-medium hover:bg-zunkiree-700 transition-colors">
            Submit
          </button>

        </form>
      </div>

      {# Right: Quick Links (2/5 width) - Pushed down to normal level #}
      <div class="lg:col-span-2 mt-20 md:mt-28 lg:mt-36 pt-8 lg:pt-12">
        <div class="lg:pl-8 lg:border-t border-gray-200 lg:pt-8">
          <h2 class="text-lg font-medium text-gray-900 mb-8">Need help with something specific?</h2>

          <div class="space-y-8">
            {# Email Us #}
            <a href="mailto:{{ site.email }}" class="group block">
              <div class="flex items-start gap-3">
                <span class="text-zunkiree-600 font-medium group-hover:underline">Email Us</span>
                <svg class="w-4 h-4 text-zunkiree-600 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </div>
              <p class="text-sm text-gray-500 mt-1">Direct contact for quick questions</p>
            </a>

            {# Schedule a Call #}
            <a href="tel:{{ site.phone }}" class="group block">
              <div class="flex items-start gap-3">
                <span class="text-zunkiree-600 font-medium group-hover:underline">Schedule a Call</span>
                <svg class="w-4 h-4 text-zunkiree-600 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </div>
              <p class="text-sm text-gray-500 mt-1">Book a discovery call with our team</p>
            </a>

            {# Resources #}
            <a href="/resources/" class="group block">
              <div class="flex items-start gap-3">
                <span class="text-zunkiree-600 font-medium group-hover:underline">Resources</span>
                <svg class="w-4 h-4 text-zunkiree-600 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </div>
              <p class="text-sm text-gray-500 mt-1">Documentation, guides, and case studies</p>
            </a>

            {# Our Location #}
            <div class="block">
              <div class="flex items-start gap-3">
                <span class="text-zunkiree-600 font-medium">Our Location</span>
                <svg class="w-4 h-4 text-zunkiree-600 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </div>
              <p class="text-sm text-gray-500 mt-1">{{ site.address.city }}, {{ site.address.country }}</p>
            </div>
          </div>

          {# Social Links #}
          <div class="mt-12 pt-8 border-t border-gray-200">
            <p class="text-sm text-gray-500 mb-4">Follow us</p>
            <div class="flex items-center gap-4">
              <a href="{{ site.social.twitter }}" class="text-gray-400 hover:text-gray-600 transition-colors" aria-label="Twitter">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href="{{ site.social.linkedin }}" class="text-gray-400 hover:text-gray-600 transition-colors" aria-label="LinkedIn">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
              <a href="{{ site.social.github }}" class="text-gray-400 hover:text-gray-600 transition-colors" aria-label="GitHub">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
              </a>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>
