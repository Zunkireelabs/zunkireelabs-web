{# =====================================================
   IN THE SPOTLIGHT — ServiceNow bento: large left card + 3 horizontal right cards
   ===================================================== #}
<section class="py-16 md:py-24">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">

    {# Section Header #}
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between mb-10">
      <div class="mb-6 lg:mb-0">
        <p class="text-xs uppercase tracking-widest text-zunkiree-400 font-medium mb-4">Resources</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-normal text-white">In the spotlight</h2>
      </div>
      <a href="/resources/" class="inline-flex items-center gap-2 text-zunkiree-400 font-medium hover:gap-3 transition-all">
        View all resources
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>

    {# ServiceNow bento: left large card + right 3 stacked horizontal cards #}
    <div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-4 items-stretch">

      {# Left — large featured card: image top, text bottom #}
      <a href="{{ spotlight[0].url }}"
        class="group flex flex-col overflow-hidden rounded-2xl transition-transform duration-300 hover:scale-[1.005]"
        style="background:linear-gradient(160deg,#0d2535 0%,#0a1f2b 55%,#071824 100%);">
        {# Image area — fills top portion #}
        <div class="flex-1 flex items-center justify-center p-8 min-h-[220px]">
          <img
            src="{{ spotlight[0].image }}"
            alt="{{ spotlight[0].title }}"
            class="w-full h-full object-contain max-h-56"
            loading="lazy"
          />
        </div>
        {# Text area below image — dark section #}
        <div class="px-7 py-6 border-t border-white/08" style="border-top:1px solid rgba(255,255,255,0.07);">
          <p class="text-[10px] uppercase tracking-widest text-zunkiree-400 font-medium mb-3">{{ spotlight[0].type }}</p>
          <h3 class="text-xl font-normal text-white leading-snug mb-3">{{ spotlight[0].title }}</h3>
          <p class="text-sm text-white/60 leading-relaxed mb-5">{{ spotlight[0].description }}</p>
          <span class="inline-flex items-center gap-1.5 text-sm text-zunkiree-400 font-medium group-hover:gap-2.5 transition-all">
            {{ spotlight[0].cta }}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </span>
        </div>
      </a>

      {# Right column — 3 horizontal thumbnail + text cards #}
      <div class="flex flex-col gap-4">
        {% for item in spotlight %}
        {% if loop.index > 1 %}
        <a href="{{ item.url }}"
          class="group flex flex-row overflow-hidden rounded-2xl flex-1 min-h-[120px] transition-transform duration-300 hover:scale-[1.01]"
          style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.07);">

          {# Left: small square thumbnail #}
          <div class="w-32 flex-shrink-0 relative overflow-hidden"
            style="
              {%- if loop.index == 2 %}background:linear-gradient(135deg,#0a1f2b 0%,#0b2238 100%);
              {%- elif loop.index == 3 %}background:linear-gradient(135deg,#0f2035 0%,#0a1a2c 100%);
              {%- else %}background:linear-gradient(135deg,#0c1e2c 0%,#091828 100%);
              {%- endif %}">
            <img
              src="{{ item.image }}"
              alt="{{ item.title }}"
              class="absolute inset-0 w-full h-full object-contain p-3"
              loading="lazy"
            />
          </div>

          {# Right: badge + title + CTA #}
          <div class="flex-1 flex flex-col justify-center px-5 py-4">
            <p class="text-[10px] uppercase tracking-widest text-zunkiree-400 font-medium mb-1.5">{{ item.type }}</p>
            <h3 class="text-sm font-normal text-white leading-snug line-clamp-2 mb-3">{{ item.title }}</h3>
            <span class="inline-flex items-center gap-1 text-xs text-zunkiree-400 font-medium group-hover:gap-2 transition-all">
              {{ item.cta }}
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </span>
          </div>

        </a>
        {% endif %}
        {% endfor %}
      </div>

    </div>

  </div>
</section>

