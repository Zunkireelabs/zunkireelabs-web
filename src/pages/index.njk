{# =====================================================
   IN THE SPOTLIGHT
   ===================================================== #}
<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-6">
    {# Section Header #}
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between mb-12">
      <div class="mb-6 lg:mb-0">
        <p class="text-xs uppercase tracking-widest text-zunkiree-600 font-medium mb-4">Resources</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-normal text-gray-900">In the spotlight</h2>
      </div>
      <a href="/resources/" class="inline-flex items-center gap-2 text-zunkiree-600 font-medium hover:gap-3 transition-all">
        View all resources
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>

    {# Spotlight Cards Grid #}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {% for item in spotlight %}
      <a href="{{ item.url }}" class="group block bg-white overflow-hidden transition-shadow duration-300 hover:shadow-xl">
        {# Card Image #}
        <div class="relative aspect-[16/10] overflow-hidden bg-gray-100">
          <img
            src="{{ item.image }}"
            alt="{{ item.title }}"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

        {# Card Content #}
        <div class="p-4">
          {# Type Badge #}
          <p class="text-[11px] uppercase tracking-wider text-gray-500 font-medium mb-1">{{ item.type }}</p>

          {# Title #}
          <h3 class="text-base font-normal text-gray-900 leading-snug line-clamp-2">
            {{ item.title }}
          </h3>

          {# CTA Link #}
          <span class="inline-flex items-center gap-1 text-sm text-blue-600 font-medium group-hover:gap-2 transition-all mt-8">
            {{ item.cta }}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </span>
        </div>
      </a>
      {% endfor %}
    </div>

  </div>
</section>

