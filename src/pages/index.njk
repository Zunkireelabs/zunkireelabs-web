        </div>
        <button @click="currentSlide = currentSlide < totalSlides - 1 ? currentSlide + 1 : 0" class="w-12 h-12 flex items-center justify-center rounded-full border border-white/20 text-white/50 hover:border-white hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </button>
      </div>
    </div>
  </div>
</section>

