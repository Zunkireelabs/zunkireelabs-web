      {# Sage gradient overlay — fades in from right #}
      <div class="absolute inset-0 pointer-events-none"
           style="background: linear-gradient(to right, transparent 28%, rgba(11,26,8,0.85) 50%, rgba(10,31,43,0.97) 100%);"></div>

      {# Sage glow — top right corner #}
      <div class="absolute top-0 right-0 w-72 h-72 pointer-events-none"
           style="background: radial-gradient(ellipse, rgba(144,169,89,0.2) 0%, transparent 70%);"></div>

      {# Right side content with glass box #}
      <div class="absolute right-0 top-0 bottom-0 flex items-center p-6 lg:p-8" style="width: 34%;">
        <template x-for="(study, index) in studies" :key="study.id">
          <div
            class="w-full"
            x-show="activeIndex === index"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 transform translate-y-4"
            x-transition:enter-end="opacity-100 transform translate-y-0"
            x-transition:leave="transition ease-in duration-200 absolute inset-0 flex items-center px-8 lg:px-12"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
          >
            {# Glass box #}
            <div class="rounded-2xl p-7 lg:p-9 w-full"
                 style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);">

              {# Client logo — white #}
              <div class="mb-6">
                <img
                  :src="study.logo"
                  :alt="study.name"
                  class="h-7 object-contain brightness-0 invert opacity-90"
                />
              </div>

              {# Big stat #}
              <div class="mb-2">
                <span class="text-6xl md:text-7xl font-light leading-none" style="color: #76b900;" x-text="study.stat"></span>
              </div>

              {# One-liner #}
              <p class="text-white/70 text-sm mb-7 leading-relaxed" x-text="study.cardText"></p>

              {# Learn More #}
              <a
                :href="study.ctaUrl"
                class="inline-flex items-center gap-2 text-sm font-medium transition-all hover:gap-3"
                style="color: #76b900;"
              >
                Learn More
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
            </div>
          </div>
        </template>
      </div>

    </div>

    {# Brand Logo Bar — below card #}
    <div class="flex items-stretch gap-2 mt-4">
      {# Play/Pause Button #}
      <button
        @click="togglePlay()"
        class="flex-shrink-0 w-14 h-16 flex items-center justify-center rounded-lg bg-white/5 hover:bg-white/10 transition-colors"
        :aria-label="isPlaying ? 'Pause carousel' : 'Play carousel'"
      >
        <svg x-show="!isPlaying" class="w-5 h-5 text-white/50" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
        <svg x-show="isPlaying" class="w-5 h-5 text-white/50" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
        </svg>
      </button>

      {# Client Logo Tabs #}
      <div
        x-ref="tabsContainer"
        class="flex-1 flex gap-2 overflow-x-auto scroll-smooth scrollbar-hide"
      >
        <template x-for="(study, index) in studies" :key="study.id">
          <button
            @click="goTo(index)"
            class="relative h-16 px-5 flex items-center justify-center transition-all duration-300 flex-shrink-0 rounded-lg"
            style="min-width: calc((100% - 32px) / 5);"
            :class="activeIndex === index ? 'bg-white/10' : 'bg-white/5 hover:bg-white/8'"
          >
            <img
              :src="study.logo"
              :alt="study.name"
              class="max-h-7 max-w-[110px] object-contain transition-all duration-300 brightness-0 invert"
              :class="activeIndex === index ? 'opacity-100' : 'opacity-40 hover:opacity-60'"
            />
            {# Progress bar #}
            <div
              class="absolute bottom-0 left-0 h-0.5 rounded-b-lg bg-zunkiree-400"
              :class="activeIndex === index && isPlaying ? '' : 'hidden'"
              :style="`width: ${progress}%`"
            ></div>
            <div
              class="absolute bottom-0 left-0 right-0 h-0.5 rounded-b-lg bg-zunkiree-400"
              :class="activeIndex === index && !isPlaying ? '' : 'hidden'"
            ></div>
          </button>
        </template>
      </div>
    </div>

  </div>
</section>

<script>
  function caseStudyCarousel() {
    return {
      activeIndex: 0,
      isPlaying: true,
      progress: 0,
      interval: null,
      duration: 5000, // 5 seconds per slide

      studies: [
        {
          id: 'admizz',
          name: 'Admizz Education',
          logo: '/images/clients/admizz.webp',
