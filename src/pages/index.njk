      {# Full-width background images — fade between slides #}
      <template x-for="(study, index) in studies" :key="'visual-' + study.id">
        <div class="absolute inset-0 transition-opacity duration-500"
             :class="activeIndex === index ? 'opacity-100' : 'opacity-0'">
          <img
            :src="study.image"
            :alt="study.name + ' case study'"
