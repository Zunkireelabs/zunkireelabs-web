          cardText: 'From prototype to production in a third of the time.',
          image: 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=800&h=600&fit=crop',
          ctaText: 'Learn More',
          ctaUrl: '/case-studies/carbon-spark/'
        },
        {
          id: 'corecloud365',
          name: 'Corecloud365',
          logo: '/images/clients/corecloud365.svg',
          stat: '60%',
          statLabel: 'cost reduction',
          headline: 'Corecloud365 cuts costs by 60%',
          description: 'AI-powered automation replaced manual cloud ops. Corecloud365 now runs leaner without sacrificing a single capability.',
          cardText: 'Leaner cloud operations, zero capability trade-offs.',
          image: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=800&h=600&fit=crop',
          ctaText: 'Learn More',
          ctaUrl: '/case-studies/corecloud365/'
        },
        {
          id: 'rapid-investment',
          name: 'Rapid Investment',
          logo: '/images/clients/rapid-investment.svg',
          stat: '10x',
          statLabel: 'faster analysis',
          headline: 'Due diligence in days, not weeks',
          description: 'Rapid Investment analyzes opportunities 10x faster with Zunkiree\'s AI systems — without missing a single signal.',
          cardText: 'Investment opportunities analyzed in days, not weeks.',
          image: 'https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?w=800&h=600&fit=crop',
          ctaText: 'Learn More',
          ctaUrl: '/case-studies/rapid-investment/'
        },
        {
          id: 'cms-group',
          name: 'CMS Group',
          logo: '/images/clients/cms-group.webp',
          stat: '85%',
          statLabel: 'automation rate',
          headline: 'CMS Group automates 85% of document work',
          description: 'Their team used to drown in paperwork. Now 85% runs automatically, and the team focuses on strategy.',
          cardText: '85% of document workflows now run without human input.',
          image: 'https://images.unsplash.com/photo-1497215728101-856f4ea42174?w=800&h=600&fit=crop',
          ctaText: 'Learn More',
          ctaUrl: '/case-studies/cms-group/'
        },
        {
          id: 'mach24orbital',
          name: 'Mach24 Orbital',
          logo: '/images/clients/mach24orbital.webp',
          stat: '50%',
          statLabel: 'faster launches',
          headline: 'Mach24 halves satellite launch prep time',
          description: 'Deployment workflows are complex. Zunkiree\'s AI systems cut Mach24\'s preparation window from weeks to days.',
          cardText: 'Satellite launch prep cut from weeks to days.',
          image: 'https://images.unsplash.com/photo-1516849841032-87cbac4d88f7?w=800&h=600&fit=crop',
          ctaText: 'Learn More',
          ctaUrl: '/case-studies/mach24orbital/'
        },
        {
          id: 'khushbu-nirman',
          name: 'Khushbu Nirman Sewa',
          logo: '/images/clients/khushbu-nirman-sewa.webp',
          stat: '40%',
          statLabel: 'efficiency gain',
          headline: 'Khushbu Nirman runs 40% leaner',
          description: 'Manual follow-ups and tracking used to eat hours. AI-powered oversight gave them back 40% of their operational capacity.',
          cardText: '40% of operational hours reclaimed through AI oversight.',
          image: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=800&h=600&fit=crop',
          ctaText: 'Learn More',
          ctaUrl: '/case-studies/khushbu-nirman/'
        },
        {
          id: 'prime-tiles',
          name: 'Prime Tiles',
          logo: '/images/clients/prime-tiles.webp',
          stat: '2x',
          statLabel: 'sales growth',
          headline: 'Prime Tiles doubles sales with AI search',
          description: 'Customers couldn\'t find what they wanted — so they left. Zunkiree Search fixed that. Conversions doubled in the first quarter.',
          cardText: 'Customers find what they want. Conversions doubled.',
          image: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&h=600&fit=crop',
          ctaText: 'Learn More',
          ctaUrl: '/case-studies/prime-tiles/'
        },
        {
          id: 'khems-cleaning',
          name: 'Khems Cleaning',
          logo: '/images/clients/khems-cleaning.webp',
          stat: '70%',
          statLabel: 'booking increase',
          headline: 'Khems Cleaning grows 70% without growing headcount',
          description: 'Manual scheduling was losing them customers. An AI booking system filled every gap and scaled capacity automatically.',
          cardText: 'AI scheduling filled every gap. Bookings up 70%.',
          image: 'https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=800&h=600&fit=crop',
          ctaText: 'Learn More',
          ctaUrl: '/case-studies/khems-cleaning/'
        }
      ],

      init() {
        this.startAutoPlay();
      },

      startAutoPlay() {
        if (this.interval) clearInterval(this.interval);
        this.progress = 0;

        const tick = 50; // Update every 50ms for smooth progress
        this.interval = setInterval(() => {
          if (this.isPlaying) {
            this.progress += (tick / this.duration) * 100;
            if (this.progress >= 100) {
              this.next();
            }
          }
        }, tick);
      },

      next() {
        this.activeIndex = (this.activeIndex + 1) % this.studies.length;
        this.progress = 0;
        this.scrollToActive();
      },

      goTo(index) {
        this.activeIndex = index;
        this.progress = 0;
        this.isPlaying = false; // Pause when user manually selects
        this.scrollToActive();
      },

      togglePlay() {
        this.isPlaying = !this.isPlaying;
        if (this.isPlaying) {
          this.progress = 0; // Reset progress when resuming
        }
      },

      scrollToActive() {
        // Scroll only the tab container horizontally (not the page)
        this.$nextTick(() => {
          const container = this.$refs.tabsContainer;
          const buttons = container.querySelectorAll('button');
          const activeButton = buttons[this.activeIndex];

          if (activeButton && container) {
            // Calculate scroll position to center the active button
            const containerWidth = container.offsetWidth;
            const buttonLeft = activeButton.offsetLeft;
            const buttonWidth = activeButton.offsetWidth;

            // Scroll container only (not the page)
            container.scrollTo({
              left: buttonLeft - (containerWidth / 2) + (buttonWidth / 2),
              behavior: 'smooth'
            });
          }
        });
      }
    }
  }
</script>

