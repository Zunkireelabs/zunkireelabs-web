<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-6">
    {# Section Header #}
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between mb-12">
      <div class="max-w-2xl mb-6 lg:mb-0">
        <p class="text-xs uppercase tracking-widest text-zunkiree-600 font-medium mb-4">Our Services</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-normal text-gray-900 mb-4">Engineering excellence at every layer</h2>
        <p class="text-lg text-gray-600">
          From AI systems to data platforms, we build infrastructure-level solutions that compound value over time.
        </p>
      </div>
      <a href="/services/" class="inline-flex items-center gap-2 text-zunkiree-600 font-medium hover:gap-3 transition-all">
        View all services
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>

    {# Services Slider #}
    <div x-data="{ currentSlide: 0, totalSlides: Math.ceil({{ services | length }} / 2) }" class="relative">
      {# Slider Container #}
      <div class="overflow-hidden">
        <div
          class="flex transition-transform duration-500 ease-out"
          :style="'transform: translateX(-' + (currentSlide * 100) + '%)'"
        >
          {% for service in services %}
          <div class="w-full md:w-1/2 flex-shrink-0 px-2">
            {# Service Card #}
            <div class="bg-white border border-gray-200 overflow-hidden">
              {# Card Top - Icon + Content #}
              <div class="p-8 flex flex-col md:flex-row gap-6">
                {# Icon #}
                <div class="flex-shrink-0">
                  <div class="w-20 h-20 flex items-center justify-center">
                    {# SVG Gradient for service icons #}
                    <svg width="0" height="0" class="absolute">
                      <defs>
                        <linearGradient id="service-icon-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                          <stop offset="0%" style="stop-color:#ff6b5c"/>
                          <stop offset="100%" style="stop-color:#eb1600"/>
                        </linearGradient>
                      </defs>
                    </svg>
                    {% if service.icon == "ai" %}
                    <svg class="w-16 h-16" fill="none" stroke="url(#service-icon-gradient)" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                    </svg>
                    {% elif service.icon == "chat" %}
                    <svg class="w-16 h-16" fill="none" stroke="url(#service-icon-gradient)" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                    </svg>
                    {% elif service.icon == "data" %}
                    <svg class="w-16 h-16" fill="none" stroke="url(#service-icon-gradient)" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"></path>
                    </svg>
                    {% elif service.icon == "code" %}
                    <svg class="w-16 h-16" fill="none" stroke="url(#service-icon-gradient)" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                    </svg>
                    {% elif service.icon == "cloud" %}
                    <svg class="w-16 h-16" fill="none" stroke="url(#service-icon-gradient)" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path>
                    </svg>
                    {% elif service.icon == "globe" %}
                    <svg class="w-16 h-16" fill="none" stroke="url(#service-icon-gradient)" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
                    </svg>
                    {% elif service.icon == "mobile" %}
                    <svg class="w-16 h-16" fill="none" stroke="url(#service-icon-gradient)" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                    </svg>
                    {% elif service.icon == "search" %}
                    <svg class="w-16 h-16" fill="none" stroke="url(#service-icon-gradient)" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                    </svg>
                    {% endif %}
                  </div>
                </div>

                {# Divider #}
                <div class="hidden md:block w-px bg-gray-200"></div>

                {# Content #}
                <div class="flex-1">
                  <h3 class="text-2xl font-normal text-gray-900 mb-3">{{ service.title }}</h3>
                  <p class="text-gray-600 mb-6 leading-relaxed">{{ service.description }}</p>
                  <a href="{{ service.url }}" class="inline-flex items-center justify-center px-6 py-3 bg-zunkiree-600 text-white font-medium hover:bg-zunkiree-700 transition-colors">
                    {{ service.cta }}
                  </a>
                </div>
              </div>

              {# Card Bottom - Client Logos #}
              <div class="border-t border-gray-200 px-8 py-6">
                <div class="flex items-center justify-end gap-6 md:gap-8">
                  {% for client in service.clients %}
                  <img
                    src="{{ client.logo }}"
                    alt="{{ client.name }}"
                    class="h-5 w-auto object-contain"
                  />
                  {% endfor %}
                </div>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>

      {# Navigation #}
      <div class="flex items-center justify-center gap-6 mt-8">
        {# Prev Button #}
        <button
          @click="currentSlide = currentSlide > 0 ? currentSlide - 1 : totalSlides - 1"
          class="w-12 h-12 flex items-center justify-center border border-gray-300 text-gray-600 hover:border-gray-900 hover:text-gray-900 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>

        {# Dots #}
        <div class="flex items-center gap-2">
          <template x-for="i in totalSlides" :key="i">
            <button
              @click="currentSlide = i - 1"
              class="w-2.5 h-2.5 rounded-full transition-colors"
              :class="currentSlide === (i - 1) ? 'bg-zunkiree-600' : 'bg-gray-300 hover:bg-gray-400'"
            ></button>
          </template>
        </div>

        {# Next Button #}
        <button
          @click="currentSlide = currentSlide < totalSlides - 1 ? currentSlide + 1 : 0"
          class="w-12 h-12 flex items-center justify-center border border-gray-300 text-gray-600 hover:border-gray-900 hover:text-gray-900 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

