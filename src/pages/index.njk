    <div class="mb-12">
      <p class="text-xs uppercase tracking-widest text-zunkiree-600 font-medium mb-4">Case Studies</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-normal text-gray-900">How innovators use Zunkiree</h2>
    </div>

    {# Logo Tab Bar #}
    <div class="flex items-stretch gap-2">
      {# Play/Pause Button #}
      <button
        @click="togglePlay()"
        class="flex-shrink-0 w-14 h-20 flex items-center justify-center bg-gray-100 hover:bg-gray-200 transition-colors"
        :aria-label="isPlaying ? 'Pause carousel' : 'Play carousel'"
      >
        {# Play Icon #}
        <svg x-show="!isPlaying" class="w-5 h-5 text-gray-600" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
        {# Pause Icon #}
        <svg x-show="isPlaying" class="w-5 h-5 text-gray-600" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
        </svg>
      </button>

      {# Client Logo Tabs - Horizontal Scroll (5 visible at once) #}
      <div
        x-ref="tabsContainer"
        class="flex-1 flex gap-2 overflow-x-auto scroll-smooth scrollbar-hide"
        style="--tab-count: 5;"
      >
        <template x-for="(study, index) in studies" :key="study.id">
          <button
            @click="goTo(index)"
            :x-ref="'tab-' + index"
            class="relative h-20 px-6 flex items-center justify-center transition-all duration-300 flex-shrink-0"
            style="min-width: calc((100% - 32px) / 5);"
            :class="activeIndex === index ? 'bg-white shadow-sm' : 'bg-gray-100 hover:bg-gray-50'"
          >
            <img
              :src="study.logo"
              :alt="study.name"
              class="max-h-8 max-w-[120px] object-contain transition-all duration-300"
              :class="activeIndex === index ? 'grayscale-0 opacity-100' : 'grayscale opacity-50 hover:opacity-70'"
            />
            {# Progress Bar (only on active, animates while playing) #}
            <div
              class="absolute bottom-0 left-0 h-1 bg-zunkiree-600"
              :class="activeIndex === index && isPlaying ? '' : 'hidden'"
              :style="`width: ${progress}%`"
            ></div>
            {# Static indicator (only on active, when paused) #}
            <div
              class="absolute bottom-0 left-0 right-0 h-1 bg-zunkiree-600"
              :class="activeIndex === index && !isPlaying ? '' : 'hidden'"
            ></div>
          </button>
        </template>
      </div>
    </div>

    {# Content Area - Separate container with gap #}
    <div class="mt-6 bg-white border border-gray-200">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
        {# Left: Content #}
        <div class="p-8 lg:p-12 flex flex-col justify-center min-h-[500px]">
          <template x-for="(study, index) in studies" :key="study.id">
            <div
              x-show="activeIndex === index"
              x-transition:enter="transition ease-out duration-300"
              x-transition:enter-start="opacity-0 transform translate-y-4"
              x-transition:enter-end="opacity-100 transform translate-y-0"
              x-transition:leave="transition ease-in duration-200 absolute"
              x-transition:leave-start="opacity-100"
              x-transition:leave-end="opacity-0"
            >
              {# Client Logo Large #}
              <div class="mb-6">
                <img
                  :src="study.logo"
                  :alt="study.name"
                  class="h-10 object-contain"
                />
              </div>

              {# Big Stat #}
              <div class="mb-4">
                <span class="text-5xl md:text-6xl lg:text-7xl font-light text-gray-900" x-text="study.stat"></span>
                <span class="text-lg text-gray-500 ml-2" x-text="study.statLabel"></span>
              </div>

              {# Headline #}
              <h3 class="text-xl md:text-2xl font-medium text-gray-900 mb-4" x-text="study.headline"></h3>

              {# Description #}
              <p class="text-gray-600 mb-6 max-w-lg" x-text="study.description"></p>

              {# CTA #}
              <a
                :href="study.ctaUrl"
                class="inline-flex items-center gap-2 text-zunkiree-600 font-medium hover:gap-3 transition-all"
              >
                <span x-text="study.ctaText"></span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </a>
            </div>
          </template>
        </div>

        {# Right: Image #}
        <div class="relative h-64 lg:h-auto lg:min-h-[500px] overflow-hidden bg-gray-100">
          {# Case study images with transition #}
          <template x-for="(study, index) in studies" :key="'visual-' + study.id">
            <div
              class="absolute inset-0"
              :class="activeIndex === index ? '' : 'hidden'"
            >
              <img
                :src="study.image"
                :alt="study.name + ' case study'"
                class="w-full h-full object-cover"
              />
              {# Subtle overlay for better contrast #}
              <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent"></div>
            </div>
          </template>
          {# Accent line #}
          <div class="absolute bottom-0 left-0 w-1/3 h-1 bg-zunkiree-600"></div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  function caseStudyCarousel() {
    return {
      activeIndex: 0,
      isPlaying: true,
      progress: 0,
      interval: null,
      duration: 5000, // 5 seconds per slide

      studies: [
        {
          id: 'admizz',
          name: 'Admizz Education',
          logo: '/images/clients/admizz.webp',
          stat: '45%',
          statLabel: 'faster responses',
          headline: 'Admizz transforms student inquiry management',
          description: 'Admizz Education revolutionized their student inquiry process with Zunkiree Search, reducing response time and dramatically improving student satisfaction across their consultancy network.',
          image: 'https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=800&h=600&fit=crop',
          ctaText: 'Read the case study',
          ctaUrl: '/case-studies/admizz-education/'
        },
        {
          id: 'carbon-spark',
          name: 'Carbon Spark',
          logo: '/images/clients/carbon-spark.webp',
          stat: '3x',
          statLabel: 'faster deployment',
          headline: 'Carbon Spark accelerates AI adoption',
          description: 'Carbon Spark leveraged our AI infrastructure to deploy intelligent systems 3x faster, enabling rapid scaling of their sustainability analytics platform.',
          image: 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=800&h=600&fit=crop',
          ctaText: 'Read the case study',
          ctaUrl: '/case-studies/carbon-spark/'
        },
        {
          id: 'corecloud365',
          name: 'Corecloud365',
          logo: '/images/clients/corecloud365.svg',
          stat: '60%',
          statLabel: 'cost reduction',
          headline: 'Corecloud365 optimizes cloud operations',
          description: 'Corecloud365 achieved significant cost savings by integrating our AI-powered search and automation tools into their cloud management platform.',
          image: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=800&h=600&fit=crop',
          ctaText: 'Read the case study',
          ctaUrl: '/case-studies/corecloud365/'
        },
        {
          id: 'rapid-investment',
          name: 'Rapid Investment',
          logo: '/images/clients/rapid-investment.svg',
          stat: '10x',
          statLabel: 'faster analysis',
          headline: 'Rapid Investment transforms due diligence',
          description: 'Rapid Investment Group uses our AI systems to analyze investment opportunities 10x faster, giving them a competitive edge in the financial markets.',
          image: 'https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?w=800&h=600&fit=crop',
          ctaText: 'Read the case study',
          ctaUrl: '/case-studies/rapid-investment/'
        },
        {
          id: 'cms-group',
          name: 'CMS Group',
          logo: '/images/clients/cms-group.webp',
          stat: '85%',
          statLabel: 'automation rate',
          headline: 'CMS Group automates enterprise workflows',
          description: 'CMS Group achieved 85% automation of their document processing workflows, freeing their team to focus on high-value strategic work.',
          image: 'https://images.unsplash.com/photo-1497215728101-856f4ea42174?w=800&h=600&fit=crop',
          ctaText: 'Read the case study',
          ctaUrl: '/case-studies/cms-group/'
        },
        {
          id: 'mach24orbital',
          name: 'Mach24 Orbital',
          logo: '/images/clients/mach24orbital.webp',
          stat: '50%',
          statLabel: 'faster launches',
          headline: 'Mach24 Orbital streamlines space operations',
          description: 'Mach24 Orbital integrated our AI systems to optimize their satellite deployment workflows, cutting launch preparation time in half.',
          image: 'https://images.unsplash.com/photo-1516849841032-87cbac4d88f7?w=800&h=600&fit=crop',
          ctaText: 'Read the case study',
          ctaUrl: '/case-studies/mach24orbital/'
        },
        {
          id: 'khushbu-nirman',
          name: 'Khushbu Nirman Sewa',
          logo: '/images/clients/khushbu-nirman-sewa.webp',
          stat: '40%',
          statLabel: 'efficiency gain',
          headline: 'Khushbu Nirman digitizes construction management',
          description: 'Khushbu Nirman Sewa transformed their construction project management with our AI-powered tracking and resource optimization tools.',
          image: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=800&h=600&fit=crop',
          ctaText: 'Read the case study',
          ctaUrl: '/case-studies/khushbu-nirman/'
        },
        {
          id: 'prime-tiles',
          name: 'Prime Tiles',
          logo: '/images/clients/prime-tiles.webp',
          stat: '2x',
          statLabel: 'sales growth',
          headline: 'Prime Tiles revolutionizes customer discovery',
          description: 'Prime Tiles deployed Zunkiree Search to help customers find the perfect tiles instantly, doubling their online conversion rates.',
          image: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&h=600&fit=crop',
          ctaText: 'Read the case study',
          ctaUrl: '/case-studies/prime-tiles/'
        },
        {
          id: 'khems-cleaning',
          name: 'Khems Cleaning',
          logo: '/images/clients/khems-cleaning.webp',
          stat: '70%',
          statLabel: 'booking increase',
          headline: 'Khems Cleaning scales with smart scheduling',
          description: 'Khems Cleaning Services implemented our AI booking system, dramatically increasing their service capacity and customer satisfaction.',
          image: 'https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=800&h=600&fit=crop',
          ctaText: 'Read the case study',
          ctaUrl: '/case-studies/khems-cleaning/'
        }
      ],

      init() {
        this.startAutoPlay();
      },

      startAutoPlay() {
        if (this.interval) clearInterval(this.interval);
        this.progress = 0;

        const tick = 50; // Update every 50ms for smooth progress
        this.interval = setInterval(() => {
          if (this.isPlaying) {
            this.progress += (tick / this.duration) * 100;
            if (this.progress >= 100) {
              this.next();
            }
          }
        }, tick);
      },

      next() {
        this.activeIndex = (this.activeIndex + 1) % this.studies.length;
        this.progress = 0;
        this.scrollToActive();
      },

      goTo(index) {
        this.activeIndex = index;
        this.progress = 0;
        this.isPlaying = false; // Pause when user manually selects
        this.scrollToActive();
      },

      togglePlay() {
        this.isPlaying = !this.isPlaying;
        if (this.isPlaying) {
          this.progress = 0; // Reset progress when resuming
        }
      },

      scrollToActive() {
        // Scroll only the tab container horizontally (not the page)
        this.$nextTick(() => {
          const container = this.$refs.tabsContainer;
          const buttons = container.querySelectorAll('button');
          const activeButton = buttons[this.activeIndex];

          if (activeButton && container) {
            // Calculate scroll position to center the active button
            const containerWidth = container.offsetWidth;
            const buttonLeft = activeButton.offsetLeft;
            const buttonWidth = activeButton.offsetWidth;

            // Scroll container only (not the page)
            container.scrollTo({
              left: buttonLeft - (containerWidth / 2) + (buttonWidth / 2),
              behavior: 'smooth'
            });
          }
        });
      }
    }
  }
</script>

