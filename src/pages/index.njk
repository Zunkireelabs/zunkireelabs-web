                </div>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
      <div class="flex items-center justify-center gap-6 mt-8">
        <button @click="currentSlide = currentSlide > 0 ? currentSlide - 1 : totalSlides - 1" class="w-12 h-12 flex items-center justify-center rounded-full border border-white/20 text-white/50 hover:border-white hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        </button>
        <div class="flex items-center gap-2">
          <template x-for="i in totalSlides" :key="i">
            <button @click="currentSlide = i - 1" class="w-2.5 h-2.5 rounded-full transition-colors" :class="currentSlide === (i - 1) ? 'bg-zunkiree-500' : 'bg-white/20 hover:bg-white/40'"></button>
